      <Column Name="Email" DataType="System.String"/>
      <Column Name="Website" DataType="System.String"/>
      <Column Name="Address" DataType="System.String"/>
      <Column Name="Logo" DataType="System.Byte[]" BindableControl="Picture"/>
    </TableDataSource>
    <TableDataSource Name="Current Account" ReferenceName="Current Account" DataType="System.Int32" Enabled="true">
      <Column Name="Kind" DataType="System.Int32"/>
      <Column Name="Code" DataType="System.String"/>
      <Column Name="Name1" DataType="System.String"/>
      <Column Name="Name2" DataType="System.String"/>
