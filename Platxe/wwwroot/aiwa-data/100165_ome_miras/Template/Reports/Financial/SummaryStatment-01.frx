      <Column Name="Fax" DataType="System.String"/>
      <Column Name="Email" DataType="System.String"/>
      <Column Name="Website" DataType="System.String"/>
      <Column Name="Address" DataType="System.String"/>
    </TableDataSource>
    <Total Name="Total" Expression="[Report Data.debit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="Total1" Expression="[Report Data.credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="Total2" Expression="[Report Data.debit]-[Report Data.credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
  </Dictionary>
