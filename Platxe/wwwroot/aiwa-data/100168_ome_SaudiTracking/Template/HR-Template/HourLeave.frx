  public class ReportScript
  {
    private void Data1_AfterData(object sender, EventArgs e)
    {
      switch(((Int32)Report.GetColumnValue(&quot;Request data.LeaveKind&quot;)))
      {
        case 0:
          chka1.Checked=true;
          chke1.Checked=true;
        break;
        case 1:
          chka2.Checked=true;
          chke2.Checked=true;
          break;
        case 2:
          chka3.Checked=true;
          chke3.Checked=true;
          break;
      }
    }
  }
}
