      <Column Name="LastDate" DataType="System.DateTime"/>
    </TableDataSource>
    <TableDataSource Name="Account Details" ReferenceName="Account Details" DataType="System.Int32" Enabled="true">
      <Column Name="Kind" DataType="System.Int32"/>
      <Column Name="Code" DataType="System.String"/>
      <Column Name="Name1" DataType="System.String"/>
      <Column Name="Name2" DataType="System.String"/>
      <Column Name="Key" DataType="System.Guid"/>
      <Column Name="Parent" DataType="System.String"/>
      <Column Name="Level" DataType="System.Int32"/>
    </TableDataSource>
    <Total Name="Total1" Expression="[Report Data.Debit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="Total2" Expression="[Report Data.Credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="Total" Expression="[Report Data.Debit]-[Report Data.Credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
  </Dictionary>
