<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="08/26/2020 14:33:58" ReportInfo.Modified="03/27/2021 13:36:50" ReportInfo.CreatorVersion="2020.3.7.0">
  <ScriptText>using System;
using System.Collections;
using System.Collections.Generic;
using System.ComponentModel;
using System.Windows.Forms;
using System.Drawing;
using System.Data;
using FastReport;
using FastReport.Data;
using FastReport.Dialog;
using FastReport.Barcode;
using FastReport.Table;
using FastReport.Utils;

namespace FastReport
{
  public class ReportScript
  {
    decimal balance=0;
    private void Data1_AfterData(object sender, EventArgs e)
    {
      balance += ((Decimal)Report.GetColumnValue(&quot;Report Data.Debit&quot;))- ((Decimal)Report.GetColumnValue(&quot;Report Data.Credit&quot;));
      Text12.Text=balance.ToString(&quot;n2&quot;)  ;
    }
  }
}
</ScriptText>
  <Dictionary>
    <TableDataSource Name="Company Profile" ReferenceName="Company Profile" DataType="System.Int32" Enabled="true">
      <Column Name="ArabicName" DataType="System.String"/>
      <Column Name="EnglishName" DataType="System.String"/>
