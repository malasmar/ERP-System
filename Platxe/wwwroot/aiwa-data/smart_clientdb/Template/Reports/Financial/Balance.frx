  <Dictionary>
    <TableDataSource Name="Company Profile" ReferenceName="Company Profile" DataType="System.Int32" Enabled="true">
      <Column Name="ArabicName" DataType="System.String"/>
      <Column Name="EnglishName" DataType="System.String"/>
      <Column Name="RegistrationCode" DataType="System.String"/>
      <Column Name="CommercialType" DataType="System.String"/>
      <Column Name="Kind" DataType="System.String"/>
      <Column Name="VATRegestration" DataType="System.String"/>
