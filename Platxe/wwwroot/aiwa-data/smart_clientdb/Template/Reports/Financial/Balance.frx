      <Column Name="CateName2" DataType="System.String"/>
      <Column Name="FirstDate" DataType="System.DateTime"/>
      <Column Name="LastDate" DataType="System.DateTime"/>
    </TableDataSource>
    <Total Name="totOpen" Expression="[Report Data.Opening]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totDebit" Expression="[Report Data.Debit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totCredit" Expression="[Report Data.Credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totCurrent" Expression="[Report Data.Debit]-[Report Data.Credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totBalance" Expression="[Report Data.Opening]+[Report Data.Debit]-[Report Data.Credit]" Evaluator="Data1" PrintOn="ReportSummary1"/>
  </Dictionary>
