      <Column Name="DepartmentKey" DataType="System.Guid"/>
      <Column Name="CostCenter" DataType="System.Guid"/>
      <Column Name="atDate" DataType="System.DateTime"/>
    </TableDataSource>
    <Total Name="totSalary" Expression="[Report Data.Salary]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totBen1" Expression="[Report Data.Benefit1]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totBen2" Expression="[Report Data.Benefit2]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totReg" Expression="[Report Data.Registered]" Evaluator="Data1" PrintOn="ReportSummary1"/>
    <Total Name="totRem" Expression="[Report Data.Benefit1]+[Report Data.Benefit2]-[Report Data.Registered]" Evaluator="Data1" PrintOn="ReportSummary1"/>
  </Dictionary>
