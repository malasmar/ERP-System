using FastReport.Utils;

namespace FastReport
{
  public class ReportScript
  {
 

    private void Data1_AfterData(object sender, EventArgs e)
    {
      string x=&quot;&quot;;
      for(int i=0;i&lt;=((Int32)Report.GetColumnValue(&quot;Report Details.Level&quot;));++i)
      {
        x = x + &quot;  &quot;;
      }
      Text58.Text= x + ((String)Report.GetColumnValue(&quot;Report Details.Name1&quot;));
     
    }
  }
}
</ScriptText>
  <Dictionary>
    <TableDataSource Name="Company Profile" ReferenceName="Company Profile" DataType="System.Int32" Enabled="true">
