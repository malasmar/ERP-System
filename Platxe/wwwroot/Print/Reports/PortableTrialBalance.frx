      <Column Name="Credit" DataType="System.Decimal"/>
      <Column Name="Source" DataType="System.Boolean" BindableControl="CheckBox"/>
      <Column Name="Row" DataType="System.Int64"/>
      <Column Name="DC" DataType="System.Boolean" BindableControl="CheckBox"/>
      <Column Name="ExpensesKind" DataType="System.Int32"/>
    </TableDataSource>
    <Parameter Name="FirstDate" DataType="System.String"/>
    <Parameter Name="LastDate" DataType="System.String"/>
    <Total Name="OD" Expression="[Report Details.oDebit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.T]==0"/>
    <Total Name="OC" Expression="[Report Details.oCredit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.T]==0"/>
    <Total Name="TD" Expression="[Report Details.tbDebit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.T]==0"/>
    <Total Name="TC" Expression="[Report Details.tbCredit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.T]==0"/>
    <Total Name="D" Expression="[Report Details.Debit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.Level]==1"/>
    <Total Name="C" Expression="[Report Details.Credit]" Evaluator="Data1" PrintOn="ReportSummary1" EvaluateCondition="[Report Details.Level]==1"/>
  </Dictionary>
