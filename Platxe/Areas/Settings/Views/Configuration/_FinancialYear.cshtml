@model CLiCore.Configuration.FinancialYear
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iT.T(xLan,"1819","Financial Year")</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <form id="frm-FinancialYear" data-parsley-validate="true">
        <div class="modal-body">
            @Html.HiddenFor(m => m.Key)
            @{
                if (Model.Key != null)
                {
                    <div class="xkey text-gray">@iT.T(xLan,"1299","Key"): @Model.Key</div>
                }
            }
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1265","No")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().NumberBoxFor(m => m.No).ID("cnt-No").Width(120) 
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1785","From")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().DateBoxFor(m => m.From).ID("cnt-From").Width(200).DisplayFormat("dd.MM.yyyy").InputAttr("required", true)
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1786","Last")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().DateBoxFor(m => m.Last).ID("cnt-Last").Width(200).DisplayFormat("dd.MM.yyyy").InputAttr("required", true)
                </div>
            </div>
               <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1357","Closed")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().SwitchFor(m => m.Closed).ID("cnt-Closed").Width(65).SwitchedOnText("Closed").SwitchedOffText("Opening")
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1282","Status")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().SwitchFor(m => m.Disable).ID("cnt-Disable").Width(65).SwitchedOnText("Disable").SwitchedOffText("Active")
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <div class="btn-group">
                <button type="submit" class="btn btn-yellow text-dark">@iT.T(xLan,"1197","Save Change")</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1198","Cancel")</button>
            </div>
        </div>
    </form>
</div>
<script class="append-on-ajax-script">
    $(document).ready(function() {
        $("#frm-FinancialYear").submit(function(event) {
            event.preventDefault();
            SaveAccount();
        });
    });
    function SaveAccount() {
        var data = $('#frm-FinancialYear').serialize();
        $.ajax({
            type: "POST",
            url: "/api/Settings/iconfiguration/UpdateFinancialYear",
            data: data,
            dataType: "json",
            success: function(response) {
                $("#mod-FinancialYear").modal('toggle');
                RefreshGrid();
            },
            failure: function(response) {
                alert(response);
            },
            error: function(response) {
                alert(response.responseText);
            }
        });
    }
</script>
