                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2252","Benefit-2")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Benefit2).ID("cnt-Benefit2").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2253","Benefit-3")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Benefit3).ID("cnt-Benefit3").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                </div>
                <div class="tab-pane fade" id="nav-pills-tab-3">
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2254","Absence")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Absence).ID("cnt-Absence").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2255","Late")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Late).ID("cnt-Late").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2256","Penalty")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Penalty).ID("cnt-Penalty").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2257","Insurance")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Insurance).ID("cnt-Insurance").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2258","Deduction-1")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Deduction1).ID("cnt-Deduction1").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2259","Deduction-2")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Deduction2).ID("cnt-Deduction2").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2260","Deduction-3")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Deduction3).ID("cnt-Deduction3").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                </div>


            </div>


        </div>
        <div class="modal-footer">
            <div class="btn-group">
                <button type="submit" class="btn btn-yellow text-dark">@iT.T(xLan,"1197","Save Change")</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1198","Cancel")</button>
            </div>
        </div>
    </form>
</div>
<script class="append-on-ajax-script">
    $(document).ready(function ()
    {
        $("#frm-SalariesIntegration").submit(function (event)
        {
            event.preventDefault();
            SaveAccount();
        });
    });
    function SaveAccount ()
    {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "")
        {
            alert('Please enter Code!');
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "")
        {
            alert('Please enter name (Display) !');
            return;
        }
        var data = $('#frm-SalariesIntegration').serialize();
        $.ajax({
            type: "POST",
            url: "/api/Settings/iFinancialCategories/UpdateSalariesIntegration",
            data: data,
            dataType: "json",
            success: function (response)
            {
                $("#mod-SalariesIntegration").modal('toggle');
                RefreshGrid();
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
</script>
