                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2245","EndService")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.EndService).ID("cnt-EndService").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
               
                </div>
                <div class="tab-pane fade" id="nav-pills-tab-2">
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2246","Home")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.AllHome).ID("cnt-AllHome").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2247","Transportation")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.AllTransportation).ID("cnt-AllTransportation").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2248","Comunication")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.AllComunication).ID("cnt-AllComunication").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
