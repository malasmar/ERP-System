                    <hr />
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2251","Benefit-1")</label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().LookupFor(m => m.Benefit1).ID("cnt-Benefit1").DataSource(data).ValueExpr("Key").DisplayExpr("Display")
