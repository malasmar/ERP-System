    function ValidateSave ()
    {
        if (VoucherStatus == false)
        {
            if (SlipStatus != 3)
            {
                $.alert({
                    title: 'Stop',
                    icon: 'fa fa-warning',
                    type: 'red',
                    content: 'You can not edit document until status be re-audit!',
                    buttons: {
                        Ok: {
                            text: 'ok'
                        }
                    }
                });
                return false;
            }
        }
        var rowscount = $('#tb-rows tr').length;
        if (rowscount == 0)
        {
            $.alert({
                title: 'Stop',
                icon: 'fa fa-warning',
                type: 'red',
                content: 'There is no data in General Ledger!',
                buttons: {
                    Ok: {
                        text: 'ok'
                    }
                }
            });
            return false;
        }
        var db = 0;
        var cr = 0;
        $('#tb-rows').find('tr').each(function ()
        {
            db += Number(Number($(this).find('[id="td-Debit"]').data('value')).toFixed(2));
            cr += Number(Number($(this).find('[id="td-Credit"]').data('value')).toFixed(2));
        });
        if ((Number(db.toFixed(2)) != Number(cr.toFixed(2))))
        {
            $.alert({
                title: 'Stop',
                icon: 'fa fa-warning',
                type: 'red',
                content: 'There is difference between debit and credit,Difference is : ' + comma(db - cr),
                buttons: {
                    Ok: {
                        text: 'ok'
                    }
                }
            });
            return false;
        }
        if ($('#frm-Description').dxTextArea('option', 'text') == '')
        {
            $.alert({
                title: 'Stop',
                icon: 'fa fa-warning',
                type: 'red',
                content: 'Please add GL description!',
                buttons: {
                    Ok: {
                        text: 'ok'
                    }
                }
            });
            return false;
        }
        return true;
    }
    function SaveGeneralLedger ()
    {
        if (ValidateSave() == false)
        {
            return;
        }

        if (InPosting == true)
        {
            return;
        }

        $.confirm({
            title: 'Confirm',
            content: 'Save/update Journal Voucher confirmation?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Save/Update',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                          if (InPosting == true)
                            return;

                          InPosting=true;
                          $('.PLSave').prop('disabled',true);

                        //Start Update
                        var values = [];
                        $('#tb-rows').find('tr').each(function ()
                        {
                            var d = new Date($(this).find('[id="td-ReferenceDate"]').data('value'));
                            //d.setDate(d.getDate() + 1);
                            if (d.getFullYear() < 2000)
                            {
                                d = null;
                            }
                            values.push({
                                Key: $(this).find('[id="td-Key"]').data('value'),
                                Index: $(this).find('[id="td-Index"]').data('value'),
                                ReferenceNo: $(this).find('[id="td-ReferenceNo"]').data('value'),
                                ReferenceDate: d,
                                TransactionNo: $(this).find('[id="td-TransactionNo"]').data('value'),
                                AccountKind: $(this).find('[id="td-AccountKind"]').data('value'),
                                AccountType: $(this).find('[id="td-AccountType"]').data('value'),
                                AccountKey: $(this).find('[id="td-AccountKey"]').data('value'),
                                CostCenter: $(this).find('[id="td-CostCenter"]').data('value'),
                                Project: $(this).find('[id="td-Project"]').data('value'),
                                Person: $(this).find('[id="td-Person"]').data('value'),
                                Description: $(this).find('[id="td-Description"]').data('value'),
                                vatKey: $(this).find('[id="td-vatKey"]').data('value'),
                                vatRate: $(this).find('[id="td-vatRate"]').data('value'),
                                vatRegNo: $(this).find('[id="td-vatRegNo"]').data('value'),
                                vatCurrent: $(this).find('[id="td-vatCurrent"]').data('value'),
                                Importation: $(this).find('[id="td-Importation"]').data('value'),
                                ExpensesKind: $(this).find('[id="td-ExpensesKind"]').data('value'),
                                PaymentKind: $(this).find('[id="td-PaymentKind"]').data('value'),
                                Debit: $(this).find('[id="td-Debit"]').data('value'),
                                Credit: $(this).find('[id="td-Credit"]').data('value'),
                                isVAT: $(this).find('[id="td-isVAT"]').data('value'),
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/fin/idocuments/UpdateJournalVoucher",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus,
                            dataType: "json",
                            success: function (response)
                            {
                                if (response.Status == true)
                                {
                                    exDocumentError(response);
                                    InPosting=false;
                                    return;
                                }
                                $('#No').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info');
                                $('#inf-Status').addClass('bg-danger');
                                $('#txt-Status').text(iShll.update);
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                PrintDocument();
                                InPosting=false;
                                $('.PLSave').prop('disabled',false);

                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });
                        //End Update
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        $('.PLSave').prop('disabled', false);
                        return;
                    }
                }
            }
        });
    }
