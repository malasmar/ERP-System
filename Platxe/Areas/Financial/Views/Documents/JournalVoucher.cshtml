    function SaveInvoices ()
    {
        TempRowInvoices = [];
        TempRowInvoices.splice(0, TempRowInvoices.length);
        //var x = CloseInvoices.length;
        //while (x--) {
        //    if (CloseInvoices[x].Key == RowKey) {
        //        CloseInvoices.splice(x, 1);
        //    }
        //}
        var amount = 0;
        var clsRows = 0;
        var grdAgesInvoices = $('#grd-AgesCloseInvoices').dxDataGrid("instance");
        grdAgesInvoices.selectRows(grdAgesInvoices.getSelectedRowKeys(), true).done(function ()
        {
            grdAgesInvoices.saveEditData().done(function ()
            {
                var selectedRowsData = grdAgesInvoices.getSelectedRowsData();
                for (const item of selectedRowsData)
                {
                    if (item.xAmount > 0)
                    {
                        TempRowInvoices.push({
                            Key: RowKey,
                            InvoiceKey: item.OperationKey,
                            Amount: item.xAmount
                        });
                        amount += item.xAmount;
                        clsRows += 1;
                    }
                }
            });
        })
        $('#txt-PaymentInvoices').text('This payment incloud ' + clsRows + ' Invoices,Amount is: ' + comma(amount));
        if (clsDocumentKind == 80)
        {
            $('#row-Debit').dxNumberBox('option', 'value', 0);
            $('#row-Credit').dxNumberBox('option', 'value', amount);
        }
        if (clsDocumentKind == 71)
        {
            $('#row-Debit').dxNumberBox('option', 'value', amount);
            $('#row-Credit').dxNumberBox('option', 'value', 0);
        }
        $('#row-Debit').dxNumberBox('option', 'readOnly', true);
        $('#row-Credit').dxNumberBox('option', 'readOnly', true);
        $("#mod-AgesInvoices").modal('toggle');
    }
    function ChangePaymentKind (e)
    {
        switch (e.value)
        {
            case 0:
                $('#btn-SalesInvoice').prop('hidden', true);
                $('#btn-PurchaseInvoice').prop('hidden', true);
                $('#row-Debit').dxNumberBox('option', 'readOnly', false);
                $('#row-Credit').dxNumberBox('option', 'readOnly', false);
                $('#txt-PaymentInvoices').text('The payment out of invoices.');
                TempRowInvoices = [];
                TempRowInvoices.splice(0, TempRowInvoices.length);
                break;
            case 1:
                $('#btn-SalesInvoice').prop('hidden', false);
                $('#btn-PurchaseInvoice').prop('hidden', false);
                $('#row-Debit').dxNumberBox('option', 'readOnly', true);
                $('#row-Credit').dxNumberBox('option', 'readOnly', true);
                $('#txt-PaymentInvoices').text('Please select invoices.');
                if (ChangedAccountKey == false)
                {
                    var clsRows = 0;
                    var clsAmount = 0;
                    TempRowInvoices = [];
                    TempRowInvoices.splice(0, TempRowInvoices.length);
                    for (const item of RowInvoices)
                    {
                        if (item.Key == RowKey)
                        {
                            clsRows += 1;
                            clsAmount += item.Amount;
                            TempRowInvoices.push({
                                Key: RowKey,
                                InvoiceKey: item.InvoiceKey,
                                Amount: item.Amount
                            });
                        }
                    }
                    if (clsAmount > 0)
                    {
                        $('#txt-PaymentInvoices').text('This payment incloud ' + clsRows + ' Invoices,Amount is: ' + comma(clsAmount));
                    } else
                    {
                        $('#txt-PaymentInvoices').text('The payment out of invoices.');
                    }
                } else
                {
                    TempRowInvoices = [];
                    TempRowInvoices.splice(0, TempRowInvoices.length);
                }
                break;
            case 2:
                $('#btn-SalesInvoice').prop('hidden', true);
                $('#btn-PurchaseInvoice').prop('hidden', true);
                $('#row-Debit').dxNumberBox('option', 'readOnly', false);
                $('#row-Credit').dxNumberBox('option', 'readOnly', false);
                $('#txt-PaymentInvoices').text('The payment out of invoices.');
                TempRowInvoices = [];
                TempRowInvoices.splice(0, TempRowInvoices.length);
                break;
        }
    }

