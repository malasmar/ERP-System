            return;
        }
        if ($('#row-Debit').dxNumberBox('option', 'value') == 0 && $('#row-Credit').dxNumberBox('option', 'value') == 0)
        {
            $.alert({
                title: 'Stop',
                content: "Please add debit or credit amount!",
