    function SelectRowAgesInvoice (e)
    {
        var grd = $('#grd-AgesCloseInvoices').dxDataGrid("instance");
        grd.selectRows(e.key, true);
    }
    function SaveInvoices ()
    {
        TempRowInvoices = [];
        TempRowInvoices.splice(0, TempRowInvoices.length);
        //var x = CloseInvoices.length;
        //while (x--) {
        //    if (CloseInvoices[x].Key == RowKey) {
        //        CloseInvoices.splice(x, 1);
        //    }
        //}
        var amount = 0;
        var clsRows = 0;
        var grdAgesInvoices = $('#grd-AgesCloseInvoices').dxDataGrid("instance");
        grdAgesInvoices.selectRows(grdAgesInvoices.getSelectedRowKeys(), true).done(function ()
        {
            grdAgesInvoices.saveEditData().done(function ()
            {
                var selectedRowsData = grdAgesInvoices.getSelectedRowsData();
                for (const item of selectedRowsData)
                {
                    if (item.xAmount > 0)
                    {
                        TempRowInvoices.push({
                            Key: RowKey,
                            InvoiceKey: item.OperationKey,
                            Amount: item.xAmount
                        });
                        amount += item.xAmount;
                        clsRows += 1;
                    }
                }
            });
        })
        $('#txt-PaymentInvoices').text('This payment incloud ' + clsRows + ' Invoices,Amount is: ' + comma(amount));
        $('#row-Amount').dxNumberBox('option', 'value', amount);
        $('#row-Amount').dxNumberBox('option', 'readOnly', true);
        $("#mod-AgesInvoices").modal('toggle');
    }
    function ChangePaymentKind (e)
    {
        switch (e.value)
        {
            case 0:
                $('#btn-SelectInvoices').prop('hidden', true);
                $('#row-Amount').dxNumberBox('option', 'readOnly', false);
                $('#txt-PaymentInvoices').text('The payment out of invoices.');
                TempRowInvoices = [];
                TempRowInvoices.splice(0, TempRowInvoices.length);
                break;
            case 1:
                $('#btn-SelectInvoices').prop('hidden', false);
                $('#row-Amount').dxNumberBox('option', 'readOnly', true);
                $('#txt-PaymentInvoices').text('Please select invoices.');
                if (ChangedAccountKey == false)
                {
                    var clsRows = 0;
                    var clsAmount = 0;
                    TempRowInvoices = [];
                    TempRowInvoices.splice(0, TempRowInvoices.length);
                    for (const item of RowInvoices)
                    {
                        if (item.Key == RowKey)
                        {
                            clsRows += 1;
                            clsAmount += item.Amount;
                            TempRowInvoices.push({
                                Key: RowKey,
                                InvoiceKey: item.InvoiceKey,
                                Amount: item.Amount
                            });
                        }
                    }
                    if (clsAmount > 0)
                    {
                        $('#txt-PaymentInvoices').text('This payment incloud ' + clsRows + ' Invoices,Amount is: ' + comma(clsAmount));
                    } else
                    {
                        $('#txt-PaymentInvoices').text('The payment out of invoices.');
                    }
                } else
                {
                    TempRowInvoices = [];
                    TempRowInvoices.splice(0, TempRowInvoices.length);
                }
                break;
            case 2:
                $('#btn-SelectInvoices').prop('hidden', true);
                $('#row-Amount').dxNumberBox('option', 'readOnly', false);
                $('#txt-PaymentInvoices').text('The payment out of invoices.');
                TempRowInvoices = [];
                TempRowInvoices.splice(0, TempRowInvoices.length);
                break;
        }
    }
    function GetMonthlyNo ()
    {
        var d = new Date();
        d = $('#frm-VoucherDate').dxDateBox('option', 'value');
        $.ajax({
            type: "get",
            url: "/api/icore/MaxMonthlyVoucher",
            data: { DocumentKind: DocumentKind, Year: d.getFullYear(), Month: d.getMonth() + 1 },
            dataType: "json",
            success: function (response)
            {
                $('#txt-MonthlyNo').text(response);
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
    function PrintDocument ()
    {
        if (opk == null)
