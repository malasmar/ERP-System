    function ShowAgesInvoices ()
    {
        if ($('#row-AccountKind').dxSelectBox('option', 'value') != 0)
            return;
        $('#con-AgesInvoices').empty();
        $("#con-AgesInvoices").load('/Financial/Selections/AgesInvoices?Key=' + $("#row-Account").dxLookup('option', 'value') + '&DocumentKind=80');
        $("#mod-AgesInvoices").modal({ backdrop: 'static' }).modal('toggle');
