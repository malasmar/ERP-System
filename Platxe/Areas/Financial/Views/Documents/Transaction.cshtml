        }
        if (VoucherStatus == false)
        {
            if (SlipStatus != 3)
            {
                $.alert({
                    title: 'Stop',
                    icon: 'fa fa-warning',
                    type: 'red',
                    content: 'You can not edit document until status be re-audit!',
                    buttons: {
