    function cta4AgesCloseInvoices (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [ {
                icon: "selectall"
            } ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                var grdAgesInvoices = $('#grd-AgesCloseInvoices').dxDataGrid("instance");
                grdAgesInvoices.cellValue(options.rowIndex, 'xAmount', options.data.TotalRem);
                grdAgesInvoices.saveEditData();
