@model CLiFinancial.Documents.Transaction
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));

    string Currency = CLiCore.VoucherOperation.DefaultCurrency(DB);
    string vatHidden = "";
    string PersonHidden = "";
    string ImportationHidden = "";
    string LanAccountName = "Account Name";
    string HiddenSalaries = "";
    switch (Model.DocumentKind)
    {
        case (int)DocumentKind.finCashCollection:
        case (int)DocumentKind.finCashPayment:
            LanAccountName = iT.T(xLan, "2142", "Cash Account");
            break;
        case (int)DocumentKind.finBankCollection:
        case (int)DocumentKind.finBankPayment:
            LanAccountName = "Bank Account";
            LanAccountName = iT.T(xLan, "2143", "Bank Account");
            break;
        case (int)DocumentKind.finDebitNote:
        case (int)DocumentKind.finCreditNote:
            LanAccountName = "Current Account";
            LanAccountName = iT.T(xLan, "2144", "Current Account");
            break;
    }
    if (Model.DocumentKind == (int)DocumentKind.finBankCollection || Model.DocumentKind == (int)DocumentKind.finCashCollection)
    {
        vatHidden = "hidden";
        ImportationHidden = "hidden";
        HiddenSalaries = "hidden";
    }
    if (Model.DocumentKind == (int)DocumentKind.finBankPayment || Model.DocumentKind == (int)DocumentKind.finCashPayment)
    {
        PersonHidden = "hidden";
    }
    if (Model.DocumentKind == (int)DocumentKind.finDebitNote || Model.DocumentKind == (int)DocumentKind.finCreditNote)
    {
        PersonHidden = "hidden";
        ImportationHidden = "hidden";
    }
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }

    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }
    /*  .xd > tr:hover .ccp {
                                    display: block !important;
                                }*/
    .xd > tr:hover {
        cursor: pointer;
    }

    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }

    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }
</style>
<div class="invoice">
    <div class="invoice-company">
        <div class="float-end hidden-print">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i>@iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
        <div class="float-end hidden-print me-1">
            <div class="btn-group">
                <button type="button" class="btn btn-gray mb-10px" onclick="ViewGeneralLedger('@Model.OperationKey')">GL</button>
                <button @HiddenSalaries type="button" class="btn btn-danger mb-10px" onclick="ShowSalariesPayment()">Salaries Payment</button>
            </div>
        </div>
        <div class="shl-invoice-header">
            @CLiCore.iCore.DocumentsName(xLan,Model.DocumentKind) <span id="inf-Status" class="badge bg-info text-dark"><small class="f-s-9 me-1">@iT.T(xLan,"2141","Status")</small><span id="txt-Status" class="me-1">Update</span></span><span id="txt-VoucherNo" class="text-danger"># @Model.VoucherNo </span><small class="f-s-11 me-1">@iT.T(xLan,"2140","Monthly No")<span id="txt-MonthlyNo"> @Model.MonthlyNo</span></small>

            @{
                if (Model.Status != 3 && Model.OperationKey != null)
                {
                    <p class="f-s-10 mt-2"><i class="fa fa-exclamation-circle text-danger"></i> The document status not allowed to edit or save transaction.</p>
                }
            }
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
        </div>
    </div>
    <form id="frm-Voucher">
        @Html.HiddenFor(m=>m.DocumentKind)
        @Html.HiddenFor(m=>m.OperationKey)
        @Html.HiddenFor(m=>m.VoucherNo)
        @Html.HiddenFor(m=>m.MonthlyNo)
        @Html.HiddenFor(m=>m.CreateUser)
        @Html.HiddenFor(m=>m.CreateDate)
        @Html.HiddenFor(m=>m.AccountKind)
        <div class="invoice-header">
            <div class="invoice-from">
                <div class="row">
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1210","Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().DateBoxFor(m => m.VoucherDate).ID("frm-VoucherDate").Width(110).DisplayFormat("dd.MM.yyyy").Min(new DateTime(xYear,1,1)).Max(DateTime.UtcNow.AddMinutes(180)).OnValueChanged("GetMonthlyNo")
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1162","Category")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Category).ID("frm-Category").DataSource(CLiFinancial.Selections.Groups.TransactionCategories(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@LanAccountName</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.AccountKey).ID("frm-AccountKey").DataSource(CLiFinancial.Selections.Dynamic.DocumentKind(DB,xLan, Model.DocumentKind)).ValueExpr("Key").DisplayExpr("Display").OnValueChanged("ChangeFrmAccount")
                                <div class="me-2 mt-1">
                                    <small class="bg-purple-transparent-2 me-2">@iT.T(xLan, "1227","Balance") <b id="frm-AccountBalance" class="me-2">0.00</b></small>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1212","Description")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextAreaFor(m => m.Description).ID("frm-Description").Height(65)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2145","Recipient Name")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.RecipientName).ID("frm-RecipientName")
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1344","Currency")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Currency).ID("frm-Currency").DataSource(CLiFinancial.Selections.Currency.GetList(DB)).ValueExpr("Code").DisplayExpr("Code").Width(100).Value(Currency)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1328","Prefix")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Prefix).ID("frm-Prefix").DataSource(CLiFinancial.Selections.Prefix.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").Width(185)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display").Width(185)
                            </div>
                        </div>
                        <div class="form-group row" hidden>
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1329","Transaction No")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.TransactionNo).ID("frm-TransactionNo").Width(185)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1330","Reference No")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().TextBoxFor(m => m.ReferenceNo).ID("frm-ReferenceNo").Width(75)
                                    @Html.DevExtreme().DateBoxFor(m => m.ReferenceDate).ID("frm-ReferenceDate").Width(110).DisplayFormat("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>

                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1220","Project")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.Project).ID("frm-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1332","Cst.Center")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.CostCenter).ID("frm-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark" style="height:225px">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-3 ">
                                    <b class="mb-3">@iT.T(xLan,"2154","Voucher Details")</b>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1347","Subtotal")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Subtotal.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2146","VAT")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.vatAmount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1120","Total")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Total.ToString("n2")</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark" style="height:225px">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-3 ">
                                    <b class="mb-3">@iT.T(xLan,"2154","Voucher Details")</b>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2155","Create User")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10"><span>@Model.CreateUserInfo.Display</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2156","Create Date")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10" style="direction:ltr">@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy hh:mm tt") : "")</div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2157","Update User")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10"><span>@Model.CreateUserInfo.Display</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2158","Update Date")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10" style="direction:ltr">@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy hh:mm tt") : "")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <div class="invoice-content mt-3">
        <div class="sticky">
            <button type="button" id="btn-add" class="btn btn-yellow btn-sm text-dark" onclick="AddNewRow()">@iT.T(xLan,"1214","Add New Row")</button>
            <button type="button" id="btn-CopyInvoice" class="btn btn-white btn-sm" onclick="ShowCopy()" title="@iT.T(xLan,"","Copy from previous JV")"><i class="fa fa-clone"></i></button>
        </div>
        <div class="table-responsive">
            <table class="table table-invoice table-hover">
                <thead>
                    <tr>
                        <th style="width:100px;max-width:100px">@iT.T(xLan,"1215","Actions")</th>
                        <th style="width:110px;min-width:110px;max-width:110px">@iT.T(xLan,"1158","Kind")</th>
                        <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1164","Code")</th>
                        <th style="width:30%;min-width:150px">@iT.T(xLan,"1165","Account Name")</th>
                        <th style="width:70%">@iT.T(xLan,"1212","Description")</th>
                        <th @vatHidden style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>
                        <th @vatHidden style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1345","VAT")</th>
                        <th style="width:120px;min-width:120px;max-width:120px">@iT.T(xLan,"1347","Subtotal")</th>
                    </tr>
                </thead>
                <tbody class="xd" id="tb-rows">
                </tbody>
            </table>
        </div>
        <div class="invoice-price">
            <div class="invoice-price-left">
                <div class="invoice-price-row">
                    <div @vatHidden class="sub-price">
                        <small>@iT.T(xLan,"1347","Subtotal")</small>
                        <span id="txt-Amount" class="text-dark">0.00</span>
                    </div>
                    <div @vatHidden class="sub-price">
                        <small>@iT.T(xLan,"1348","VAT Total")</small>
                        <span id="txt-vatAmount" class="text-dark">0.00</span>
                    </div>
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1120","Total")</small>
                        <span id="txt-Total" class="text-red me-2">0.00</span>
                    </div>
                </div>
            </div>
            <div class="invoice-price-right">
                <small>@iT.T(xLan,"1120","TOTAL")</small> <span class="fw-bold" id="txt-xTotal">0.00</span>
            </div>
        </div>
    </div>
    <div class="invoice-note">
        <hr>
        <div class="text-left">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i>@iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
    </div>
</div>
<div id="mod-Row" class="modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@iT.T(xLan,"1218","Row Details")</h4>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1333","Account Kind")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-AccountKind").DataSource(iReplacer.finTransactionAccByDocument(xLan,Model.DocumentKind)).ValueExpr("Value").DisplayExpr("Display").Width(150).Value(0).OnValueChanged("ChangeAccountKind")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1334","Current Kind")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-AccountType").ValueExpr("Value").DisplayExpr("Display").Width(150).OnValueChanged("ChangeAccountType")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1219","Account")</label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="input-group">
                            @Html.DevExtreme().Lookup().ID("row-Account").ValueExpr("Key").DisplayExpr("Display").Width("90%").OnValueChanged("ChangeAccountKey")
                            <button id="btn-rowAddEdit" type="button" class="btn btn-white f-s-10" onclick="AddRowAccount()" style="max-width:35px"><i class="fas fa-plus"></i></button>

                        </div>
                        <div class="me-2 mb-1">
                            <small class="f-s-10 f-w-500 text-dark me-2" id="inf-Balance">@iT.T(xLan,"","Account Balance:") <b class="me-2" id="txt-AccountBalance"></b></small>
                        </div>
                    </div>
                </div>
                <div id="div-PaymentKind">
                    <div class="form-group row">
                        <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1335","Payment Kind")</label>
                        <div class="col-lg-9 col-sm-12">
                            <div class="input-group">
                                @Html.DevExtreme().SelectBox().ID("row-PaymentKind").DataSource(iReplacer.finPaymentKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width(150).Value(0).OnValueChanged("ChangePaymentKind")
                                <button hidden id="btn-SelectInvoices" type="button" class="btn btn-white f-s-10" onclick="ShowAgesInvoices()">@iT.T(xLan, "1349","Select Invoices")</button>
                            </div>
                            <div class="me-2 mb-1">
                                <small class="f-s-10 f-w-500 text-dark" id="txt-PaymentInvoices">@iT.T(xLan,"1336","Calculated in Ages Operation")</small>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1212","Description")</label>
                    <div class="col-9">
                        @Html.DevExtreme().TextArea().ID("row-Description").Height(65)
                    </div>
                </div>
                <div hidden id="div-ExpensesDistribution">
                    <div class="form-group row">
                        <label class=" col-3 ">@iT.T(xLan, "1337","Expenses Kind")</label>
                        <div class="col-9">
                            @Html.DevExtreme().SelectBox().ID("row-ExpensesKind").ElementAttr("class", "plxenter").Width(130).DataSource(iReplacer.finAccounts(xLan)).ValueExpr("Value").DisplayExpr("Display").Value(0)
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class=" col-3 ">@iT.T(xLan, "1338","Start Year") </label>
                        <div class="col-9">
                            @Html.DevExtreme().NumberBox().ID("row-ExpDisYear").ElementAttr("class", "plxenter").ShowSpinButtons(true).Width(130).Min(0).Value(2020)
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-3 col-md-12 ">@iT.T(xLan, "1339","Start Month")</label>
                        <div class="col-lg-9 col-md-12 ">
                            @Html.DevExtreme().SelectBox().ID("row-ExpDisMonth").ElementAttr("class", "plxenter").Width(130).DataSource(iReplacer.finAccounts(xLan)).ValueExpr("Value").DisplayExpr("Display")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class=" col-3 ">@iT.T(xLan, "1340","Months")</label>
                        <div class="col-9">
                            @Html.DevExtreme().NumberBox().ID("row-ExpDisMonths").ElementAttr("class", "plxenter").ShowSpinButtons(true).Width(130).Min(0)
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1077","Amount")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Amount").ShowSpinButtons(true).Width(130).Min(0).Format("0,###.##").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div @vatHidden>
                    <div hidden id="div-vat">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1977","vatKey")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBox().ID("row-vatKey").Width(130).DataSource(CLiFinancial.Selections.vatRate.vatRates(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").OnValueChanged("EditAmount")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-3">@iT.T(xLan,"1350","vat Amount")</label>
                            <div class="col-9">
                                @Html.DevExtreme().NumberBox().ID("row-vatAmount").ShowSpinButtons(true).Width(130).Min(0).Format("0,###.##").ReadOnly(true)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-3">@iT.T(xLan,"1120","Total")</label>
                            <div class="col-9">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBox().ID("row-Total").Width(130).ShowSpinButtons(true).Format("0,###.##")
                                    <button type="button" class="btn btn-white f-s-10" onclick="RefelectAmount()">@iT.T(xLan, "1326","Reflect Amount")</button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1341","vat Reg No")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().TextBox().ID("row-vatRegNo").Width("89%")
                                    <button type="button" class="btn btn-white f-s-10" onclick="SearchVAT()"><i class="fas fa-search"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"","vat Sup/Client")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().TextBox().ID("row-vatCurrent").Width("89%")
                                    <button type="button" class="btn btn-white f-s-10" onclick="SearchVAT()"><i class="fas fa-search"></i></button>
                                </div>
                            </div>
                        </div>
                    </div>

                </div>
                <div @ImportationHidden>
                    <div class="form-group row" id="div-Importation">
                        <label class=" col-3 ">@iT.T(xLan, "1342","Importation File")</label>
                        <div class="col-9">
                            @Html.DevExtreme().Lookup().ID("row-Importation").ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                        </div>
                    </div>
                </div>
                <div @PersonHidden>
                    <div class="form-group row" id="div-Person">
                        <label class=" col-3 ">@iT.T(xLan, "1343","Collection Person")</label>
                        <div class="col-9">
                            @Html.DevExtreme().Lookup().ID("row-Person").ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1330","Reference No")</label>
                    <div class="col-9">
                        @Html.DevExtreme().TextBox().ID("row-ReferenceNo")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1210","Date")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().DateBox().ID("row-ReferenceDate").Width(130).DisplayFormat("dd.MM.yyyy").Value(DateTime.Now)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1199","Cost Center")</label>
                    <div class="col-9">
                        @Html.DevExtreme().Lookup().ID("row-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1220","Project")</label>
                    <div class="col-9">
                        @Html.DevExtreme().Lookup().ID("row-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <div class="btn-group">
                    <button type="submit" class="btn btn-yellow text-dark" onclick="SaveRowChange()">@iT.T(xLan,"1197","Save Change")</button>
                    <button type="button" class="btn btn-dark" onclick="CancelRow()">@iT.T(xLan,"1198","Cancel")</button>
                </div>
            </div>
        </div>
    </div>
</div>
