    function SaveGeneralLedger ()
    {
        if (ValidateSave() == false)
        {
            return;
        }

      if(InPosting==true) {
            return;
        }

        $.confirm({
            title: 'Confirm',
            content: 'Save/update Transaction confirmation?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Save/Update',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                              if (InPosting == true)
                            return;

                          InPosting=true;
                          $('.PLSave').prop('disabled',true);


                        //Start Update
                        var values = [];
                        $('#tb-rows').find('tr').each(function ()
                        {
                            var d = new Date($(this).find('[id="td-ReferenceDate"]').data('value'));
                            //d.setDate(d.getDate() + 1);
                            if (d.getFullYear() < 2000)
                            {
                                d = null;
                            }
                            values.push({
                                Key: $(this).find('[id="td-Key"]').data('value'),
                                Index: $(this).find('[id="td-Index"]').data('value'),
                                ReferenceNo: $(this).find('[id="td-ReferenceNo"]').data('value'),
                                ReferenceDate: d,
                                TransactionNo: $(this).find('[id="td-TransactionNo"]').data('value'),
                                AccountKind: $(this).find('[id="td-AccountKind"]').data('value'),
                                AccountType: $(this).find('[id="td-AccountType"]').data('value'),
                                AccountKey: $(this).find('[id="td-AccountKey"]').data('value'),
                                CostCenter: $(this).find('[id="td-CostCenter"]').data('value'),
                                Project: $(this).find('[id="td-Project"]').data('value'),
                                Person: $(this).find('[id="td-Person"]').data('value'),
                                Description: $(this).find('[id="td-Description"]').data('value'),
                                Amount: $(this).find('[id="td-Amount"]').data('value'),
                                vatKey: $(this).find('[id="td-vatKey"]').data('value'),
                                vatRate: $(this).find('[id="td-vatRate"]').data('value'),
                                vatAmount: $(this).find('[id="td-vatAmount"]').data('value'),
                                Total: $(this).find('[id="td-Total"]').data('value'),
                                vatRegNo: $(this).find('[id="td-vatRegNo"]').data('value'),
                                vatCurrent: $(this).find('[id="td-vatCurrent"]').data('value'),
                                Importation: $(this).find('[id="td-Importation"]').data('value'),
                                ExpensesKind: $(this).find('[id="td-ExpensesKind"]').data('value'),
                                PaymentKind: $(this).find('[id="td-PaymentKind"]').data('value'),
                                SalaryKey  : $(this).find('[id="td-SalaryKey"]').data('value') 
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/fin/idocuments/UpdateTransaction",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus + '&Invoices=' + JSON.stringify(CloseInvoices),
                            dataType: "json",
                            success: function (response)
                            {
                                if (response.Status == true)
                                {
                                    exDocumentError(response);
                                    InPosting=false;
                                    return;
                                }
                                $('#No').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info');
                                $('#inf-Status').addClass('bg-danger');
                                $('#txt-Status').text(iShll.update);
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                InPosting=false;
                                PrintDocument();
                                 $('.PLSave').prop('disabled',false);
                                //ShowPrintTemplate();
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });
                        //End Update
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                         $('.PLSave').prop('disabled',false);
                        return;
                    }
                }
            }
        });
    }
    //Calc
    var IsLoading = 0;
    function EditAmount ()
    {
        if (IsLoading == 1)
            return;
        var vatRate = 0;
        if ($("#row-vatKey").dxSelectBox('option', 'value') == null)
        {
            vatRate = 0;
        } else
        {
            var selctedvat = $("#row-vatKey").dxSelectBox('instance').option('selectedItem');
            vatRate = selctedvat.Rate;
        }
        var amount = $("#row-Amount").dxNumberBox("option", "value");
        var vatamount = 0;
        var totalamount = 0;
        if (vatRate == 0)
        {
            vatamount = 0;
            totalamount = amount;
        }
        if (vatRate > 0)
        {
            vatamount = Number(((amount * vatRate) / 100).toFixed(2));
            totalamount = Number((amount + vatamount).toFixed(2));
            //$('#row-').dxTextBox('option', 'disabled', false);
            //$('#edvatRegNo').dxTextBox('option', 'disabled', false);
        }
        $("#row-vatAmount").dxNumberBox("option", "value", vatamount);
        $("#row-Total").dxNumberBox("option", "value", totalamount);
    }
    function RefelectAmount ()
    {
        var vatRate = 0;
        if ($("#row-vatKey").dxSelectBox('option', 'value') == null)
        {
            vatRate = 0;
        } else
        {
            var selctedvat = $("#row-vatKey").dxSelectBox('instance').option('selectedItem');
            vatRate = selctedvat.Rate;
        }
        var totalamount = $("#row-Total").dxNumberBox("option", "value");
        var vatamount = 0;
        var amount = 0;
        if (vatRate == 0)
        {
            vatamount = 0;
            amount = totalamount
        }
        if (vatRate > 0)
        {
            amount = Number(((totalamount * 100) / (100 + vatRate)).toFixed(2));
            vatamount = Number(((amount * vatRate) / 100).toFixed(2));
        }
        $("#row-vatAmount").dxNumberBox("option", "value", vatamount);
        $("#row-Amount").dxNumberBox("option", "value", amount)
    }
