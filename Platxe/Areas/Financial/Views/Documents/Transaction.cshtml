        str += '      <td ' + vatHidden + ' >' + comma($('#row-Amount').dxNumberBox('option', 'value')) + '</td>'
        str += '      <td ' + vatHidden + ' >' + comma($('#row-vatAmount').dxNumberBox('option', 'value')) + '<small class="me-1 f-s-9 text-mute">' + selectedvat.Rate + '%</small></td>'
        str += '      <td>' + comma($('#row-Total').dxNumberBox('option', 'value')) + '</td>'
        str += '<td hidden id="td-Key" data-value="' + RowKey + '"></td>'
