        str += '<td hidden id="td-ReferenceNo" data-value="' + $('#row-ReferenceNo').dxTextBox('option', 'value') + '"></td>'
        str += '<td hidden id="td-ReferenceDate" data-value="' + $('#row-ReferenceDate').dxDateBox('option', 'value') + '"></td>'
