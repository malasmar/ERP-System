            if (clsAmount > 0)
            {
                $('#txt-PaymentInvoices').text('This payment incloud ' + clsRows + ' Invoices,Amount is: ' + comma(clsAmount));
            } else
            {
                $('#txt-PaymentInvoices').text('The payment out of invoices.');
            }
            ChangedAccountKey = false;
            isLoadingDetails = 0;
            $("#mod-Row").modal({ backdrop: 'static' }).modal('toggle');
        });
        $('#tb-rows').on('click', '#btn-delete', function ()
        {
            DeleteRow($(this).data('key'), $(this).data('rowkey'));
        });
    });
    //Start Operation
    var inChangeAccountKind = 0;
    function ChangeAccountKind (e)
    {
        inChangeAccountKind = 1;

        $("#row-AccountType").dxSelectBox({
            dataSource: '/api/icore/LoadAccountTypes?Kind=' + e.value
        });
        $('#row-AccountType').dxSelectBox('reset');
        $("#row-AccountType").dxSelectBox("getDataSource").load().done(function ()
        {
            $('#row-AccountType').dxSelectBox('option', 'value', 0);
        });
        $("#row-Account").dxLookup({
            dataSource: new DevExpress.data.DataSource({
                loadMode: "raw",
                load: function ()
                {
                    return $.getJSON('/api/icore/LoadAccounts?Kind=' + e.value + '&CurrentKind=' + $('#row-AccountType').dxSelectBox('option', 'value'));
                },
                paginate: true,
                pageSize: 50
            })
        });
        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup("getDataSource").load().done(function ()
        {
            if (rowCurrentAccountKey != null)
            {
                $('#row-Account').dxLookup('option', 'value', rowCurrentAccountKey);
            }
        });

        switch (e.value)
        {
            case 0:
                $('#row-AccountType').dxSelectBox('option', 'readOnly', false);
                $('#div-PaymentKind').prop('hidden', false);
                $('#div-Importation').prop('hidden', true);
                $('#div-Person').prop('hidden', false);
                $('#div-vat').prop('hidden', true);
                $('#btn-rowAddEdit').prop('disabled', false);
                break;
            case 1:
                $('#div-PaymentKind').prop('hidden', true);
                $('#row-AccountType').dxSelectBox('option', 'readOnly', false);
                $('#div-Importation').prop('hidden', true);
                $('#div-Person').prop('hidden', true);
                $('#div-vat').prop('hidden', true);
                $('#btn-rowAddEdit').prop('disabled', true);
                break;
            case 6:
                $('#div-PaymentKind').prop('hidden', true);
                $('#row-AccountType').dxSelectBox('option', 'readOnly', false);
                $('#div-Importation').prop('hidden', true);
                $('#div-Person').prop('hidden', true);
                $('#div-vat').prop('hidden', true);
                $('#btn-rowAddEdit').prop('disabled', false);
                break;
            case 5:
                $('#div-Importation').prop('hidden', false);
                $('#div-PaymentKind').prop('hidden', true);
                $('#row-AccountType').dxSelectBox('option', 'readOnly', true);
                $('#div-Person').prop('hidden', true);
                $('#div-vat').prop('hidden', false);
                $('#btn-rowAddEdit').prop('disabled', false);
                break;
            case 7:
                $('#div-PaymentKind').prop('hidden', true);
                $('#row-AccountType').dxSelectBox('option', 'readOnly', true);
                $('#div-Importation').prop('hidden', true);
                $('#div-Person').prop('hidden', true);
                $('#div-vat').prop('hidden', false);
                $('#btn-rowAddEdit').prop('disabled', true);
                break;
            default:
                $('#div-PaymentKind').prop('hidden', true);
                $('#row-AccountType').dxSelectBox('option', 'readOnly', true);
                $('#div-Person').prop('hidden', true);
                $('#div-Importation').prop('hidden', true);
                $('#div-vat').prop('hidden', true);
                $('#btn-rowAddEdit').prop('disabled', true);
                break;
        }
        inChangeAccountKind = 0;
    }
    function ChangeAccountType (e)
    {
        if (inChangeAccountKind == 1)
            return;


        if ($('#row-AccountKind').dxSelectBox('option', 'value') == 0)
        {
            $("#row-Account").dxLookup({
                dataSource: new DevExpress.data.DataSource({
                    loadMode: "raw",
                    load: function ()
                    {
                        return $.getJSON('/api/icore/LoadAccounts?Kind=' + $('#row-AccountKind').dxSelectBox('option', 'value') + '&CurrentKind=' + e.value);
                    },
                    paginate: true,
                    pageSize: 50
                })
            });
            $('#row-Account').dxLookup('reset');
            $("#row-Account").dxLookup("getDataSource").load().done(function ()
            {
                //$('#row-Account').dxLookup('option', 'value', 0);
            });
        }
    }
    //End Start Operation
    function ChangeAccountKey (e)
    {
        if (isLoadingDetails == 1)
            return;

        var d = new Date();
        d = $('#frm-VoucherDate').dxDateBox('option', 'value');
        AccountBalance('txt-AccountBalance', e.value, d.toLocaleDateString(), $('#row-AccountKind').dxSelectBox('option', 'value'), $('#row-AccountType').dxSelectBox('option', 'value'));

        ChangedAccountKey = true;
        $('#row-PaymentKind').dxSelectBox('option', 'value', 0);

        if (e.value == null)
        {
            $('#btn-rowAddEdit i').removeClass('fa-pen');
            $('#btn-rowAddEdit i').addClass('fa-plus');

        } else
        {
            $('#btn-rowAddEdit i').removeClass('fa-plus');
            $('#btn-rowAddEdit i').addClass('fa-pen');
        }
    }
    function ChangeFrmAccount (e)
    {
        var d = new Date();
        d = $('#frm-VoucherDate').dxDateBox('option', 'value');
        AccountBalance('frm-AccountBalance', e.value, d.toLocaleDateString(), 0, 0);
    }
    function AddRowAccount ()
    {
        $('#con-Card').empty();
        $("#con-Card").load('/Cards/Account?Key=' + $('#row-Account').dxLookup('option', 'value') + '&Kind=' + $('#row-AccountKind').dxSelectBox('option', 'value'));
        $("#mod-Card").modal({ backdrop: 'static' }).modal('toggle');
    }
    function EndSaveAccount (xAccountKey)
    {

        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup("getDataSource").reload().done(function ()
        {
            $('#row-Account').dxLookup('option', 'value', xAccountKey);
        });


    }
    function AddNewRow ()
    {
        TempRowInvoices = [];
        isNewRow = true;
        RowKey = GeneratGuid();
        $('#row-AccountKind').dxSelectBox('option', 'value', 0);
        $('#row-AccountType').dxSelectBox('option', 'value', 0);
        $('#row-Account').dxLookup('reset');
        $('#row-Description').dxTextArea('option', 'value', $('#frm-Description').dxTextArea('option', 'value'));
        $('#row-Amount').dxNumberBox('option', 'value', 0);
        $('#row-Total').dxNumberBox('option', 'value', 0);
        $('#row-vatAmount').dxNumberBox('option', 'value', 0);
        $('#row-PaymentKind').dxSelectBox('option', 'value', 0);
        var selectedvat = $("#row-vatKey").dxSelectBox('instance');
        selectedvat.getDataSource().load().done(function (res)
        {
            $('#row-vatKey').dxSelectBox('option', 'value', res[ 0 ].Key);
        });
        $('#row-CostCenter').dxLookup('reset');
        $('#row-Project').dxLookup('reset');
        //$('#row-CostCenter').dxLookup('option', 'value', $('#frm-CostCenter').dxLookup('option', 'value'));
        $('#row-Project').dxLookup('option', 'value', $('#frm-Project').dxLookup('option', 'value'));
        $('#row-Importation').dxLookup('reset');
        $('#row-Person').dxLookup('reset');
        $('#row-AccountType').dxSelectBox('option', 'readOnly', false);
        $('#div-PaymentKind').prop('hidden', false);
        $('#txt-PaymentInvoices').text('The payment out of invoices.');
        $('#btn-SelectInvoices').prop('hidden', true);
        $('#div-Importation').prop('hidden', true);
        $('#div-Person').prop('hidden', false);
        $('#div-vat').prop('hidden', true);
          SalaryKey  =null;
        $("#mod-Row").modal({ backdrop: 'static' }).modal('toggle');
    }
    function CancelRow ()
    {
        $("#mod-Row").modal('toggle');
    }
    function SaveRowChange ()
    {
        if ($('#row-Account').dxLookup('option', 'value') == null)
        {
            $.alert({
                title: 'Stop',
                content: "Please select account.",
            });
            $('#row-Account').dxLookup('focus');
            return;
        }
        if ($('#row-Amount').dxNumberBox('option', 'value') == 0)
        {
            $.alert({
                title: 'Stop',
                content: "Please add amount.",
            });
            $('#row-Amount').dxNumberBox('focus');
            return;
        }
        if ($('#row-Description').dxTextArea('option', 'value') == '')
        {
            $.alert({
                title: 'Stop',
                content: "Please add description.",
            });
            $('#row-Description').dxTextArea('focus');
            return;
        }
        if ($('#row-AccountKind').dxSelectBox('option', 'value') == 5 || $('#row-AccountKind').dxSelectBox('option', 'value') == 6)
        {

            if ($('#row-CostCenter').dxLookup('option', 'value') == null)
            {
                $.alert({
                    title: 'Stop',
                    content: "Please select cost center.",
                });
                return;
            }
        }
        if (isNewRow == true)
        {
            var x = TempRowInvoices.length;
            while (x--)
            {
                CloseInvoices.push({
                    Key: RowKey,
                    InvoiceKey: TempRowInvoices[ x ].InvoiceKey,
                    Amount: TempRowInvoices[ x ].Amount
                });
            }
            InsertNewRow();
        } else
        {
            var x = CloseInvoices.length;
            while (x--)
            {
                if (CloseInvoices[ x ].Key == RowKey)
                {
                    CloseInvoices.splice(x, 1);
                }
            }
            var x = TempRowInvoices.length;
            while (x--)
            {
                CloseInvoices.push({
                    Key: RowKey,
                    InvoiceKey: TempRowInvoices[ x ].InvoiceKey,
                    Amount: TempRowInvoices[ x ].Amount
                });
            }
            SaveRowEdit();
        }
    }
