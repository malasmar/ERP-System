            $('#row-vatKey').dxSelectBox('option', 'value', $(this).find('[id="td-vatKey"]').data('value'));
            $('#row-vatAmount').dxNumberBox('option', 'value', $(this).find('[id="td-vatAmount"]').data('value'));
            $('#row-Total').dxNumberBox('option', 'value', $(this).find('[id="td-Total"]').data('value'));
            $('#row-vatRegNo').dxTextBox('option', 'value', $(this).find('[id="td-vatRegNo"]').data('value'));
            $('#row-vatCurrent').dxTextBox('option', 'value', $(this).find('[id="td-vatCurrent"]').data('value'));
            $('#row-Importation').dxLookup('option', 'value', $(this).find('[id="td-Importation"]').data('value'));
            $('#row-Person').dxLookup('option', 'value', $(this).find('[id="td-Person"]').data('value'));
            $('#row-ReferenceNo').dxTextBox('option', 'value', $(this).find('[id="td-ReferenceNo"]').data('value'));
            $('#row-ReferenceDate').dxDateBox('option', 'value', $(this).find('[id="td-ReferenceDate"]').data('value'));
            $('#row-CostCenter').dxLookup('option', 'value', $(this).find('[id="td-CostCenter"]').data('value'));
            $('#row-Project').dxLookup('option', 'value', $(this).find('[id="td-Project"]').data('value'));
              SalaryKey  =$(this).find('[id="td-SalaryKey"]').data('value');

            currentRow = $(this).data('key');
            isNewRow = false;
            var clsRows = 0;
            var clsAmount = 0;
            TempRowInvoices = [];
            TempRowInvoices.splice(0, TempRowInvoices.length);
            RowInvoices = [];
            RowInvoices.splice(0, RowInvoices.length);
            for (const item of CloseInvoices)
            {
                if (item.Key == RowKey)
                {
                    clsRows += 1;
                    clsAmount += item.Amount;
                    TempRowInvoices.push({
                        Key: RowKey,
                        InvoiceKey: item.InvoiceKey,
                        Amount: item.Amount
                    });
                    RowInvoices.push({
                        Key: RowKey,
                        InvoiceKey: item.InvoiceKey,
                        Amount: item.Amount
                    });
                }
