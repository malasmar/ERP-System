@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }

    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<h1 class="page-header">@iT.T(xLan,"1400","Account Balance")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-3 col-md-12">
                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "1222","Year")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("ctr-Year").ShowSpinButtons(true).Width(130).Value(Year)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "1690","Month")</label>
                    <div class="col-9">
                        @Html.DevExtreme().SelectBox().ID("ctr-Month").Width(130).DataSource(iReplacer.MonthList(xLan)).ValueExpr("Value").DisplayExpr("Display").Value(DateTime.Now.Month)
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <hr />
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                    <button type="button" class="btn btn-danger btn-sm" onclick="ShowPostSalaries()">@iT.T(xLan, "2704","Create Journal Voucher")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiFinancial.Operation.SalariesPost>().ID("grd-SalariesPost")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("idocuments").Area("Financial")
                    .LoadAction("SalariesPost")
                    .LoadParams(new
                    {
                        Year = new JS("GetYear"),
                        Month = new JS("GetMonth")
                    })
                    )
                    .ColumnAutoWidth(true)
                    .Columns(columns =>
                    {
                        columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "2705", "Account Kind")).Width(65).Lookup(L => L.DataSource(iReplacer.finAccounts(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Kind"));
                        columns.AddFor(m => m.Type).Caption(iT.T(xLan, "2706", "Account Type")).Width(65).Lookup(L => L.DataSource(iReplacer.finEmployeeAcccountTypes(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4AccountType"));
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "2707", "Code")).Width(90);
                        columns.AddFor(m => m.Account).Caption(iT.T(xLan, "2708", "Account")).Lookup(L => L.DataSource(CLiFinancial.Selections.Dynamic.UnionSelection(DB, xLan, new PLenums.TransactionAccount[] { PLenums.TransactionAccount.Employee, PLenums.TransactionAccount.Expenses })).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("0,###.##");
                        columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("0,###.##");
                        columns.AddFor(m => m.CostCenter).Caption(iT.T(xLan, "2709", "CostCenter")).Width(150).Lookup(L => L.DataSource(CLiAccounting.Selections.CostCenter.FullList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Project).Caption(iT.T(xLan, "2710", "Project")).Width(150).Lookup(L => L.DataSource(CLiAccounting.Selections.Project.FullList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.Account).SummaryType(SummaryType.Count);

                            item.AddFor(m => m.Debit).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Credit).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");

                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "2711", "Salaries Post")))
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    .RemoteOperations(false)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    )
            </div>
        </div>
    </div>
</div>
<div id="mod-Post" class="modal"><div class="modal-dialog" id="con-Post"></div></div>
<script class="append-on-ajax-script">
    function ShowPostSalaries ()
    {
        $('#con-Post').empty();
        $("#con-Post").load('/Financial/Operation/PostSalariesPartial');
        $("#mod-Post").modal({ backdrop: 'static' }).modal('toggle');
    }
    var data;

    function RefreshGrid ()
    {
        $('#grd-SalariesPost').dxDataGrid("instance").refresh();
    }

    function GetYear ()
    {
        return $('#ctr-Year').dxNumberBox('option', 'value');
    }
    function GetMonth ()
    {
        return $('#ctr-Month').dxSelectBox('option', 'value');
    }

    
    function ct4Kind (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 1:
                str = '<div class="text-center"><span class="badge bg-success">' + options.text + '</span></div>';
                break;
            case 5:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
            case 6:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ct4AccountType (container, options)
    {
        var str = '';
        if (options.data.Kind!=1){
            return '<div class="text-center"><span class="badge bg-white">' + '' + '</span></div>';
        }
        switch (options.value)
        {
            case -1:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case 0:
                str = '<div class="text-center"><span class="badge bg-success">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
            case 2:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
            case 3:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
            case 4:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }

</script>
