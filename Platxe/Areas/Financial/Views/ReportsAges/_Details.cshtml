@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }

    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>

<script>
    function ct4Action (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'tips' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        ShowTransaction(options.data.DocumentKind, options.data.Key);
                        break;
                }
            },
        });
    }

    function ct4Description (container, options)
    {
        var str = '';
        str = '<p class="m-0 p-0 f-s-10" style="white-space:normal;">' + options.value + '</p>';
        $(str).appendTo(container)
    }
</script>


<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iT.T(xLan,"2167","Current Ages Details")</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <div class="modal-body">
        <div class="row">
            <div class="col-lg-5">
                <div class="card border-0 mb-1 bg-yellow text-dark acc">
                    <div class="card-body">
                        <div class="text-truncate">
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>@iT.T(xLan, "1228","Account Code")</td><td id="txt-Code"></td></tr>
                                    <tr><td>@iT.T(xLan, "1229","Name (Arabic )")</td><td id="txt-Arabic"></td></tr>
                                    <tr><td>@iT.T(xLan, "1230","Name (English)")</td><td id="txt-English"></td></tr>
                                    <tr><td>@iT.T(xLan, "2160","Limit")</td><td id="txt-Limit"></td></tr>
                                    <tr><td>@iT.T(xLan, "2161","Credit")</td><td id="txt-Credit"></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-1"></div>
            <div class="col-6">
                <table class="table-sm">
                    <thead>
                        <tr>
                            <th style="width:auto"></th>
                            <th style="width:auto"></th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr><td>@iT.T(xLan, "2168","Credit Totl")</td><td id="txt-CreditTotal"></td></tr>
                        <tr><td>@iT.T(xLan, "2162","Delayed")</td><td id="txt-Delayed"></td></tr>
                        <tr><td>@iT.T(xLan, "2163","Due")</td><td id="txt-Due"></td></tr>
                        <tr><td>@iT.T(xLan, "2169","30 Days")</td><td id="txt-Due30"></td></tr>
                        <tr><td>@iT.T(xLan, "2170","60 Days")</td><td id="txt-Due60"></td></tr>
                        <tr><td>@iT.T(xLan, "2171","90 Days")</td><td id="txt-Due90"></td></tr>
                    </tbody>
                </table>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <hr class="p-0 m-1" />
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="PrintReport()">@iT.T(xLan, "1361","Print Report")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiFinancial.Reports.Ages.AgesDetails>().ID("grd-AgesDetails")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("ireports").Area("Financial")
                    .Key("Key")
                    .LoadAction("AgesDetails")
                    .LoadParams(new
                    {
                        Key = ViewBag.Key
                    })
                    )
                    .FocusedRowEnabled(true)
                    .ColumnAutoWidth(true)
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption(iT.T(xLan, "", "#")).Width(40).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                        columns.AddFor(m => m.DocumentKind).Caption(iT.T(xLan, "1975", "DocumentKind")).Width(110).Lookup(L => L.DataSource(iReplacer.DocumentsName(xLan, true)).ValueExpr("Value").DisplayExpr("Display"));
                        columns.AddFor(m => m.InvoiceDate).Caption(iT.T(xLan, "2172", "Date")).Width(100).Format("dd.MM.yyyy");
                        columns.AddFor(m => m.InvoiceNo).Caption(iT.T(xLan, "2173", "Invoice No")).Width(80);
                        columns.AddFor(m => m.DueDate).Caption(iT.T(xLan, "2174", "Due Date")).Width(100).Format("dd.MM.yyyy");
                        columns.AddFor(m => m.DueDays).Caption(iT.T(xLan, "2175", "Due Days")).Width(90);
                        columns.AddFor(m => m.Total).Caption(iT.T(xLan, "2176", "Amount")).Width(90).Format("0,###.##");
                        columns.AddFor(m => m.ClosedAmount).Caption(iT.T(xLan, "2177", "Closed")).Width(90).Format("0,###.##");
                        columns.AddFor(m => m.Remaining).Caption(iT.T(xLan, "2178", "Remaining")).Width(90).Format("0,###.##");
                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.InvoiceDate).SummaryType(SummaryType.Count);
                            item.AddFor(m => m.Total).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.ClosedAmount).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Remaining).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .RowAlternationEnabled(true)
                    .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "2167", "Sales Ages Details")))
                    .RtlEnabled(devRtl)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    )
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="btn-group">
            <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1242","Close")</button>
        </div>
    </div>
</div>


<script class="append-on-ajax-script">
    $(document).ready(function ()
    {
        $('#txt-Code').text(data.Code);
        $('#txt-Arabic').text(data.Name1);
        $('#txt-English').text(data.Name2);
        $('#txt-Limit').text(comma(data.Limit));
        $('#txt-Credit').text(comma(data.Credit));
        $('#txt-CreditTotal').text(comma(data.Credit));
        $('#txt-Delayed').text(comma(data.Delayed));
        $('#txt-Due').text(comma(data.Due));
        $('#txt-Due30').text(comma(data.Due30));
        $('#txt-Due60').text(comma(data.Due60));
        $('#txt-Due90').text(comma(data.Due90));
    });





    function PrintReport ()
    {
        window.open('/Print/Financial/AccountStatment?Key=' + getKey() + '&FirstDate=' + getFirst() + '&LastDate=' + getLast() + '&Opening=' + getOpening());
    }
    function OpenTransaction (Kind, Key)
    {
        switch (Kind)
        {
            case 3:
            case 4:
            case 5:
            case 6:
            case 7:
            case 8:
                window.open('/Financial/Documents/Transaction?Key=' + Key);
                break;
            case 9:
                window.open('/Financial/Documents/JournalVoucher?Key=' + Key);
                break;
            case 80:
                window.open('/Sales/Documents/SalesInvoice?Key=' + Key);
                break;
            case 83:
                window.open('/Sales/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 71:
                window.open('/Purchasing/Documents/PurchaseInvoice?Key=' + Key);
                break;
            case 75:
                window.open('/Purchasing/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 77:
                window.open('/Inventory/Documents/Consumption?Key=' + Key);
                break;
            case 78:
                window.open('/Inventory/Documents/ConsumptionReturn?Key=' + Key);
                break;
            default:

                break;
        }
    }
    function ShowTransaction (Kind, Key)
    {
        switch (Kind)
        {
            case 3:
            case 4:
            case 5:
            case 6:
            case 7:
            case 8:
                ViewFinancialTransaction(Key);
                break;
            case 9:
                ViewJournalVoucher(Key);
                break;
            case 80:
            case 83:
                ViewSalesInvoices(Key);
                break;
            case 71:
            case 75:
                ViewPurchaseInvoice(Key);
                break;

                window.open('/Purchasing/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 77:
                window.open('/Inventory/Documents/Consumption?Key=' + Key);
                break;
            case 78:
                window.open('/Inventory/Documents/ConsumptionReturn?Key=' + Key);
                break;
            default:

                break;
        }
    }
</script>
