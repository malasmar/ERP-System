<h1 class="page-header">@iT.T(xLan,"1027","Cost Center and Project Dashboard")<span class="badge bg-Yellow">v14.2</span></h1>
<div class="row">
    <div class="col-xl-3 col-md-6">
        <div class="widget widget-stats bg-white text-dark">
            <div class="stats-icon stats-icon-square bg-gradient-cyan-blue text-white d-flex align-items-center justify-content-center"><i class="fas fa-user"></i></div>
            <div class="stats-content">
                <div class="stats-title text-dark text-opacity-75">@iT.T(xLan,"1148","Cost Center Count")</div>
                <div class="stats-number" id="txt-Clients">0</div>
                <div class="stats-progress progress">
                    <div class="progress-bar" style="width: 70.1%;"></div>
                </div>
                <div class="stats-desc text-dark text-opacity-75">@iT.T(xLan,"1149","All the Cost Center in the system.")</div>
            </div>
        </div>
    </div>
    <div class="col-xl-3 col-md-6">
        <div class="widget widget-stats bg-white text-dark">
            <div class="stats-icon stats-icon-square bg-gradient-cyan-blue text-white d-flex align-items-center justify-content-center"><i class="fas fa-user-tie"></i></div>
            <div class="stats-content">
                <div class="stats-title text-dark text-opacity-75">@iT.T(xLan,"1150","Project Count")</div>
                <div class="stats-number" id="txt-ActiveClients">0</div>
                <div class="stats-progress progress">
