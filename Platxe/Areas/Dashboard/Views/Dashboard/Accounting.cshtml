                <div class="stats-title text-dark text-opacity-75">@iT.T(xLan,"1004","General Ledger Count")</div>
                <div class="stats-number"><span id="txt-GL-Total">0</span></div>
                <div class="stats-progress progress">
                    <div class="progress-bar" style="width: 70.1%;"></div>
                </div>
                <div class="stats-desc text-dark text-opacity-75"><b id="txt-GL-Opining" class="me-2">11</b>@iT.T(xLan,"1005","Opening GL")</div>
