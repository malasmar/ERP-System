@{
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    string xLan = User.FindFirstValue("aiwLan");
}
<style>
    .tick line {
        display: none;
    }
       .xsc{
                overflow-y:auto;
                max-height:450px;
                    height:450px   ;
            }
</style>
<link href="~/template/assets/plugins/ionicons/css/ionicons.min.css?version=3.019" rel="stylesheet" />
<h1 class="page-header">@iT.T(xLan,"1001","Accounting Dashboard")  <span class="badge bg-Yellow">v14.2</span></h1>
<div class="row">
    <div class="col-lg-2 col-md-12">
        <div class="widget widget-stats bg-white text-dark mb-2">
