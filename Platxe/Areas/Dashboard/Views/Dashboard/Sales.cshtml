                        { 'label': '9', 'value': response.Sep, 'color': app.color.success },
                        { 'label': '10', 'value': response.Oct, 'color': app.color.cyan },
                        { 'label': '11', 'value': response.Nov, 'color': app.color.blue },
                        { 'label': '12', 'value': response.Dec, 'color': app.color.purple },
                    ]
                } ];
                nv.addGraph(function ()
                {
                    var barChart = nv.models.discreteBarChart()
                        .x(function (d) { return d.label })
                        .y(function (d) { return d.value })
                        .showValues(false)
                        .showXAxis(true)
                        .showYAxis(true)
                         .margin({
                            left: 60
                        })
                        .duration(250);
                    barChart.xAxis.axisLabel('Months');
                    d3.select('#nv-bar-chart svg').datum(barChartData).call(barChart);
                    nv.utils.windowResize(barChart.update);
                    return barChart;
                });
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
    function LoadWeaklySales ()
    {
        $.ajax({
            type: "get",
            url: "/api/Dash/iDashboard/WeaklyNetSales",
            dataType: "json",
            success: function (response)
            {
                var CurrentYear = [];
                for (const item of response)
                {
                    var d = new Date(item.VoucherDate);
                    CurrentYear.push([ d, item.Amount ]);
                }
                var stackedAreaChartData = [ {
                    'key': 'SALES',
                    'color': app.color.red,
                    'values': CurrentYear
                } ];
                nv.addGraph(function ()
                {
                    var stackedAreaChart = nv.models.stackedAreaChart()
                        .useInteractiveGuideline(true)
                        .x(function (d) { return d[ 0 ] })
                        .y(function (d) { return d[ 1 ] })
                        .controlLabels({ stacked: 'Stacked' })
                        .showControls(false)
                        .margin({
                            bottom: 25,
                            left: 80
                        })
                        .duration(300);
                    stackedAreaChart.xAxis.tickFormat(function (d) { return d3.time.format('%d.%m')(new Date(d)) });
                    stackedAreaChart.yAxis.tickFormat(d3.format(',.0f'));
                    d3.select('#nv-stacked-area-chart svg')
                        .datum(stackedAreaChartData)
                        .transition().duration(1000)
                        .call(stackedAreaChart)
                        .each('start', function ()
                        {
                            setTimeout(function ()
                            {
                                d3.selectAll('#nv-stacked-area-chart *').each(function ()
                                {
                                    if (this.__transition__)
                                        this.__transition__.duration = 1;
                                })
                            }, 0)
                        });
                    nv.utils.windowResize(stackedAreaChart.update);
                    return stackedAreaChart;
                });
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
