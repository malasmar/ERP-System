            success: function (response)
            {
                var barChartData = [ {
                    key: 'Cumulative Return',
                    values: [
                        { 'label': '1', 'value': response.Jan, 'color': app.color.red },
                        { 'label': '2', 'value': response.Feb, 'color': app.color.orange },
                        { 'label': '3', 'value': response.Mar, 'color': app.color.success },
