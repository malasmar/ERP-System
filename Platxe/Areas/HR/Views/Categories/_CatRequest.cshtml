@model CLiHR.Categories.Request
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iT.T(xLan,"2347","Request Cards")</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <form id="frm-CatRequest" data-parsley-validate="true">
        <div class="modal-body">
            @Html.HiddenFor(m => m.Key)
            @{
                if (Model.Key != null)
                {
                    <div class="xkey text-gray">@iT.T(xLan,"1299","Key"): @Model.Key</div>
                }
            }
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1265","No")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().NumberBoxFor(m => m.No).ID("cnt-No").Width(120)
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1274","Arabic Name")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true)
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1166","English Name")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2")
                </div>
            </div>
            <div class="form-group row mt-4">
                <label class="col-lg-3 col-sm-12  "></label>
                <div class="col-lg-8 col-sm-12">
                    @Html.DevExtreme().CheckBoxFor(m => m.FinancialConfirmation).Text(iT.T(xLan, "1562","Financial Confirmation"))
                    <div class="p-1">
                        <small>Request must approval from financial department</small>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12 "></label>
                <div class="col-lg-8 col-sm-12">
                    @Html.DevExtreme().CheckBoxFor(m => m.HRConfirmation).Text(iT.T(xLan, "2356","HR Confirmation"))
                    <div class="p-1">
                        <small>Request must approval from HR department</small>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12 "></label>
                <div class="col-lg-8 col-sm-12">
                    @Html.DevExtreme().CheckBoxFor(m => m.SupervisorConfirmation).Text(iT.T(xLan, "2357","Supervisor Confirmation"))
                    <div class="p-1">
                        <small>Request must approval from All structure has admin approval rights</small>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12 "></label>
                <div class="col-lg-8 col-sm-12">
                    @Html.DevExtreme().CheckBoxFor(m => m.ClosedOnBoss).Text(iT.T(xLan, "2731","Boss Confirmation"))
                    <div class="p-1">
                        <small>Request closed with boss confirmation</small>
                    </div>
                </div>
            </div>
       
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1282","Status")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().SwitchFor(m => m.Disable).ID("cnt-Disable").Width(65).SwitchedOnText("Disable").SwitchedOffText("Active")
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <div class="btn-group">
                <button type="submit" class="btn btn-yellow text-dark">@iT.T(xLan,"1197","Save Change")</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1198","Cancel")</button>
            </div>
        </div>
    </form>
</div>
<script class="append-on-ajax-script">
    $(document).ready(function ()
    {
        $("#frm-CatRequest").submit(function (event)
        {
            event.preventDefault();
            SaveAccount();
        });
    });
    function SaveAccount ()
    {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "")
        {
            alert('Please enter Code!');
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "")
        {
            alert('Please enter name (Display) !');
            return;
        }
        var data = $('#frm-CatRequest').serialize();
        $.ajax({
            type: "POST",
            url: "/api/hr/icards/UpdateCatRequest",
            data: data,
            dataType: "json",
            success: function (response)
            {
                $("#mod-CatRequest").modal('toggle');
                RefreshGrid();
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
</script>
