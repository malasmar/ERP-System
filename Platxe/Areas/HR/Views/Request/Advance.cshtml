@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<h1 class="page-header">@iT.T(xLan,"2623","Advance Request")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-4 col-md-12">

                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "2624","Status")</label>
                    <div class="col-9">
                        @Html.DevExtreme().SelectBox().ID("ctr-Status").Width(130).DataSource(iReplacer.hrRequestStatus(xLan)).ValueExpr("Value").DisplayExpr("Display").Value(100)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "2625","Structure")</label>
                    <div class="col-9">
                        @Html.DevExtreme().SelectBox().ID("ctr-Structure").Width(350).DataSource(CLiHR.Selections.Structure.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-dark" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiHR.Request.Advance>().ID("grd-Advance")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("iselfService").Area("HR")
                    .Key("Key")
                    .LoadAction("RequestAdvance")
                    .LoadParams(new
                    {
                        Status = new JS("GetStatus"),
                        Key = new JS("GetStructure")
                    })
                    )
                    .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                    .Columns(columns =>
                    {
                        columns.AddFor(m => m.Status).Caption(iT.T(xLan, "1282", "Status")).Width(75).Lookup(L => L.DataSource(iReplacer.hrRequestStatus(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Status"));
                        columns.AddFor(m => m.Create).Caption(iT.T(xLan, "2626", "Create")).Width(110).Format("dd.MM.yyyy HH:mm");
                        columns.AddFor(m => m.Structure).Caption(iT.T(xLan, "1444", "Structure")).Width("25%").Lookup(L => L.DataSource(CLiHR.Selections.Structure.GetList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Employee).Caption(iT.T(xLan, "2627", "Employee")).Width("25%").Lookup(L => L.DataSource(CLiHR.Selections.Employees.GetList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Year).Caption(iT.T(xLan, "2628", "Year")).Width(85);
                        columns.AddFor(m => m.Month).Caption(iT.T(xLan, "2629", "Month")).Width(85);
                        columns.AddFor(m => m.Amount).Caption(iT.T(xLan, "2630", "Amount")).Width(85).Format("0,###.##");
                        columns.AddFor(m => m.Description).Caption(iT.T(xLan, "1212", "Description")).Width("50%").MinWidth(100).CellTemplate(new JS("ct4Description"));
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    )
            </div>
        </div>
    </div>
</div>
<script class="append-on-ajax-script">
    function RefreshGrid ()
    {
        $('#grd-Advance').dxDataGrid("instance").refresh();
    }

    function GetStatus ()
    {
        return $('#ctr-Status').dxSelectBox('option', 'value');
    }
    function GetStructure ()
    {
        return $('#ctr-Structure').dxSelectBox('option', 'value');
    }
    function ct4Description (container, options)
    {
        var str = '';
        str = '<p class="m-0 p-0 f-s-10" style="white-space:normal;">' + options.value + '</p>';
        $(str).appendTo(container)
    }
    function ct4Status (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge bg-gray text-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case -1:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
</script>
