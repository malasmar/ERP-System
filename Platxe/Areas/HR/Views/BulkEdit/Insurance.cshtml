@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<h1 class="page-header">@iT.T(xLan,"1442","Employees Edit") <small class="me-2">@iT.T(xLan,"1448","Insurance Details")</small></h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-dark" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiHR.Cards.Employee>().ID("grd-Employee")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("icards").Area("HR")
                    .Key("Key")
                    .LoadAction("Employee").UpdateAction("UpdateEmployees"))
                    .Editing(ed => ed.Mode(GridEditMode.Batch).AllowUpdating(true).AllowAdding(false).AllowDeleting(false).UseIcons(true))
                    .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption(iT.T(xLan, "", "#")).Width(45).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(100);
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1443", "Employee Name"));
                        columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166", "English Name"));
                        columns.AddFor(m => m.Insurance).Caption(iT.T(xLan, "1517", "Insurance")).Width(120).Lookup(L => L.DataSource(iReplacer.hrInsurance(xLan)).ValueExpr("Value").DisplayExpr("Display"));
                        columns.AddFor(m => m.InsuranceNo).Caption(iT.T(xLan, "1518", "Insurance No")).Width(100);
                        columns.AddFor(m => m.InsuranceSalary).Caption(iT.T(xLan, "1519", "Insurance Salary")).Format("0,###.##").Width(100);
                        columns.AddFor(m => m.InsuranceHome).Caption(iT.T(xLan, "1520", "Ins.Home Allowance")).Format("0,###.##").Width(100);
                        columns.AddFor(m => m.InsuranceOther).Caption(iT.T(xLan, "1521", "Ins.Other Allowance")).Format("0,###.##").Width(100);
                        columns.AddFor(m => m.InsuranceKind).Caption(iT.T(xLan, "1522", "Insurance Kind")).Width(120).Lookup(L => L.DataSource(iReplacer.hrInsuranceKind(xLan)).ValueExpr("Value").DisplayExpr("Display"));
                        columns.AddFor(m => m.InsuranceValue).Caption(iT.T(xLan, "1523", "Insurance Value")).Format("0,###.##").Width(100);
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    )
            </div>
        </div>
    </div>
</div>
<div id="mod-Employee" class="modal"><div class="modal-dialog" id="con-Employee"></div></div>
<script class="append-on-ajax-script">
    function ct4Action (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        if (e.itemData.icon == 'edit')
                        {
                            GetDetails(options.data.Key);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid ()
    {
        $('#grd-Employee').dxDataGrid("instance").refresh();
    }
    function GetDetails (Key)
    {
        $('#con-Employee').empty();
        $("#con-Employee").load('/HR/Cards/EmployeeDetails?Key=' + Key);
        $("#mod-Employee").modal({ backdrop: 'static' }).modal('toggle');
    }
</script>
