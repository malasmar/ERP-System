    function SaveGeneralLedger ()
    {
        if (ValidateSave() == false)
        {
            return;
        }

        if (InPosting == true)
            return;

        InPosting = true;
        $('.PLSave').prop('disabled', true);

        $.confirm({
            title: 'Confirm',
            content: 'Save/update Transaction confirmation?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Save/Update',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                        //Start Update
                        var values = [];
                        $('#tb-rows').find('tr').each(function ()
                        {
                            var d = new Date($(this).find('[id="td-ExpDate"]').data('value'));
                            //d.setDate(d.getDate() + 1);
                            if (d.getFullYear() < 2000)
                            {
                                d = null;
                            }
                            values.push({
                                Key: $(this).find('[id="td-Key"]').data('value'),
                                CloseRowKey: $(this).find('[id="td-CloseRowKey"]').data('value'),
                                Index: $(this).find('[id="td-Index"]').data('value'),
                                ItemKind: $(this).find('[id="td-ItemKind"]').data('value'),
                                ItemKey: $(this).find('[id="td-ItemKey"]').data('value'),
                                ProDate: null,
                                ExpDate: d,
                                Color: $(this).find('[id="td-Color"]').data('value'),
                                Size: $(this).find('[id="td-Size"]').data('value'),
                                Unit: $(this).find('[id="td-Unit"]').data('value'),
                                UnitPrice: $(this).find('[id="td-UnitPrice"]').data('value'),
                                Quantity: $(this).find('[id="td-Quantity"]').data('value'),
                                Amount: $(this).find('[id="td-Amount"]').data('value'),
                                Discount: $(this).find('[id="td-Discount"]').data('value'),
                                UnitCost: $(this).find('[id="td-UnitCost"]').data('value'),
                                Total: $(this).find('[id="td-Total"]').data('value'),
                                Batch: $(this).find('[id="td-BatchKey"]').data('value'),
                                ConsumptionKind: $(this).find('[id="td-ConsumptionKind"]').data('value'),
                                Status: $(this).find('[id="td-Status"]').data('value'),
                                Description: $(this).find('[id="td-Description"]').data('value'),
                                CostCenter: $(this).find('[id="td-CostCenter"]').data('value'),
                                BatchDetails: {
                                    Batch: $(this).find('[id="td-Batch"]').data('value'),
                                    Lot: $(this).find('[id="td-Lot"]').data('value'),
                                    PartRate: $(this).find('[id="td-PartRate"]').data('value'),
                                    PartPrice: $(this).find('[id="td-PartPrice"]').data('value')
                                }
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/inv/idocuments/UpdateConsumption",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus,
                            dataType: "json",
                            success: function (response)
                            {
                                if (response.Status == true)
                                {
                                    exDocumentError(response);
                                    return;
                                }
                                $('#No').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info');
                                $('#inf-Status').addClass('bg-danger');
                                $('#txt-Status').text(iShll.update);
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                InPosting = false;
                                $('.PLSave').prop('disabled', false);
                                //ShowPrintTemplate();
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });
                        //End Update
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return;
                    }
                }
            }
        });
    }
    //Advance Payments
    function GetMonthlyNo ()
    {
        var d = new Date();
        d = $('#frm-InvoiceDate').dxDateBox('option', 'value');
        $.ajax({
            type: "get",
            url: "/api/icore/MaxMonthlyInvoice",
            data: { DocumentKind: 80, Year: d.getFullYear(), Month: d.getMonth() + 1 },
            dataType: "json",
            success: function (response)
            {
                $('#txt-MonthlyNo').text(response);
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
