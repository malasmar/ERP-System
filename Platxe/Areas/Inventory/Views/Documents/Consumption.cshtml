    function SelectedItemChanged (e)
    {
        if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
        {
            if (e.value == null)
            {
                $('#btn-rowEdit').prop('hidden', true);
                $('#btn-rowAdd').prop('hidden', false);
            } else
            {
                $('#btn-rowEdit').prop('hidden', false);
                $('#btn-rowAdd').prop('hidden', true);
            }
        }
        var acckind = $('#row-ItemKind').dxSelectBox('option', 'value');
        switch (acckind)
        {
            case 8:
                $("#row-Unit").dxSelectBox("reset");
                $("#row-Unit").dxSelectBox({
                    dataSource: '/api/inv/icore/ItemUnits?Key=' + e.value
                });
                $("#row-Unit").dxSelectBox("getDataSource").load().done(function (data)
                {
                    if (data.length > 0)
                    {
                        $("#row-Unit").dxSelectBox("option", "value", data[ 0 ].Code);
                    }
                });
                $.ajax({
                    type: "get",
                    url: "/api/inv/icore/InvoiceItemDetails",
                    data: { Key: e.value },
                    dataType: "json",
                    success: function (response)
                    {
                        RowItemDetails = response;
                        $('#div-Batch').prop('hidden', response.EnableBatch == false ? true : false);
                        $('#div-Color').prop('hidden', response.EnableColor == false ? true : false);
                        $('#div-Size').prop('hidden', response.EnableSize == false ? true : false);
                        if (response.EnableBatch == true)
                        {
                            $('#row-PartPrice').dxNumberBox('option', 'value', response.PartPrice);
                            $('#row-PartRate').dxNumberBox('option', 'value', response.PartRate);
                        }
                        if (isNewRow == true)
                        {
                            if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
                            {
                                $('#row-UnitPrice').dxNumberBox('option', 'value', response.Price);
                            }
                        }
                    },
                    failure: function (response)
                    {
                        alert(response);
                    },
                    error: function (response)
                    {
                        alert(response.responseText);
                    }
                });
                break;
            default:
                $('#div-Batch').prop('hidden', true);
                $('#div-Color').prop('hidden', true);
                $('#div-Size').prop('hidden', true);
                break;
        }
    }
