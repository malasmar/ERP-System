@model CLiInventory.Documents.Transaction
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    string Currency = CLiCore.VoucherOperation.DefaultCurrency(DB);
    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
  
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }

    .xd > tr:hover {
        cursor: pointer;
    }

    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }

    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }

    .width-20 {
        width: 20px !important;
        min-width: 20px !important;
    }
</style>
<div class="invoice">
    <div class="invoice-company">
        <div class="float-end hidden-print">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="window.print()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
        <div class="float-end hidden-print me-1">
            <div class="btn-group">
                <button type="button" class="btn btn-gray mb-10px" onclick="ViewGeneralLedger('@Model.OperationKey')">GL</button>
            </div>
        </div>
        <div class="shl-invoice-header">

            @iT.T(xLan,"1623","Consumption Stock") <span id="inf-Status" class="badge bg-info text-dark"><small class="f-s-9 me-1">@iT.T(xLan,"2141","Status")</small><span id="txt-Status" class="me-1">Update</span></span><span id="txt-VoucherNo" class="text-danger"># @Model.InvoiceNo </span>

            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
        </div>
    </div>
    <form id="frm-Voucher">
        @Html.HiddenFor(m=>m.DocumentKind)
        @Html.HiddenFor(m=>m.OperationKey)
        @Html.HiddenFor(m=>m.InvoiceNo)
        @Html.HiddenFor(m=>m.MonthlyNo)
        @Html.HiddenFor(m=>m.CreateUser)
        @Html.HiddenFor(m=>m.CreateDate)
        @Html.HiddenFor(m=>m.OriginalInvoice)
        @Html.HiddenFor(m=>m.AccountKind)
        <div class="invoice-header">
            <div class="invoice-from">
                <div class="row">
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1624","Invoice Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().DateBoxFor(m => m.InvoiceDate).ID("frm-InvoiceDate").Width(125).DisplayFormat("dd.MM.yyyy").Min(new DateTime(xYear,1,1)).Max(DateTime.UtcNow.AddMinutes(180)).OnValueChanged("GetMonthlyNo")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1625","Warehouse")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SourceWarehouse).ID("frm-SourceWarehouse").DataSource(CLiInventory.Selections.Warehouse.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display") 
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1355","Client")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.AccountKey).ID("frm-AccountKey").DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, PLenums.TransactionAccount.Expenses)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1212","Description")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextAreaFor(m => m.Description).ID("frm-Description").Height(60)
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1328","Prefix")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Prefix).ID("frm-Prefix").DataSource(CLiFinancial.Selections.Prefix.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display") 
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display") 
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1220","Project")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.Project).ID("frm-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display") 
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1332","Cst.Center")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.CostCenter).ID("frm-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display") 
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-3 ">
                                    <b class="mb-3">Invoice Total</b>
                                </div>
                                <div class="d-flex align-items-center mb-1">
                                    <h2 class="mb-0"><span>@Model.Total.ToString("n2")</span></h2>
                                </div>
                                <div class="mb-4">
                                    <span></span>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>Subtotal
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.SubTotal.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>Discount
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Discount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>Total
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Total.ToString("n2")</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <div class="invoice-content mt-3">
        <div class="sticky">
            <button type="button" id="btn-add" class="btn btn-yellow btn-sm text-dark" onclick="AddNewRow()">@iT.T(xLan,"1988","Ad New Row")</button>
            <button type="button" id="btn-CopyInvoice" class="btn btn-white btn-sm" onclick="ShowCopyInvoice()" title="@iT.T(xLan,"2231","Copy from previous invoice")"><i class="fa fa-clone"></i></button>
            <button hidden type="button" id="btn-InvoicedQuotation" class="btn btn-danger btn-sm" onclick="LoadQuotationDetails()">@iT.T(xLan,"1627","Return ALl")</button>
        </div>
        <div class="table-responsive">
            <table class="table table-invoice table-hover">
                <thead>
                    <tr>
                        <th style="width:100px;max-width:100px">@iT.T(xLan,"1215","Actions")</th>
                        <th style="width:65px;min-width:65px;max-width:65px">@iT.T(xLan,"1158","Kind")</th>
                        <th style="width:120px;min-width:120px;max-width:120px">@iT.T(xLan,"1164","Code")</th>
                        <th style="width:100%;min-width:150px">@iT.T(xLan,"1586","Item Name")</th>
                        <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1628","Expiry")</th>
                        <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1076","Quantity")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1629","Unit Price")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1120","Total")</th>
                    </tr>
                </thead>
                <tbody class="xd" id="tb-rows">
                </tbody>
            </table>
        </div>
        <div class="invoice-price">
            <div class="invoice-price-left">
                <div class="invoice-price-row">
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1347","Subtotal")</small>
                        <span id="txt-Amount" class="text-dark">0.00</span>
                    </div>
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1120","Total")</small>
                        <span id="txt-Total" class="text-red me-2">0.00</span>
                    </div>
                </div>
            </div>
            <div class="invoice-price-right">
                <small>@iT.T(xLan,"1120","TOTAL")</small> <span class="fw-bold" id="txt-xTotal">0.00</span>
            </div>
        </div>
    </div>
    <div class="invoice-note">
        <hr>
        <div class="text-left">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> >@iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="window.print()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i>@iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
    </div>
</div>
<div id="mod-Row" class="modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@iT.T(xLan,"1218","Row Details")</h4>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1333","Account Kind")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-ItemKind").DataSource(iReplacer.invSalesItems(xLan)).ValueExpr("Value").DisplayExpr("Display").Width(150).Value(8).ReadOnly(true).OnValueChanged("ChangeItemKind")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"","Item/Account")</label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="input-group">
                            @Html.DevExtreme().Lookup().ID("row-Account").DataSourceOptions(x=>x.Paginate(true).PageSize(50)).ValueExpr("Key").DisplayExpr("Display").Width("90%").ShowClearButton(true).OnValueChanged("SelectedItemChanged")
                            <button hidden id="btn-rowSearch" type="button" class="btn btn-white f-s-10" onclick="SearchQuotationDetails()" style="max-width:35px"><i class="fas fa-search"></i></button>
                            <button id="btn-rowAdd" type="button" class="btn btn-white f-s-10" onclick="AddRowAccount()" style="max-width:35px"><i class="fas fa-plus"></i></button>
                            <button hidden id="btn-rowEdit" type="button" class="btn btn-white f-s-10" onclick="AddRowAccount()" style="max-width:35px"><i class="fas fa-pen"></i></button>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1587","Unit")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-Unit").ValueExpr("Code").DisplayExpr("Code").Width(150)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12"></label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="alert alert-yellow  m-1 p-1 rounded-1">
                            Unlimited Navigation Tabs is <b>not compatible</b> with the bootstrap dropdown menu.
                        </div>
                    </div>
                </div>
                <div id="div-Batch" hidden>
                    <div id="item-expiry" class="form-group row">
                        <label class="col-3  ">@iT.T(xLan, "1630","Expiry Date")</label>
                        <div class="col-9">
                            @Html.DevExtreme().DateBox().ID("row-ExpDate").Width(132).DisplayFormat("dd.MM.yyyy").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-3  ">@iT.T(xLan,"1631","Batch Code")</label>
                        <div class="col-9">
                            <div class="input-group">
                                @Html.DevExtreme().TextBox().ID("row-Batch").Width("90%").ElementAttr("class", "plxenter")
                                <button type="button" class="btn btn-white btn-xs" onclick="SearchBatchLot()"><i class="fa fa-search width-20"></i></button>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-3  ">@iT.T(xLan,"1632","Lot No.")</label>
                        <div class="col-9">
                            <div class="input-group">
                                @Html.DevExtreme().TextBox().ID("row-Lot").Width("90%").ElementAttr("class", "plxenter")
                                <button type="button" class="btn btn-white btn-xs" onclick="SearchBatchLot()"><i class="fa fa-search width-20"></i></button>
                            </div>
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-3  ">@iT.T(xLan,"1324","Sales Price")</label>
                        <div class="col-9">
                            @Html.DevExtreme().NumberBox().ID("row-SalesPrice").ShowSpinButtons(true).Width(132).Format("0,###.####").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-3  ">@iT.T(xLan,"1590","Part Rate")</label>
                        <div class="col-9">
                            @Html.DevExtreme().NumberBox().ID("row-PartRate").ShowSpinButtons(true).Width(132).Value(0).ElementAttr("class", "plxenter")
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-3  ">@iT.T(xLan,"1591","Part Price")</label>
                        <div class="col-9">
                            @Html.DevExtreme().NumberBox().ID("row-PartPrice").ShowSpinButtons(true).Width(132).Value(0).ElementAttr("class", "plxenter")
                        </div>
                    </div>
                </div>
                <div>
                    <div id="div-color" class="form-group row" hidden>
                        <label class="col-lg-3 col-sm-12  ">Item Color <span class="text-red right">*</span></label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().SelectBox().ID("row-Color").Width(132).DataSource(CLiInventory.Selections.Properties.Colors(DB, xLan)).ValueExpr("No").DisplayExpr("Display").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                    <div id="div-size" class="form-group row" hidden>
                        <label class="col-lg-3 col-sm-12  ">Item Size<span class="text-red right">*</span></label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().SelectBox().ID("row-Size").Width(132).DataSource(CLiInventory.Selections.Properties.Sizes(DB, xLan)).ValueExpr("No").DisplayExpr("Display").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                </div>
                <hr class="p-0 m-2" />
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1076","Quantity")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Quantity").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.##").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1989","UnitPrice")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-UnitPrice").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.####").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1077","Amount")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Amount").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.####").ReadOnly(true)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1120","Total")</label>
                    <div class="col-9">
                        <div class="input-group">
                            @Html.DevExtreme().NumberBox().ID("row-Total").Width(130).ShowSpinButtons(true).Format("0,###.####")
                            <button type="button" class="btn btn-white f-s-10" onclick="RefelectAmount()">@iT.T(xLan, "1326","Reflect Amount")</button>
                        </div>
                    </div>
                </div>
                <hr class="p-0 m-2" />
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1212","Description")</label>
                    <div class="col-9">
                        @Html.DevExtreme().TextBox().ID("row-Description")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1199","Cost Center")</label>
                    <div class="col-9">
                        @Html.DevExtreme().Lookup().ID("row-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1220","Project")</label>
                    <div class="col-9">
                        @Html.DevExtreme().Lookup().ID("row-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true)
                    </div>
                </div>
            </div>
            <div class="modal-footer sticky-bottom">
                <div class="btn-group">
                    <button type="submit" class="btn btn-yellow text-dark" onclick="SaveRowChange()">@iT.T(xLan,"1197","Save Change")</button>
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1198","Cancel")</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="mod-CopyInvoice" class="modal"><div class="modal-dialog modal-lg" id="con-CopyInvoice"></div></div>
<script class="append-on-ajax-script">
    var clcDebitCredit = 0;
    var isNewRow;
    var currentRow;
    var opk = null;
    var VoucherStatus = false;
    var Currency;
    var rowCurrentItemKey = null;
    var RowKey = null;
    var RowItemDetails;
    var IsLoading;
    var DiscountKind = false;
    var ModalShowKind = 0;
    var CloseRowKey = null;
    var InvoiceStatus = 0;
    var InPosting = false;
    $(document).ready(function ()
    {
        Currency = '@Currency';
        if ('@ViewBag.Status' == 'True')
        {
            opk = '@Model.OperationKey';
            InvoiceStatus = Number('@Model.Status');
            VoucherStatus = false;
            $('#inf-Status').removeClass('bg-info');
            $('#inf-Status').addClass('bg-danger');
            $('#txt-Status').text(iShll.update);
            LoadData(opk);
        } else
        {
            $('#inf-Status').addClass('bg-info');
            $('#inf-Status').removeClass('bg-danger');
            $('#txt-Status').text(iShll.new);
            VoucherStatus = true;
        }
        $('#tb-rows').on('click', '#btn-edit', function ()
        {
            IsLoading = 1;
            $('#tb-rows').find('[id="tr-' + $(this).data('key') + '"]').each(function ()
            {
                RowKey = $(this).find('[id="td-Key"]').data('value');
                rowCurrentItemKey = $(this).find('[id="td-ItemKey"]').data('value');
                CloseRowKey = $(this).find('[id="td-CloseRowKey"]').data('value');
                $('#row-ItemKind').dxSelectBox('option', 'value', $(this).find('[id="td-ItemKind"]').data('value'));
                $('#row-Account').dxLookup('option', 'value', $(this).find('[id="td-ItemKey"]').data('value'));
                $('#row-Unit').dxSelectBox('option', 'value', $(this).find('[id="td-Unit"]').data('value'));
                $('#row-ExpDate').dxDateBox('option', 'value', $(this).find('[id="td-ExpDate"]').data('value'));
                $('#row-Color').dxSelectBox('option', 'value', $(this).find('[id="td-Color"]').data('value'));
                $('#row-Size').dxSelectBox('option', 'value', $(this).find('[id="td-Size"]').data('value'));
                $('#row-Quantity').dxNumberBox('option', 'value', $(this).find('[id="td-Quantity"]').data('value'));
                $('#row-UnitPrice').dxNumberBox('option', 'value', $(this).find('[id="td-UnitPrice"]').data('value'));
                $('#row-Amount').dxNumberBox('option', 'value', $(this).find('[id="td-Amount"]').data('value'));
                $('#row-Total').dxNumberBox('option', 'value', $(this).find('[id="td-Total"]').data('value'));
                $('#row-Description').dxTextBox('option', 'value', $(this).find('[id="td-Description"]').data('value'));
                $('#row-CostCenter').dxLookup('option', 'value', $(this).find('[id="td-CostCenter"]').data('value'));
                $('#row-Project').dxLookup('option', 'value', $(this).find('[id="td-Project"]').data('value'));
            });
            currentRow = $(this).data('key');
            isNewRow = false;
            IsLoading = 0;
            $("#mod-Row").modal({ backdrop: 'static' }).modal('toggle');
        });
        inChangeItemKind = 1;
        $("#row-Account").dxLookup({
            dataSource: '/api/icore/LoadAccounts?Kind=8'
        });
        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup("getDataSource").load();
        inChangeItemKind = 0;
