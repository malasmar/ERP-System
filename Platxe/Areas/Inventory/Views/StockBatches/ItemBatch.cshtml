@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<h1 class="page-header">@iT.T(xLan,"1655","Item Batches")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-dark" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiInventory.Cards.StockItem>().ID("grd-StockItem")
                .ShowBorders(true).Width("100%")
                .DataSource(d => d.WebApi()
                    .Controller("icards").Area("Inventory")
                .Key("Key")
                .LoadAction("StockItem"))
                .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                .Columns(columns =>
                {
                columns.Add().Name("act").Caption(iT.T(xLan,  "","#")).Width(35).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                columns.AddFor(m => m.Category).Caption(iT.T(xLan, "1172","Parent")).Width(165).Lookup(L=>L.DataSource(CLiInventory.Selections.Categories.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display"));
                columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164","Code")).Width(100);
                columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165","Account Name"));
                columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166","English Name"));
                columns.AddFor(m => m.Barcode).Caption(iT.T(xLan, "1423","Barcode")).Width(100);
                columns.AddFor(m => m.Cost).Caption(iT.T(xLan, "1576","Cost")).Width(85).Format("0,###.##");
                columns.AddFor(m => m.Price).Caption(iT.T(xLan, "1187","Price")).Width(85).Format("0,###.##");;
                columns.AddFor(m => m.vatKey).Caption(iT.T(xLan, "1297","vat Rate")).Width(100).Lookup(L=>L.DataSource(CLiFinancial.Selections.vatRate.vatRates(DB,xLan)).ValueExpr("Key").DisplayExpr("Display"));
                columns.AddFor(m => m.Total).Caption(iT.T(xLan, "1120","Total")).Width(85).Format("0,###.##");;
                columns.AddFor(m => m.Disable).Caption(iT.T(xLan, "1282","Status")).Width(75).Lookup(L=>L.DataSource(iReplacer.CardStatus(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Disable"));
                })
                .Pager(pg =>
                {
                pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                pg.ShowNavigationButtons(true);
                pg.ShowPageSizeSelector(true);
                pg.ShowInfo(true);
                pg.InfoText("{0} of {1} | {2} Rows");
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                sp.Width(250);
                sp.Visible(true);
                })
                .RowAlternationEnabled(true)
                .RtlEnabled(devRtl)
                )
            </div>
        </div>
    </div>
</div>
<div id="mod-ItemBatches" class="modal"><div class="modal-dialog modal-lg" id="con-ItemBatches"></div></div>
<div id="mod-ItemBatch" class="modal"><div class="modal-dialog modal-x2" id="con-ItemBatch"></div></div>
<script class="append-on-ajax-script">
    function ct4Action(container, options) {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'tips' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function(e) {
                switch (e.itemIndex) {
                    case 0:
                        if (e.itemData.icon == 'tips') {
                            ItemBatches(options.data.Key);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid() {
        $('#grd-StockItem').dxDataGrid("instance").refresh();
    }
    function ct4Disable(container, options) {
        var str = '';
        switch (options.value) {
            case false:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case true:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ItemBatches(Key) {
        $('#con-ItemBatches').empty();
        $("#con-ItemBatches").load('/Inventory/StockBatches/ItemBatches?Key=' + Key);
        $("#mod-ItemBatches").modal({ backdrop: 'static' }).modal('toggle');
    }
    function ct4SUAction(container, options) {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function(e) {
                switch (e.itemIndex) {
                    case 0:
                        if (e.itemData.icon == 'edit') {
                            AddNewUnit(options.data.Key, options.data.Item);
                        }
                        break;
                }
            },
        });
    }
    function AddNewUnit(Key, Item) {
        $('#con-ItemBatch').empty();
        $("#con-ItemBatch").load('/Inventory/StockBatches/BatchDetails?Key=' + Key + '&Item=' + Item);
        $("#mod-ItemBatch").modal({ backdrop: 'static' }).modal('toggle');
    }
</script>
