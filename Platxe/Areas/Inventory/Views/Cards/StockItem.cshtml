@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<h1 class="page-header">@iT.T(xLan,"1573","Stock Items Cards")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-dark" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                    <button type="button" class="btn btn-yellow text-dark" onclick="GetDetails(null)">@iT.T(xLan, "1574","New Stock Item")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiInventory.Cards.StockItem>().ID("grd-StockItem")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("icards").Area("Inventory")
                    .Key("Key")
                    .LoadAction("StockItem"))
                    .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption(iT.T(xLan, "", "#")).Fixed(true).FixedPosition(devFixd).Width(100).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                        columns.AddFor(m => m.EnablePkg).Caption(iT.T(xLan, "2367", "Package")).Width(65).Lookup(L => L.DataSource(iReplacer.InvStockPkg(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4EnablePkg"));
                        columns.AddFor(m => m.Category).Caption(iT.T(xLan, "1162", "Category")).Width(190).CellTemplate(new JS("ctWordWrap")).Lookup(L => L.DataSource(CLiInventory.Selections.Categories.GetList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(100);
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).MinWidth(200).CellTemplate(new JS("ctWordWrap"));
                        columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166", "English Name")).MinWidth(150).CellTemplate(new JS("ctWordWrap"));
                        columns.AddFor(m => m.Barcode).Caption(iT.T(xLan, "1423", "Barcode")).Width(100);
                        columns.AddFor(m => m.Cost).Caption(iT.T(xLan, "1576", "Cost")).Width(85).Format("0,###.##");
                        columns.AddFor(m => m.Price).Caption(iT.T(xLan, "1187", "Price")).Width(85).Format("0,###.##"); ;
                        columns.AddFor(m => m.vatKey).Caption(iT.T(xLan, "1297", "vat Rate")).Width(100).Lookup(L => L.DataSource(CLiFinancial.Selections.vatRate.vatRates(DB, xLan)).ValueExpr("Key").DisplayExpr("Display"));
                        columns.AddFor(m => m.Total).Caption(iT.T(xLan, "1120", "Total")).Width(85).Format("0,###.##"); ;
                        columns.AddFor(m => m.Disable).Caption(iT.T(xLan, "1282", "Status")).Width(75).Lookup(L => L.DataSource(iReplacer.CardStatus(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Disable"));
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .RowAlternationEnabled(true)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    .RtlEnabled(devRtl)
                    )
            </div>
        </div>
    </div>
</div>
<div id="mod-StockItem" class="modal"><div class="modal-dialog" id="con-StockItem"></div></div>
<div id="mod-StockUnits" class="modal"><div class="modal-dialog" id="con-StockUnits"></div></div>
<div id="mod-StockUnit" class="modal"><div class="modal-dialog modal-x2" id="con-StockUnit"></div></div>
<script class="append-on-ajax-script">
    var key = null;
    function ct4Action (container, options)
    {

        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' },
                { icon: 'tips' },
                { icon: 'trash' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        if (e.itemData.icon == 'edit')
                        {
                            key    =options.data.Key;
                            GetDetails(options.data.Key);
                        }
                        break;
                    case 1:
                        if (e.itemData.icon == 'tips')
                        {
                            ItemUnits(options.data.Key);
                        }
                        break;
                    case 2:
                        if (e.itemData.icon == 'trash')
                        {
                            DeleteRow(options.data.Key, options.data.Name1);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid ()
    {
        $('#grd-StockItem').dxDataGrid("instance").refresh();
    }
    function GetDetails (Key)
    {
        $('#con-StockItem').empty();
        $("#con-StockItem").load('/Inventory/Cards/StockItemDetails?Key=' + Key);
        $("#mod-StockItem").modal({ backdrop: 'static' }).modal('toggle');
    }
    function DeleteRow (Key, Display)
    {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure to delete CostCenter: ' + Display,
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Delete',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                        $.ajax({
                            type: "Delete",
                            url: "/api/inv/icards/DeleteStockItem",
                            data: { Key: Key },
                            dataType: "json",
                            success: function (response)
                            {
                                if (response == 0)
                                {
                                    $.alert({
                                        title: 'Stop',
                                        content: "Cannot delete CostCenter,It is have a child's",
                                    });
                                } else
                                {
                                    RefreshGrid();
                                }
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return;
                    }
                }
            }
        });
    }
    function ct4Disable (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case false:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case true:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ItemUnits (Key)
    {
        $('#con-StockUnits').empty();
        $("#con-StockUnits").load('/Inventory/Cards/StockUnits?Key=' + Key);
        $("#mod-StockUnits").modal({ backdrop: 'static' }).modal('toggle');
    }
    function ct4SUAction (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        if (e.itemData.icon == 'edit')
                        {
                            AddNewUnit(options.data.Key, options.data.Item);
                        }
                        break;
                }
            },
        });
    }
    function AddNewUnit (Key, Item)
    {
        $('#con-StockUnit').empty();
        $("#con-StockUnit").load('/Inventory/Cards/StockUnit?Key=' + Key + '&Item=' + Item);
        $("#mod-StockUnit").modal({ backdrop: 'static' }).modal('toggle');
    }

    function ct4EnablePkg (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case true:
                str = '<div class="text-center"><span class="badge bg-yellow text-dark">' + options.text + '</span></div>';
                break;
            case false:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function CodesBeforeSend (method, ajaxOptions)
    {
        ajaxOptions.data.xKey = key;
    }
</script>
