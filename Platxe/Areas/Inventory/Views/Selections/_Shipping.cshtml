@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iT.T(xLan,"2381","Shipping Stock")</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <div class="modal-body">
        <div>
            @(Html.DevExtreme().DataGrid<CLiInventory.Documents.Selections.Transfers>().ID("grd-Transfers")
                .ShowBorders(true).Width("100%")
                .DataSource(d => d.WebApi()
                .Controller("idocuments").Area("Inventory")
                .Key("OperationKey")
                .LoadAction("SelectTransfer").LoadParams(new { TargetWarehouse = ViewBag.TargetWarehouse }))
                .ColumnAutoWidth(true)
                .Columns(columns =>
                {
                    columns.Add().Name("act").Fixed(true).FixedPosition((HorizontalEdge)devFixd).Caption("Act.").Width(40).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("cta4Transfers"));
                    columns.AddFor(m => m.SourceWarehouse).Caption(iT.T(xLan, "2382", "Source Warehouse")).Lookup(L=>L.DataSource(CLiInventory.Selections.Warehouse.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display"));
                    columns.AddFor(m => m.InvoiceDate).Caption(iT.T(xLan, "1210", "Date")).Width(80).Format("dd.MM.yyyy");
                    columns.AddFor(m => m.InvoiceNo).Caption(iT.T(xLan, "1265", "No")).Width(70);
                    columns.AddFor(m => m.Quantity).Caption(iT.T(xLan, "2383", "Quantity")).Width(85).Format("0,###.##");
                    columns.AddFor(m => m.ClosedQty).Caption(iT.T(xLan, "2384", "Closed")).Width(85).Format("0,###.##");
                    columns.AddFor(m => m.RemQty).Caption(iT.T(xLan, "2385", "Rem.Quantity")).Width(85).Format("0,###.##");
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                    pg.InfoText("{0} of {1} | {2} Rows");
                })
                .Paging(p => { p.PageSize(50); })
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                })
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                .RowAlternationEnabled(true)
                .RtlEnabled(devRtl)
                )
        </div>
    </div>
    <div class="modal-footer">
        <div class="btn-group">
            <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1242","Close")</button>
        </div>
    </div>
</div>
