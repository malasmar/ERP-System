@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }

    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<h1 class="page-header">@iT.T(xLan,"2545","Stocktaking Offset")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="SelectionStocktaking()">@iT.T(xLan, "2546","Select Stocktaking")</button>
                    <button id="div-Offset" type="button" class="btn btn-danger btn-sm" onclick="UpdateStocktakingOffset()">@iT.T(xLan,"2547","Offset Stocktaking")</button>
                    <button type="button" class="btn btn-dark btn-sm" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-lg-5">
                <div class="card border-0 mb-1 bg-yellow text-dark acc">
                    <div class="card-body">
                        <div class="text-truncate">
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>@iT.T(xLan, "1625","Warehouse")</td><td id="txt-Warehouse"></td></tr>
                                    <tr><td>@iT.T(xLan, "1210","Date")</td><td id="txt-Date"></td></tr>
                                    <tr><td>@iT.T(xLan, "1731","Person")</td><td id="txt-Person"></td></tr>
                                    <tr><td>@iT.T(xLan, "1880","Comment")</td><td id="txt-Comment"></td></tr>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
            <div class="col-lg-3">
                <div class="card border-0 mb-1 bg-gray text-dark acc">
                    <div class="card-body">
                        <div class="text-truncate">
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>@iT.T(xLan, "2548","Increase Qty")</td><td id="txt-IncreaseQty"></td></tr>
                                    <tr><td>@iT.T(xLan, "2549","Increase Value")</td><td id="txt-IncreaseValue"></td></tr>
                                    <tr><td>@iT.T(xLan, "2550","Deficiency Qty")</td><td id="txt-DeficiencyQty"></td></tr>
                                    <tr><td>@iT.T(xLan, "2551","Deficiency Value")</td><td id="txt-DeficiencyValue"></td></tr>

                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiInventory.Audit.StocktakingDetails>().ID("grd-StocktakingDetails")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("icore").Area("Auditing")
                    .Key("RecNo")
                    .LoadAction("StocktakingDetails")
                    .LoadParams(new
                    {
                        Key = new JS("getKey")
                    })
                    )
                    .FocusedRowEnabled(true)
                    .ColumnAutoWidth(true)
                    .Columns(columns =>
                    {
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(100);
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).MinWidth(200).CellTemplate(new JS("ctWordWrap"));
                        columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166", "English Name")).MinWidth(200).CellTemplate(new JS("ctWordWrap"));
                        columns.AddFor(m => m.Quantity).Caption(iT.T(xLan, "2552", "File Qty")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Balance).Caption(iT.T(xLan, "2553", "System Qty")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Difference).Caption(iT.T(xLan, "1217", "Difference")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.UnitCost).Caption(iT.T(xLan, "2468", "Unit Cost")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Cost).Caption(iT.T(xLan, "1576", "Cost")).Width(100).Format("0,###.##");

                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.Code).SummaryType(SummaryType.Count);
                            item.AddFor(m => m.Quantity).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Balance).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Difference).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Cost).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "2545", "Stocktaking Offset")))
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    )
            </div>
        </div>
    </div>
</div>
<div id="mod-Stocktaking" class="modal"><div class="modal-dialog modal-lg" id="con-Stocktaking"></div></div>


<script class="append-on-ajax-script">

    var key = null;

    function getKey ()
    {
        return key;
    }

    function RefreshGrid ()
    {

        $('#grd-StocktakingDetails').dxDataGrid("instance").refresh();

    }

    function SelectionStocktaking ()
    {
        $('#con-Stocktaking').empty();
        $("#con-Stocktaking").load('/Auditing/Inventory/Stocktaking');
        $("#mod-Stocktaking").modal({ backdrop: 'static' }).modal('toggle');
    }

    function cta4Stocktaking (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [ {
                icon: "selectall"
            } ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                key = options.data.Key;
                RefreshGrid();
                $('#txt-Warehouse').text(options.data.Warehouse);
                $('#txt-Date').text(options.data.Date);
                $('#txt-Person').text(options.data.Person);
                $('#txt-Comment').text(options.data.Comment);

                $('#txt-IncreaseQty').text(comma(options.data.IncreaseQty));
                $('#txt-DeficiencyQty').text(comma(options.data.DeficiencyQty));
                $('#txt-IncreaseValue').text(comma(options.data.IncreaseValue));
                $('#txt-DeficiencyValue').text(comma(options.data.DeficiencyValue));

                if (options.data.Status != 0)
                {
                    $('#div-Offset').prop('hidden', true);
                }
                $("#mod-Stocktaking").modal('toggle');
            },
        });
    }

    function UpdateStocktakingOffset ()
    {
        $.confirm({
            title: '<span class="f-s-10 text-grey">Confirm</span>',
            content: 'Are you sure to offset current stocktaking file?',
            buttons: {
                Delete: {
                    text: 'Offset',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                        $.ajax({
                            type: "post",
                            url: "/api/Auditing/icore/UpdateOpeningBalance",
                            data: { Key: key,Comment: $('#frm-Description').dxTextArea('option', 'value') },
                            dataType: "json",
                            success: function (response)
                            {
                                if (response == true)
                                {
                                    $('#div-Offset').prop('hidden', true);
                                }
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });

                    }
                },
                cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return
                    }
                }
            }
        });
    }
        function ct4Status (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
 
        }
        $(str).appendTo(container)
    }
</script>
