@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }

    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<h1 class="page-header">@iT.T(xLan,"2505","Warehouse Balance")<small class="me-1"> @iT.T(xLan,"2372","Base Warehouse")</small></h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-3 col-md-12">

                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "2507","Date")</label>
                    <div class="col-9">
                        @Html.DevExtreme().DateBox().ID("edFirstDate").Width(130).DisplayFormat("dd.MM.yyyy").Value(DateTime.Now)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "2374","Warehouse")</label>
                    <div class="col-9">
                        @Html.DevExtreme().Lookup().ID("edWarehouse").Width(300).DataSource(CLiInventory.Selections.Warehouse.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display")
                    </div>
                </div>
            </div>
            <div class="col-lg-4"></div>

        </div>
        <div class="row">
            <div class="col-12">
                <hr />
                <div class="btn-group">
                    <button type="button" class="btn btn-dark btn-sm" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                    <button type="button" class="btn btn-primary btn-sm" onclick="PrintReport()">@iT.T(xLan, "1361","Print Report")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiInventory.Reports.Balance.WarehouseBalance>().ID("grd-WarehouseBalance")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("ireports").Area("Inventory")
                    .Key("Key")
                    .LoadAction("WarehouseBalance")
                    .LoadParams(new
                    {
                        Warehouse = new JS("getWarehouse"),
                        Date = new JS("getFirst")
                       
                    })
                    )
                    .FocusedRowEnabled(true)
                    .ColumnAutoWidth(true)
                    .Columns(columns =>
                    {
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(100);
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).MinWidth(200).CellTemplate(new JS("ctWordWrap"));
                        columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166", "English Name")).MinWidth(200).CellTemplate(new JS("ctWordWrap")).Visible(false);
                        columns.AddFor(m => m.Unit).Caption(iT.T(xLan, "2379", "Unit")).Width(100);
                        columns.AddFor(m => m.Date).Caption(iT.T(xLan, "2509", "Cost Date")).Width(100).Format("dd.MM.yyyy");
                        columns.AddFor(m => m.Quantity).Caption(iT.T(xLan, "2464", "Quantity")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Cost).Caption(iT.T(xLan, "2468", "Unit Cost")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Amount).Caption(iT.T(xLan, "2466", "Amount")).Width(100).Format("0,###.##");
                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.Code).SummaryType(SummaryType.Count);
                            item.AddFor(m => m.Quantity).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Cost).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Amount).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .RowAlternationEnabled(true)
                    .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "2505", "Warehouse Balance")))
                    .RtlEnabled(devRtl)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    )
            </div>
        </div>
    </div>
</div>
<script class="append-on-ajax-script">

    function RefreshGrid ()
    {
        $('#grd-WarehouseBalance').dxDataGrid("instance").refresh();
    }

    function getFirst ()
    {
        var fd = new Date($('#edFirstDate').dxDateBox('option', 'value'));
        return fd.toLocaleDateString();
    }

    function getWarehouse ()
    {
        return $('#edWarehouse').dxLookup('option', 'value');
    }



    function PrintReport ()
    {
        window.open('/Print/Financial/WarehouseValue?Key=' + getWarehouse() + '&Date=' + getFirst());
    }

</script>
