@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}

<h1 class="page-header">@iT.T(xLan,"2325","Unposted Operation")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-3">
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan, "1222","Year")</label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="input-group">
                            @Html.DevExtreme().NumberBox().ID("num-Year").ShowSpinButtons(true).Width(90).Value(Year)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <hr />
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                    <button type="button" class="btn btn-danger btn-sm" onclick="ConfirmPost()">@iT.T(xLan, "2326","Post Selected Rows")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiFinancial.Operation.UnpostedVouchers>().ID("grd-UnpostedVouchers")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("icore").Area("Auditing")
                    .Key("Key")
                    .LoadAction("UnpostedVouchers").LoadParams(new { Year = new JS("GetYear") }))
                    .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption(iT.T(xLan, "", "#")).Width(100).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                        columns.AddFor(m => m.DocumentKind).Caption(iT.T(xLan, "1975", "DocumentKind")).Width(110).Lookup(L => L.DataSource(iReplacer.DocumentsName(xLan, true)).ValueExpr("Value").DisplayExpr("Display"));
                        columns.AddFor(m => m.VoucherDate).Caption(iT.T(xLan, "1210", "Date")).Width(100).Format("dd.MM.yyyy");
                        columns.AddFor(m => m.VoucherNo).Caption(iT.T(xLan, "1265", "No")).Width(80);
                        columns.AddFor(m => m.Description).Caption(iT.T(xLan, "1212", "Description")).Width("100%").MinWidth(180).CellTemplate(new JS("ct4Description"));
                        columns.AddFor(m => m.Subtotal).Caption(iT.T(xLan, "1347", "Subtotal")).Width(90).Format("0,###.##");
                        columns.AddFor(m => m.vatAmount).Caption(iT.T(xLan, "1345", "VAT")).Width(90).Format("0,###.##");
                        columns.AddFor(m => m.Total).Caption(iT.T(xLan, "1120", "Total")).Width(90).Format("0,###.##").CellTemplate(new JS("ctRedBold"));
                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.DocumentKind).SummaryType(SummaryType.Count);
                            item.AddFor(m => m.Subtotal).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.vatAmount).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Total).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    .Selection(s => s.Mode(SelectionMode.Multiple).ShowCheckBoxesMode(GridSelectionShowCheckBoxesMode.Always).AllowSelectAll(true).SelectAllMode(SelectAllMode.AllPages))
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    )
            </div>
        </div>
    </div>
</div>

<div id="mod-ProgressBar" class="modal">
    <div class="modal-dialog modal-lg" id="con-ProgressBar">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@iT.T(xLan,"2327","Post Transaction")</h4>
            </div>
            <div class="modal-body">
                <div class="row">
                    <div class="col-12">
                        <div class="p-2" id="div-Progress">
                            <div class="text-center">
                                <p class="f-s-11 text-dark mb-0 pb-0">Post Transaction <small> Please Wait</small></p>
                                <p class="f-s-10 text-red mt-1 pt-1" id="txtInfo">@iT.T(xLan, "2328","Please Wait")</p>
                            </div>
                            <div id="progress">
                                @(Html.DevExtreme().ProgressBar().ID("progressBarStatus").Min(0).Width("100%"))
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script class="append-on-ajax-script">
    function ct4Action (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: "edit" },
                { icon: "print" },
                { icon: "tips" } ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        if (e.itemData.icon == 'edit')
                        {
                            switch (options.data.DocumentKind)
                            {
                                case 3:
                                case 4:
                                case 5:
                                case 6:
                                case 7:
                                case 8:
                                    window.open('/Financial/Documents/Transaction?DocumentKind=' + options.data.DocumentKind + '&Key=' + options.data.Key);
                                    break;
                                case 9:
                                    window.open('/Financial/Documents/JournalVoucher?DocumentKind=' + options.data.DocumentKind + '&Key=' + options.data.Key);
                                    break;
                                case 80:
                                    window.open('/Sales/Documents/SalesInvoice?Key=' + options.data.Key);
                                    break;
                                case 83:
                                    window.open('/Sales/Documents/ReturnInvoice?Key=' + options.data.Key);
                                    break;
                                case 71:
                                    window.open('/Purchasing/Documents/PurchaseInvoice?Key=' + options.data.Key);
                                    break;
                                case 75:
                                    window.open('/Purchasing/Documents/ReturnInvoice?Key=' + options.data.Key);
                                    break;
                                case 77:
                                    window.open('/Inventory/Documents/Consumption?Key=' + options.data.Key);
                                    break;
                                case 78:
                                    window.open('/Inventory/Documents/ConsumptionReturn?Key=' + options.data.Key);
                                    break;

                                    break;
                                default:
                                    window.open('/Financial/Documents/Transaction?DocumentKind=' + options.data.DocumentKind + '&Key=' + options.data.Key);
                                    break;
                            }
                        }
                        break;
                    case 1:
                        if (e.itemData.icon == 'trash')
                        {
                            DeleteRow(options.data.Key, options.data.Name1);
                        }
                        if (e.itemData.icon == 'print')
                        {
                            FinancialPrintTemplates(options.data.DocumentKind, options.data.Key);
                        }

                        break;
                    case 2:
                        if (e.itemData.icon == 'tips')
                        {
                            ViewJournalVoucher(options.data.Key);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid ()
    {
        $('#grd-UnpostedVouchers').dxDataGrid("instance").refresh();
    }
    function GetYear ()
    {
        return $('#num-Year').dxNumberBox('option', 'value');
    }
    function ct4Posted (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case true:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case false:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ct4Status (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
            case 2:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
            case 3:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ct4Description (container, options)
    {
        var str = '';
        str = '<p class="m-0 p-0 f-s-10" style="white-space:normal;">' + options.value + '</p>';
        $(str).appendTo(container)
    }



    function ConfirmPost ()
    {
        var srcount = $('#grd-UnpostedVouchers').dxDataGrid("instance").getSelectedRowKeys().length;
        if (srcount == 0)
        {
            return
        }
        $.confirm({
            title: 'Confirmation',
            content: 'Post Selected Vouchers?',
            buttons: {
                Delete: {
                    text: 'Post Voucher',
                    action: function ()
                    {
                        PostTransaction()
                    }
                },
                cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return
                    }
                }
            }
        })
    }

    var ic = 0;
    var data;
    function PostTransaction ()
    {
        data = $("#grd-UnpostedVouchers").dxDataGrid("instance").getSelectedRowsData();
        ic = data.length - 1;
        $("#progressBarStatus").dxProgressBar("option", "max", data.length);
        $("#mod-ProgressBar").modal({ backdrop: 'static' }).modal('toggle');
        PostTransactionRow(0);
    }
    function PostTransactionRow (i)
    {
        $('#txtInfo').text('Working on Invoice ' + data[ i ].VoucherNo + ' the (row ' + i.toString() + ' of ' + ic.toString() + ') ');
        $("#progressBarStatus").dxProgressBar("option", "value", i + 1);
        $.ajax({
            type: "Post",
            url: "/api/Auditing/icore/PostVoucher",
            data: { Key: data[ i ].Key },
            dataType: "json",
            success: function (response)
            {
                if (i < ic)
                {
                    ++i;
                    PostTransactionRow(i);
                }
                if (i == ic)
                {
                    $("#mod-ProgressBar").modal('hide');
                    RefreshGrid();
                }
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
</script>
