@model CLiCore.Platx.Whatsapp
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="row justify-content-center">
    <div class="col-lg-6 col-md-12">
        <h1 class="page-header">@iT.T(xLan,"2742","Whatsapp Settings")</h1>
        <div class="panel panel-inverse">

            <div class="panel-body">

                <div class="note note-warning note-with-end-icon mb-3 mr-2 ml-2">
                    <div class="note-icon"><i class="fa fa-ban"></i></div>
                    <div class="note-content text-start">
                        <h4><b>Payment Service!</b></h4>
                        <p>
                            Whatsapp Service need to payment additional fees,Your <b>subscribe </b> not support this service
                            <br />
                            <b>Whatsapp </b> service need also third party subscribe
                        </p>
                    </div>
                </div>

                <form id="frm-Whatsapp" data-parsley-validate="true">
                    <div><small>@iT.T(xLan, "2742","Whatsapp Settings")</small></div>
                    <div class="form-group row">
                        <label class="col-lg-4 col-sm-12">@iT.T(xLan, "2743","API URL")</label>
                        <div class="col-lg-8 col-sm-12">
                            @Html.DevExtreme().TextBoxFor(m => m.APIURL).Width(300)
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-4 col-sm-12">@iT.T(xLan, "2744","Instance ID")</label>
                        <div class="col-lg-8 col-sm-12">
                            @Html.DevExtreme().TextBoxFor(m => m.InstanceID).Width(300)
                        </div>
                    </div>
                    <div class="form-group row">
                        <label class="col-lg-4 col-sm-12">@iT.T(xLan, "2745","Token")</label>
                        <div class="col-lg-8 col-sm-12">
                            @Html.DevExtreme().TextBoxFor(m => m.Token).Width(300)
                        </div>
                    </div>
                    <hr class="m-2 p-0" />
                    <div class="form-group row">
                        <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1282","Status")</label>
                        <div class="col-lg-8 col-sm-12">
                            @Html.DevExtreme().SwitchFor(m => m.Status).ID("cnt-Disable").Width(65).SwitchedOffText(iT.T(xLan,"1304","Disable")).SwitchedOnText(iT.T(xLan,"1305","Active"))
                        </div>
                    </div>
                    <div class="me-4 p-3">
                        <button class="btn btn-danger">@iT.T(xLan,"1772","Save Changed")</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function ()
    {
        $("#frm-Whatsapp").submit(function (event)
        {
            event.preventDefault();
            UpdateDefault();
        });
    });
    function UpdateDefault ()
    {
        $.confirm({
            title: 'Confirm!',
            content: 'Are you sure to update Whatsapp settings?',
            buttons: {
                Update: function ()
                {
                    var data = $('#frm-Whatsapp').serialize();
                    $.ajax({
                        type: "POST",
                        url: "/api/Manager/icore/UpdateWhatsapp",
                        data: data,
                        dataType: "json",
                        success: function (response)
                        {
                            $.alert({
                                title: 'Info',
                                content: 'Operation Complete',
                            });
                        },
                        failure: function (response)
                        {
                            alert(response);
                        },
                        error: function (response)
                        {
                            alert(response.responseText);
                        }
                    });
                },
                cancel: function ()
                {
                    return;
                }
            }
        });
    }

</script>
