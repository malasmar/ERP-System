@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    Guid Subscribe = Guid.Parse(User.FindFirstValue("aiwSubscribe"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<h1 class="page-header">@iT.T(xLan,"1673","Users")</h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-12">
                <div class="btn-group">
                    <button type="button" class="btn btn-dark" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                    <button type="button" class="btn btn-yellow text-dark" onclick="GetDetails(null)">@iT.T(xLan, "1670","Create New User")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiCore.Platx.Users>().ID("grd-Users")
                .ShowBorders(true).Width("100%")
                .DataSource(d => d.WebApi()
                    .Controller("icore").Area("Manager")
                .Key("Key")
                .LoadAction("Users"))
                .ColumnAutoWidth(true)
                    .FocusedRowEnabled(true)
                .Columns(columns =>
                {
                columns.Add().Name("act").Caption(iT.T(xLan,  "","#")).Width(70).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "1158","Kind")).Width(75).Lookup(L=>L.DataSource(iReplacer.UserKind(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Kind"));
                columns.AddFor(m => m.No).Caption(iT.T(xLan, "1265","No")).Width(80);
                columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165","Account Name"));
                columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166","English Name"));
                columns.AddFor(m => m.Email).Caption(iT.T(xLan, "1303","Email"));
                columns.AddFor(m => m.Phone).Caption(iT.T(xLan, "1190","Phone"));
                columns.AddFor(m => m.DataBase).Caption(iT.T(xLan, "1671","DataBase")).Lookup(L=>L.DataSource(CLiCore.Account.Selections.Database.GetData(xLan,Subscribe)).ValueExpr("Key").DisplayExpr("Display"));
                columns.AddFor(m => m.CreateDate).Caption(iT.T(xLan, "1575","Create Date")).Width(90).Format("dd.MM.yyyy");
                columns.AddFor(m => m.UpdateDate).Caption(iT.T(xLan, "1672","Update Date")).Width(90).Format("dd.MM.yyyy");
                })
                .Pager(pg =>
                {
                pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                pg.ShowNavigationButtons(true);
                pg.ShowPageSizeSelector(true);
                pg.ShowInfo(true);
                pg.InfoText("{0} of {1} | {2} Rows");
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                sp.Width(250);
                sp.Visible(true);
                })
                .RowAlternationEnabled(true)
                .RtlEnabled(devRtl)
                )
            </div>
        </div>
    </div>
</div>
<div id="mod-User" class="modal"><div class="modal-dialog" id="con-User"></div></div>
<script class="append-on-ajax-script">
    function ct4Action(container, options) {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' },
                { icon: 'trash' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function(e) {
                switch (e.itemIndex) {
                    case 0:
                        if (e.itemData.icon == 'edit') {
                            GetDetails(options.data.Key);
                        }
                        break;
                    case 1:
                        if (e.itemData.icon == 'trash') {
                            DeleteRow(options.data.Key, options.data.Name1);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid() {
        $('#grd-Users').dxDataGrid("instance").refresh();
    }
    function GetDetails(Key) {
        $('#con-User').empty();
        $("#con-User").load('/Manager/Users/UserDetails?Key=' + Key);
        $("#mod-User").modal({ backdrop: 'static' }).modal('toggle');
    }
    function DeleteRow(Key, Display) {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure to disable user: ' + Display,
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Delete',
                    btnClass: 'btn-red',
                    action: function() {
                        $.ajax({
                            type: "Delete",
                            url: "/api/Manager/icore/DeleteUser",
                            data: { Key: Key },
                            dataType: "json",
                            success: function(response) {
                                if (response == 0) {
                                    $.alert({
                                        title: 'Stop',
                                        content: "Cannot disable user,It is have a child's",
                                    });
                                } else {
                                    RefreshGrid();
                                }
                            },
                            failure: function(response) {
                                alert(response);
                            },
                            error: function(response) {
                                alert(response.responseText);
                            }
                        });
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function() {
                        return;
                    }
                }
            }
        });
    }
    function ct4Kind(container, options) {
        var str = '';
        switch (options.value) {
            case 0:
                str = '<div class="text-center"><span class="badge bg-yellow text-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function cta4PaymentMethods(container, options) {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' },
                { icon: 'trash' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function(e) {
                switch (e.itemIndex) {
                    case 0:
                        if (e.itemData.icon == 'edit') {
                            $('#con-Paymentmethod').empty();
                            $("#con-Paymentmethod").load('/Manager/Users/PaymentMethodDetails?Key=' + options.data.Key);
                            $("#mod-Paymentmethod").modal({ backdrop: 'static' }).modal('toggle');
                        }
                        break;
                    case 1:
                        if (e.itemData.icon == 'trash') {
                            DeleteRow(options.data.Key, options.data.Name1);
                        }
                        break;
                }
            },
        });
    }
</script>
