    function ChangefrmAccountKind (e)
    {
        $("#frm-AccountKey").dxLookup({
            dataSource: '/api/icore/LoadAccounts?Kind=' + e.value
        });
        $('#frm-AccountKey').dxLookup('reset');
    }
    //Start Operation
    var inChangeItemKind = 0;
    function ChangeItemKind (e)
    {
        if (inChangeItemKind == 1)
            return;
        inChangeItemKind = 1;
        $("#row-Account").dxLookup({
            dataSource: '/api/icore/LoadAccounts?Kind=' + e.value
        });
        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup("getDataSource").load().done(function ()
        {
            if (rowCurrentItemKey != null)
            {
                $('#row-Account').dxLookup('option', 'value', rowCurrentItemKey);
            }
        });
        inChangeItemKind = 0;
    }
    //End Start Operation
    //Stock
    function SelectedItemChanged (e)
    {
        var acckind = $('#row-ItemKind').dxSelectBox('option', 'value');
        switch (acckind)
        {
            case 8:
                $("#row-Unit").dxSelectBox("reset");
                $("#row-Unit").dxSelectBox({
                    dataSource: '/api/inv/icore/ItemUnits?Key=' + e.value
                });
                $("#row-Unit").dxSelectBox("getDataSource").load().done(function (data)
                {
                    if (data.length > 0)
                    {
                        $("#row-Unit").dxSelectBox("option", "value", data[ 0 ].Code);
                    }
                });
                $.ajax({
                    type: "get",
                    url: "/api/inv/icore/InvoiceItemDetails",
                    data: { Key: e.value },
                    dataType: "json",
                    success: function (response)
                    {
                        RowItemDetails = response;
                        $('#div-Batch').prop('hidden', response.EnableBatch == false ? true : false);
                        $('#div-Color').prop('hidden', response.EnableColor == false ? true : false);
                        $('#div-Size').prop('hidden', response.EnableSize == false ? true : false);
                        if (response.EnableBatch == true)
                        {
                            $('#row-PartPrice').dxNumberBox('option', 'value', response.PartPrice);
                            $('#row-PartRate').dxNumberBox('option', 'value', response.PartRate);
                        }
                        if (response.vatKey == null)
                        {
                            var selectedvat = $("#row-vatKey").dxSelectBox('instance');
                            selectedvat.getDataSource().load().done(function (res)
                            {
                                $('#row-vatKey').dxSelectBox('option', 'value', res[ 0 ].Key);
                            });
                        } else
                        {
                            $('#row-vatKey').dxSelectBox('option', 'value', response.vatKey);
                        }
                    },
                    failure: function (response)
                    {
                        alert(response);
                    },
                    error: function (response)
                    {
                        alert(response.responseText);
                    }
                });
                break;
            default:
                $('#div-Batch').prop('hidden', true);
                $('#div-Color').prop('hidden', true);
                $('#div-Size').prop('hidden', true);
                break;
        }
    }
    function EditAmount ()
    {
        //if (IsLoading == 1)
        //    return;
        var selectedvat = $("#row-vatKey").dxSelectBox('instance').option('selectedItem');
        var vatRate = 0;
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var UnitPrice = $('#row-UnitPrice').dxNumberBox('option', 'value');
        var Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Numbert(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        var Total = 0;
        Total = Number(Number((Amount - Discount) + vatAmount).toFixed(4));
        //$("#edADis").dxNumberBox("option", "value", Number(Number(discount).toFixed(4)));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Amount.toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(vatAmount.toFixed(4)));
        $('#row-Total').dxNumberBox('option', 'value', Number(Total.toFixed(4)));
    }
    function RefelectAmount ()
    {
        var vatRate = 0;
        var selectedvat = $('#row-vatKey').dxSelectBox('instance').option('selectedItem');
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var Quantity = 0;
        var Total = 0;
        var UnitPrice = 0;
        Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        Total = $('#row-Total').dxNumberBox('option', 'value');
        UnitPrice = ((100 * Total) / Quantity) / (100 + vatRate);
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Number(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        $('#row-UnitPrice').dxNumberBox('option', 'value', Number(Number(UnitPrice).toFixed(4)));
        $('#row-Discount').dxNumberBox('option', 'value', Number(Number(Discount).toFixed(4)));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Number(Amount).toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(Number(vatAmount).toFixed(4)));
    }
