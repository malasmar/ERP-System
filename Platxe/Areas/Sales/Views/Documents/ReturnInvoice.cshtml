    function cta4SalesInvoice (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [ {
                icon: "selectall"
            } ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                $('#frm-SourceInvoice').dxTextBox('option','value',options.data.InvoiceNo);
                $('#OriginalInvoice').val(options.data.OperationKey);
                $('#frm-ReferenceNo').dxTextBox('option', 'value', options.data.InvoiceNo);
                $('#frm-AccountKind').dxSelectBox('option', 'value', options.data.AccountKind);
                $('#frm-AccountKey').dxLookup('option', 'value', options.data.AccountKey);
                $('#frm-CurrentKey').dxLookup('option', 'value', options.data.CurrentKey);
                $('#frm-Currency').dxSelectBox('option', 'value', options.data.Currency);
                $('#frm-SourceWarehouse').dxSelectBox('option', 'value', options.data.SourceWarehouse);
                $('#frm-SalesPerson').dxSelectBox('option', 'value', options.data.SalesPerson);
                $("#mod-Invoices").modal('toggle');
            },
        });
    }
    function ReturnAllInvoice ()
    {
        if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
        {
            alert('Please select source invoice!');
            return;
        }
        LoadSourceData($('#OriginalInvoice').val());
    }
    function cta4InvoiceDetails (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [ {
                icon: "selectall"
            } ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                rowCurrentItemKey = options.data.ItemKey;
                CloseRowKey = options.data.Key;
                RowUnitCost = options.data.UnitCost;
                $('#row-ItemKind').dxSelectBox('option', 'value', options.data.ItemKind);
                $('#row-Account').dxLookup('option', 'value', options.data.ItemKey);
                $('#row-Unit').dxSelectBox('option', 'value', options.data.Unit);
                $('#row-ExpDate').dxDateBox('option', 'value', options.data.ExpDate);
                $('#row-Color').dxSelectBox('option', 'value', options.data.Color);
                $('#row-Size').dxSelectBox('option', 'value', options.data.Size);
                $('#row-Quantity').dxNumberBox('option', 'value', options.data.Quantity);
                $('#row-Bonus').dxNumberBox('option', 'value', options.data.Bonus);
                $('#row-UnitPrice').dxNumberBox('option', 'value', options.data.UnitPrice);
                $('#row-Amount').dxNumberBox('option', 'value', options.data.Amount);
                $('#row-Discount').dxNumberBox('option', 'value', options.data.Discount);
                $('#row-vatKey').dxSelectBox('option', 'value', options.data.vatKey);
                $('#row-vatAmount').dxNumberBox('option', 'value', options.data.vatAmount);
                $('#row-Total').dxNumberBox('option', 'value', options.data.Total);
                $('#row-CostCenter').dxLookup('option', 'value', options.data.CostCenter);
                $('#row-Project').dxLookup('option', 'value', options.data.Project);
                $('#row-vatKey').dxSelectBox('option', 'readOnly', true);
                $('#row-Total').dxNumberBox('option', 'readOnly', true);
                $('#row-Bonus').dxNumberBox('option', 'readOnly', true);
                if (options.data.ItemKind == 8)
                {
                    $('#row-Unit').dxSelectBox('option', 'readOnly', true);
                    $('#row-UnitPrice').dxNumberBox('option', 'readOnly', true);
                    $('#row-Discount').dxNumberBox('option', 'readOnly', true);
                }
                EditAmount();
                $("#mod-InvoiceItems").modal('toggle');
            },
        });
    }
    function SearchInvoiceItem ()
    {
        if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
        {
            alert('Please select source invoice!');
            return;
        }
        $('#con-InvoiceItems').empty();
        $("#con-InvoiceItems").load('/Sales/Selections/InvoiceDetails?Key=' + $('#OriginalInvoice').val());
        $("#mod-InvoiceItems").modal({ backdrop: 'static' }).modal('toggle');
    }

