    function SaveAdvancePayments ()
    {
        AdvancePayments = [];
        AdvancePayments.splice(0, AdvancePayments.length);
        var amount = 0;
        var clsRows = 0;
        var grdAgesInvoices = $('#grd-AdvancePayments').dxDataGrid("instance");
        grdAgesInvoices.selectRows(grdAgesInvoices.getSelectedRowKeys(), true).done(function ()
        {
            grdAgesInvoices.saveEditData().done(function ()
            {
                var selectedRowsData = grdAgesInvoices.getSelectedRowsData();
                for (const item of selectedRowsData)
                {
                    if (item.xAmount > 0)
                    {
                        AdvancePayments.push({
                            Key: item.RowKey,
                            OperationKey: item.OperationKey,
                            Amount: item.xAmount
                        });
                        amount += item.xAmount;
                        clsRows += 1;
                    }
                }
            });
        })
        $('#txt-AdvancePayments').text(comma(amount));
        $("#mod-AdvancePayments").modal('toggle');
    }
