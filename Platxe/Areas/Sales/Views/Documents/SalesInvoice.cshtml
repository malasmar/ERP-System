@model CLiInventory.Documents.Transaction
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    string Currency = CLiCore.VoucherOperation.DefaultCurrency(DB);

    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
    //CLiCore.Shared.UserDefaultData defaultData = CLiCore.Shared.UserDefaultData.GetItem(UserKey);

    bool ClosePrefix = xConfig.UserPrefixFilter(UserKey);


    string ExpiryHidden = "hidden";
    if (xConfig.ExpiryDateStatus(DB) == true)
    {
        ExpiryHidden = "";
    }
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }

    .xd > tr:hover {
        cursor: pointer;
    }
         .xd .ccp {
        display: block !important;
    }
    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }

    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }

    .width-20 {
        width: 20px !important;
        min-width: 20px !important;
    }

    .table-sm .xprince > * {
        padding: 0.1rem 0.1rem !important;
    }

</style>
<div class="invoice">
    <div class="invoice-company">
        <div class="float-end hidden-print">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
        <div class="float-end hidden-print me-1">
            <div class="btn-group">
                <button type="button" class="btn btn-gray mb-10px" onclick="ViewGeneralLedger('@Model.OperationKey')">GL</button>
            </div>
        </div>
        <div class="shl-invoice-header">
            @CLiCore.iCore.DocumentsName(xLan,Model.DocumentKind) <span id="inf-Status" class="badge bg-info text-dark"><small class="f-s-9 me-1">@iT.T(xLan,"2141","Status")</small><span id="txt-Status" class="me-1">Update</span></span><span id="txt-VoucherNo" class="text-danger"># @Model.InvoiceNo </span><small class="f-s-11 me-1">@iT.T(xLan,"2140","Monthly No")<span id="txt-MonthlyNo"> @Model.MonthlyNo</span></small>

            @{
                if (Model.OperationKey != null)
                {
                    <p class="f-s-10 mt-1"><i class="fa fa-exclamation-circle text-danger"></i> @iT.T(xLan,"2230","Not allowed to edit invoice").</p>
                }
            }
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
        </div>
    </div>
    <form id="frm-Voucher">
        @Html.HiddenFor(m=>m.DocumentKind)
        @Html.HiddenFor(m=>m.OperationKey)
        @Html.HiddenFor(m=>m.InvoiceNo)
        @Html.HiddenFor(m=>m.MonthlyNo)
        @Html.HiddenFor(m=>m.CreateUser)
        @Html.HiddenFor(m=>m.CreateDate)
        @Html.HiddenFor(m=>m.OriginalInvoice)
        <div class="invoice-header">
            <div class="invoice-from">
                <div class="row">
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1624","Invoice Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().DateBoxFor(m => m.InvoiceDate).ID("frm-InvoiceDate").Width(125).DisplayFormat("dd.MM.yyyy").Min(new DateTime(xYear,1,1)).Max(DateTime.UtcNow.AddMinutes(180)).OnValueChanged("GetMonthlyNo")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1992","AccountKind")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.AccountKind).ID("frm-AccountKind").Width(125).DataSourceOptions(o=>o.Paginate(true).PageSize(50)).DataSource(iReplacer.finTransactionAccByDocument(xLan,Model.DocumentKind)).ValueExpr("Value").DisplayExpr("Display").OnValueChanged("ChangefrmAccountKind")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1219","Account")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.AccountKey).ID("frm-AccountKey").DataSourceOptions(o=>o.Paginate(true).PageSize(50)).DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, Model.AccountKind,UserKey:UserKey)).ValueExpr("Key").DisplayExpr("Display").OnValueChanged("ChangeAccountKey")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1355","Client")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().LookupFor(m => m.CurrentKey).ID("frm-CurrentKey").Width("88%").DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, PLenums.TransactionAccount.CurrentAccount, PLenums.CurrentAccountKind.Client)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true).OnValueChanged("ChangeCurrentAccount")
                                    <button id="btn-frmAdd" type="button" class="btn btn-white f-s-10" onclick="AddfrmCurrent()" style="max-width:35px"><i class="fas fa-plus"></i></button>
                                    <button hidden id="btn-frmEdit" type="button" class="btn btn-white f-s-10" onclick="AddfrmCurrent()" style="max-width:35px"><i class="fas fa-pen"></i></button>
                                </div>
                                <div class="me-2 mt-1">
                                    <small class="bg-purple-transparent-2">@iT.T(xLan, "1227","Balance") <span id="txtMainAccountBalance">0.00</span></small>
                                </div>
                                <div class="alert  alert-yellow  m-1 p-1  ">
                                    Integration Payments: <b id="txt-AdvancePayments">0.00</b> <a href="javascript:;" class="alert-link" onclick="ShowSelectAdvancePayments()">Select Payments</a>
                                    @*<small>You can select advance payment only</small>*@
                                </div>
                            </div>
                        </div>
                        
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1212","Description")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextAreaFor(m => m.Description).ID("frm-Description").Height(60)
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1152","Quotation")</label>
                            <div class="col-lg-8 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBoxFor(m=>m.Quotation).ID("frm-Quotation").Width(125).ReadOnly(true)
                                    <button type="button" class="btn btn-white f-s-10" style="max-width:35px" onclick="ShowSelectQuotations()"><i class="fas fa-search"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1744","Proforma")</label>
                            <div class="col-lg-8 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBoxFor(m=>m.Proforma).ID("frm-Proforma").Width(125).ReadOnly(true)
                                    <button type="button" class="btn btn-white f-s-10" style="max-width:35px" onclick="ShowSelectProforma()"><i class="fas fa-search"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1498","Contract")</label>
                            <div class="col-lg-8 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBoxFor(m=>m.Contract).ID("frm-Contract").Width(125).ReadOnly(true)
                                    <button type="button" class="btn btn-white f-s-10" style="max-width:35px" onclick="ShowSelectContracts()"><i class="fas fa-search"></i></button>
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1625","Warehouse")</label>
                            <div class="col-lg-8 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SourceWarehouse).ID("frm-SourceWarehouse").DataSource(CLiInventory.Selections.Warehouse.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1373","Due Date")</label>
                            <div class="col-lg-8 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBox().ID("frm-DueDays").Width(65).OnValueChanged("ChangeDueDays").ShowSpinButtons(true)
                                    @Html.DevExtreme().DateBoxFor(m => m.DueDate).ID("frm-DueDate").Width(110).DisplayFormat("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1220","Project")</label>
                            <div class="col-lg-8 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.Project).ID("frm-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-4 col-sm-12">@iT.T(xLan,"1332","Cst.Center")</label>
                            <div class="col-lg-8 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.CostCenter).ID("frm-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1636","Invoice No")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.ReferenceNo).ID("frm-ReferenceNo").Width(110)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1344","Currency")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Currency).ID("frm-Currency").Width(110).DataSource(CLiFinancial.Selections.Currency.GetList(DB)).ValueExpr("Code").DisplayExpr("Code").Value(Currency)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1728","Importation")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.InvoiceKind).ID("frm-InvoiceKind").Width(110).DataSource(iReplacer.invImportationInvoice(xLan)).ValueExpr("Value").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row" hidden>
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1729","Imp. File")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.ImportationKey).ID("frm-ImportationKey").ValueExpr("Value").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1328","Prefix")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Prefix).ID("frm-Prefix").DataSource(CLiFinancial.Selections.Prefix.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").ReadOnly(ClosePrefix)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1731","Person")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SalesPerson).ID("frm-SalesPerson").DataSource(CLiHR.Selections.Employees.GetList(DB,xLan,2)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1287","Source")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SalesHand).ID("frm-SalesHand").ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-2">
                                    <b class="mb-1">Invoice Total</b>
                                </div>
                                <div class="d-flex align-items-center mb-1">
                                    <h2 class="mb-0"><span>@Model.Total.ToString("n2")</span></h2>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1347","Subtotal")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.SubTotal.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2153","Discount")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Discount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2146","VAT")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.vatAmount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-1">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1120","Total")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Total.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="mb-2 mt-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2155","Create User")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10"><span>@Model.CreateUserInfo.Display</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2156","Create Date")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10" style="direction:ltr">@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy hh:mm tt") : "")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="invoice-content mt-3">
            <div class="sticky">
                <button type="button" id="btn-add" class="btn btn-yellow btn-sm text-dark" onclick="AddNewRow()">@iT.T(xLan,"1214","Add New Row")</button>
                <button hidden type="button" id="btn-add" class="btn btn-yellow btn-sm text-dark" onclick="AddNewSubscribe()">@iT.T(xLan,"2516","Add Subscribe")</button>
                <button hidden type="button" id="btn-InvoicedQuotation" class="btn btn-danger btn-sm" onclick="LoadIntegrationDetails()">@iT.T(xLan,"1745","Invoices All Items")</button>
                <button type="button" id="btn-CopyInvoice" class="btn btn-white btn-sm" onclick="ShowCopyInvoice()" title="@iT.T(xLan,"2231","Copy from previous invoice")"><i class="fa fa-clone"></i></button>
            </div>
            <div class="table-responsive">
                <table class="table table-invoice table-hover">
                    <thead>
                        <tr>
                            <th style="width:100px;max-width:100px">@iT.T(xLan,"1215","Actions")</th>
                            <th style="width:65px;min-width:65px;max-width:65px">@iT.T(xLan,"1158","Kind")</th>
                            <th style="width:100px;min-width:100px;max-width:120px">@iT.T(xLan,"1164","Code")</th>
                            <th style="width:100%;min-width:150px">@iT.T(xLan,"1586","Item Name")</th>
                            <th @ExpiryHidden style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1628","Expiry")</th>
                            <th style="width:120px;min-width:120px;max-width:120px">@iT.T(xLan,"1076","Quantity")</th>
                            <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1639","Bonus")</th>
                            <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1629","Unit Price") </th>
                            <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>
                            <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1097","Discount")</th>
                            @*  <th style="width:80px;min-width:80px;max-width:80px"><small class="f-s-9">@iT.T(xLan,"1345","VAT")</small> @iT.T(xLan,"1346","Rate")</th>*@
                            <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1345","VAT")</th>
                            <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1120","Total")</th>
                        </tr>
                    </thead>
                    <tbody class="xd" id="tb-rows">
                    </tbody>
                </table>
            </div>
          
                <div class="row p-2 me-2" style="background-color:#f4f4f4">
                    <div class="col-6">
                          <div class="invoice-price">
                        <table class="table-sm">
                            <thead>
                                <tr>
                                    <th style="width:100%;min-width:130px"></th>
                                    <th style="width:auto"></th>
                                </tr>
                            </thead>
                            <tbody class="f-s-12 f-w-600" style="padding:0.15rem 0.15rem;">
                                 <tr><td>@iT.T(xLan,"","Quantity")</td><td><span id="txt-Quantity">0.00</span></td></tr>
                                <tr><td>@iT.T(xLan,"1347","Subtotal")</td><td><span id="txt-Amount">0.00</span></td></tr>
                                <tr><td>@iT.T(xLan,"2153","Discount")</td><td><span id="txt-Discount">0.00</span></td></tr>
                                <tr><td>@iT.T(xLan,"1350","VAT Amount")</td><td><span id="txt-vatAmount">0.00</span></td></tr>
                                <tr><td>@iT.T(xLan,"2517","Retention Less")</td><td>@Html.DevExtreme().NumberBoxFor(m=>m.RetentionLess).ID("frm-RetentionLess").ShowSpinButtons(true).Width(125).Min(0).Format("0,###.##").OnValueChanged("CalcAmount") </td></tr>
                                <tr><td>@iT.T(xLan,"2518","Payment Discount")</td><td>@Html.DevExtreme().NumberBoxFor(m=>m.PaymentDiscount).ID("frm-PaymentDiscount").ShowSpinButtons(true).Width(125).Min(0).Format("0,###.##").OnValueChanged("CalcAmount") </td></tr>
                                <tr><td>@iT.T(xLan,"1120","Total")</td><td><span id="txt-Total">0.00</span></td></tr>
                            </tbody>
                        </table>
                   </div>
                   
                    </div>

                           <div class="col-6">
                               @{
                                   if(Model.OperationKey!=null){
                                <div class="float-end" id="qrcode"></div>
                                   }
                               }
                           
                        </div>
                </div>
         
        </div>
    </form>

    <div class="invoice-note">
        <hr>
        <div class="text-left">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
    </div>
</div>
<div id="mod-Row" class="modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@iT.T(xLan,"1218","Row Details")</h4>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1333","Account Kind")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-ItemKind").DataSource(iReplacer.invSalesItems(xLan)).ValueExpr("Value").DisplayExpr("Display").Width(150).Value(8).OnValueChanged("ChangeItemKind")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"","Item/Account")</label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="input-group">
                            @Html.DevExtreme().Lookup().ID("row-Account").DataSourceOptions(x=>x.Paginate(true).PageSize(50)).ValueExpr("Key").DisplayExpr("Display").Width("90%").ShowClearButton(true).OnValueChanged("SelectedItemChanged")
                            <button hidden id="btn-rowSearch" type="button" class="btn btn-white f-s-10" onclick="SearchCloseingDetails()" style="max-width:35px"><i class="fas fa-search"></i></button>
