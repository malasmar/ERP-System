       function getDescriptionStyle (xx)
    {
        if (xx.length == 0)
        {
            return '';
        }
        if (xx.length > 0 && xx.length < 250)
        {
            return 'height:65px;';
        }
        if (xx.length > 500)
        {
            return 'height:75px;';
        }
    }
         function getDescriptionCaption (xx)
    {
        if (xx.length == 0)
        {
            return '';
        }  else{
               return 'Description:';
        }
    }
