    function CalcAmount ()
    {
        var amount = 0;
        var vat = 0;
        var total = 0;
        var qty=0;
        $('#tb-rows').find('tr').each(function ()
        {
            amount += $(this).find('[id="td-Amount"]').data('value');
            vat += $(this).find('[id="td-vatAmount"]').data('value');
            total += $(this).find('[id="td-Total"]').data('value');
              qty += $(this).find('[id="td-Quantity"]').data('value');
        });
        $('#txt-Quantity').text(comma(qty));
        $('#txt-Amount').text(comma(amount));
        $('#txt-vatAmount').text(comma(vat));
        var Retention = 0;
        var PaymentDiscount = 0;
        Retention = $('#frm-RetentionLess').dxNumberBox('option', 'value');
        PaymentDiscount = $('#frm-PaymentDiscount').dxNumberBox('option', 'value');

        $('#txt-Total').text(comma(total - Retention - PaymentDiscount));
        $('#txt-xTotal').text(comma(total - Retention - PaymentDiscount));


    }
