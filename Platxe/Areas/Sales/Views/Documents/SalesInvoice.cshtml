<script class="append-on-ajax-script">
    var clcDebitCredit = 0;
    var isNewRow;
    var currentRow;
    var opk = null;
    var VoucherStatus = false;
    var Currency;
    var rowCurrentItemKey = null;
    var RowKey = null;
    var RowItemDetails;
    var IsLoading;
    var DiscountKind = false;
    var AdvancePayments = [];
    var ModalShowKind = 0;
    var CloseRowKey = null;
    var InvoiceStatus = 0;

    var conHiddenExpiry = '';

     var InPosting=false;
     
    $(document).ready(function ()
    {
        Currency = '@Currency';
        conHiddenExpiry = '@ExpiryHidden';
        if ('@ViewBag.Status' == 'True')
        {
            opk = '@Model.OperationKey';
            InvoiceStatus = Number('@Model.Status');
            VoucherStatus = false;
            $('#inf-Status').removeClass('bg-info');
            $('#inf-Status').addClass('bg-danger');
            $('#txt-Status').text(iShll.update);
            LoadData(opk);
            updateQRCode('@Model.QR');
        } else
        {
            $('#inf-Status').addClass('bg-info');
            $('#inf-Status').removeClass('bg-danger');
            $('#txt-Status').text(iShll.new);
            VoucherStatus = true;
        }

        $('#tb-rows').on('click', '#btn-edit', 'tr', function ()
        {
            IsLoading = 1;
            $('#tb-rows').find('[id="tr-' + $(this).data('key') + '"]').each(function ()
            {
                RowKey = $(this).find('[id="td-Key"]').data('value');
                rowCurrentItemKey = $(this).find('[id="td-ItemKey"]').data('value');
                CloseRowKey = $(this).find('[id="td-CloseRowKey"]').data('value');
                $('#row-ItemKind').dxSelectBox('option', 'value', $(this).find('[id="td-ItemKind"]').data('value'));
                $('#row-Account').dxLookup('option', 'value', $(this).find('[id="td-ItemKey"]').data('value'));
                $('#row-Unit').dxSelectBox('option', 'value', $(this).find('[id="td-Unit"]').data('value'));
                $('#row-ExpDate').dxDateBox('option', 'value', $(this).find('[id="td-ExpDate"]').data('value'));
                $('#row-Color').dxSelectBox('option', 'value', $(this).find('[id="td-Color"]').data('value'));
                $('#row-Size').dxSelectBox('option', 'value', $(this).find('[id="td-Size"]').data('value'));
                $('#row-Quantity').dxNumberBox('option', 'value', $(this).find('[id="td-Quantity"]').data('value'));
                $('#row-Bonus').dxNumberBox('option', 'value', $(this).find('[id="td-Bonus"]').data('value'));
                $('#row-UnitPrice').dxNumberBox('option', 'value', $(this).find('[id="td-UnitPrice"]').data('value'));
                $('#row-Amount').dxNumberBox('option', 'value', $(this).find('[id="td-Amount"]').data('value'));
                $('#row-Discount').dxNumberBox('option', 'value', $(this).find('[id="td-Discount"]').data('value'));
                $('#row-vatKey').dxSelectBox('option', 'value', $(this).find('[id="td-vatKey"]').data('value'));
                $('#row-vatAmount').dxNumberBox('option', 'value', $(this).find('[id="td-vatAmount"]').data('value'));
                $('#row-Total').dxNumberBox('option', 'value', $(this).find('[id="td-Total"]').data('value'));
                $('#row-Description').dxTextBox('option', 'value', $(this).find('[id="td-Description"]').data('value'));
                $('#row-CostCenter').dxLookup('option', 'value', $(this).find('[id="td-CostCenter"]').data('value'));
                $('#row-Project').dxLookup('option', 'value', $(this).find('[id="td-Project"]').data('value'));
            });
            currentRow = $(this).data('key');
            isNewRow = false;
            IsLoading = 0;
            $("#mod-Row").modal({ backdrop: 'static' }).modal('toggle');
        });

        $('#tb-rows').on('dblclick', 'tr', function ()
        {
            IsLoading = 1;
            RowKey = $(this).find('[id="td-Key"]').data('value');
            rowCurrentItemKey = $(this).find('[id="td-ItemKey"]').data('value');
            CloseRowKey = $(this).find('[id="td-CloseRowKey"]').data('value');
            $('#row-ItemKind').dxSelectBox('option', 'value', $(this).find('[id="td-ItemKind"]').data('value'));
            $('#row-Account').dxLookup('option', 'value', $(this).find('[id="td-ItemKey"]').data('value'));
            $('#row-Unit').dxSelectBox('option', 'value', $(this).find('[id="td-Unit"]').data('value'));
            $('#row-ExpDate').dxDateBox('option', 'value', $(this).find('[id="td-ExpDate"]').data('value'));
            $('#row-Color').dxSelectBox('option', 'value', $(this).find('[id="td-Color"]').data('value'));
            $('#row-Size').dxSelectBox('option', 'value', $(this).find('[id="td-Size"]').data('value'));
            $('#row-Quantity').dxNumberBox('option', 'value', $(this).find('[id="td-Quantity"]').data('value'));
            $('#row-Bonus').dxNumberBox('option', 'value', $(this).find('[id="td-Bonus"]').data('value'));
            $('#row-UnitPrice').dxNumberBox('option', 'value', $(this).find('[id="td-UnitPrice"]').data('value'));
            $('#row-Amount').dxNumberBox('option', 'value', $(this).find('[id="td-Amount"]').data('value'));
            $('#row-Discount').dxNumberBox('option', 'value', $(this).find('[id="td-Discount"]').data('value'));
            $('#row-vatKey').dxSelectBox('option', 'value', $(this).find('[id="td-vatKey"]').data('value'));
            $('#row-vatAmount').dxNumberBox('option', 'value', $(this).find('[id="td-vatAmount"]').data('value'));
            $('#row-Total').dxNumberBox('option', 'value', $(this).find('[id="td-Total"]').data('value'));
            $('#row-Description').dxTextBox('option', 'value', $(this).find('[id="td-Description"]').data('value'));
            $('#row-CostCenter').dxLookup('option', 'value', $(this).find('[id="td-CostCenter"]').data('value'));
            $('#row-Project').dxLookup('option', 'value', $(this).find('[id="td-Project"]').data('value'));
            currentRow = $(this).data('key');
            isNewRow = false;
            IsLoading = 0;
            $("#mod-Row").modal({ backdrop: 'static' }).modal('toggle');
        });


        inChangeItemKind = 1;
        $("#row-Account").dxLookup({
                  dataSource: new DevExpress.data.DataSource({
                loadMode: "raw",
                load: function ()
                {
                    return $.getJSON( '/api/icore/LoadAccounts?Kind=8');
                },
                paginate: true,
                pageSize: 50
            })
 
        });
        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup("getDataSource").load();
        inChangeItemKind = 0;
        $('#tb-rows').on('click', '#btn-delete', function ()
        {
            DeleteRow($(this).data('key'));
        });
    });
    function ChangefrmAccountKind (e)
    {
        $("#frm-AccountKey").dxLookup({
               dataSource: new DevExpress.data.DataSource({
                loadMode: "raw",
                load: function ()
                {
                    return $.getJSON( '/api/icore/LoadAccounts?Kind=' + e.value);
                },
                paginate: true,
                pageSize: 50
            })
        });
        $('#frm-AccountKey').dxLookup('reset');
    }
    //Start Operation
    var inChangeItemKind = 0;

    function ChangeItemKind (e)
    {
        if (inChangeItemKind == 1)
            return;

        inChangeItemKind = 1;
        $('#row-Account').dxLookup('reset');
        $("#row-Account").dxLookup({
                dataSource: new DevExpress.data.DataSource({
                loadMode: "raw",
                load: function ()
                {
                    return $.getJSON('/api/icore/LoadAccounts?Kind=' + e.value);
                },
                paginate: true,
                pageSize: 50
            })
          
        });
        if (rowCurrentItemKey != null)
        {
            $('#row-Account').dxLookup('option', 'value', rowCurrentItemKey);
        }
        switch (e.value)
        {
            case 8:
                $('#div-AvilableQty').prop('hidden', false);
                $('#div-Unit').prop('hidden', false);
                break;
            case 5:
            case 6:
            case 4:
                $('#div-AvilableQty').prop('hidden', true);
                $('#div-Unit').prop('hidden', true);
                $('#div-Bonus').prop('hidden', true);
                break;
        }


        inChangeItemKind = 0;
    }
    //End Start Operation
    //Stock
    function SelectedItemChanged (e)
    {
        if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
        {
            if (e.value == null)
            {
                $('#btn-rowEdit').prop('hidden', true);
                $('#btn-rowAdd').prop('hidden', false);
            } else
            {
                $('#btn-rowEdit').prop('hidden', false);
                $('#btn-rowAdd').prop('hidden', true);
            }
        }
        var acckind = $('#row-ItemKind').dxSelectBox('option', 'value');
        switch (acckind)
        {
            case 8:
                $("#row-Unit").dxSelectBox("reset");
                $("#row-Unit").dxSelectBox({
                    dataSource: '/api/inv/icore/ItemUnits?Key=' + e.value
                });
                $("#row-Unit").dxSelectBox("getDataSource").load().done(function (data)
                {
                    if (data.length > 0)
                    {
                        $("#row-Unit").dxSelectBox("option", "value", data[ 0 ].Code);
                    }
                });
                $.ajax({
                    type: "get",
                    url: "/api/inv/icore/InvoiceItemDetails",
                    data: { Key: e.value },
                    dataType: "json",
                    success: function (response)
                    {
                        RowItemDetails = response;
                        $('#div-Batch').prop('hidden', response.EnableBatch == false ? true : false);
                        $('#div-Color').prop('hidden', response.EnableColor == false ? true : false);
                        $('#div-Size').prop('hidden', response.EnableSize == false ? true : false);
                        if (response.EnableBatch == true)
                        {
                            $('#row-PartPrice').dxNumberBox('option', 'value', response.PartPrice);
                            $('#row-PartRate').dxNumberBox('option', 'value', response.PartRate);
                        }
                        if (response.vatKey == null)
                        {
                            var selectedvat = $("#row-vatKey").dxSelectBox('instance');
                            selectedvat.getDataSource().load().done(function (res)
                            {
                                $('#row-vatKey').dxSelectBox('option', 'value', res[ 0 ].Key);
                            });
                        } else
                        {
                            $('#row-vatKey').dxSelectBox('option', 'value', response.vatKey);
                        }
                        if (isNewRow == true)
                        {
                            if ($('#OriginalInvoice').val() == null || $('#OriginalInvoice').val() == '')
                            {
                                $('#row-UnitPrice').dxNumberBox('option', 'value', response.Price);
                            }
                        }

                        var d = new Date($('#frm-InvoiceDate').dxDateBox('option', 'value'));

                        $.ajax({
                            type: "get",
                            url: "/api/icore/ItemBalanceMainUnit",
                            data: { Key: e.value, Warehouse: $('#frm-SourceWarehouse').dxSelectBox('option', 'value'), Date: d.toLocaleDateString() },
                            dataType: "json",
                            success: function (response)
                            {
                                $('#txt-AvilableQty').text(comma(response) + ' ' + $('#row-Unit').dxSelectBox('option', 'text'));
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });

                    },
                    failure: function (response)
                    {
                        alert(response);
                    },
                    error: function (response)
                    {
                        alert(response.responseText);
                    }
                });
                break;
            case 6:
                $.ajax({
            type: "get",
            url: "/api/icore/GetServiceVATKey",
            data: { Key:  e.value },
            dataType: "json",
            success: function (response)
            {
                    if (response == null)
                        {
                            var selectedvat = $("#row-vatKey").dxSelectBox('instance');
                            selectedvat.getDataSource().load().done(function (res)
                            {
                                $('#row-vatKey').dxSelectBox('option', 'value', res[ 0 ].Key);
                            });
                        } else
                        {
                            $('#row-vatKey').dxSelectBox('option', 'value', response);
                        }
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
            break;
            default:
                $('#div-Batch').prop('hidden', true);
                $('#div-Color').prop('hidden', true);
                $('#div-Size').prop('hidden', true);
                 
                break;
        }
    }
    function EditAmount ()
    {
        if (IsLoading == 1)
            return;
        var selectedvat = $("#row-vatKey").dxSelectBox('instance').option('selectedItem');
        var vatRate = 0;
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var UnitPrice = $('#row-UnitPrice').dxNumberBox('option', 'value');
        var Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Numbert(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        var Total = 0;
        Total = Number(Number((Amount - Discount) + vatAmount).toFixed(4));
        //$("#edADis").dxNumberBox("option", "value", Number(Number(discount).toFixed(4)));
        $('#txt-AmountAfterDiscount').text(comma(Amount - Discount));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Amount.toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(vatAmount.toFixed(4)));
        $('#row-Total').dxNumberBox('option', 'value', Number(Total.toFixed(4)));
    }
    function RefelectAmount ()
    {
        var vatRate = 0;
        var selectedvat = $('#row-vatKey').dxSelectBox('instance').option('selectedItem');
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var Quantity = 0;
        var Total = 0;
        var UnitPrice = 0;
        Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        Total = $('#row-Total').dxNumberBox('option', 'value');
        UnitPrice = ((100 * Total) / Quantity) / (100 + vatRate);
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Number(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        $('#txt-AmountAfterDiscount').text(comma(Amount - Discount));
        $('#row-UnitPrice').dxNumberBox('option', 'value', Number(Number(UnitPrice).toFixed(4)));
        $('#row-Discount').dxNumberBox('option', 'value', Number(Number(Discount).toFixed(4)));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Number(Amount).toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(Number(vatAmount).toFixed(4)));
    }
