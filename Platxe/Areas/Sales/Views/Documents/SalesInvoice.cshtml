    function SaveRowChange ()
    {
        if ($('#row-Account').dxLookup('option', 'value') == null)
        {
            $.alert({
                title: 'Stop',
                content: "Please select account.",
            });
            $('#row-Account').dxLookup('focus');
            return;
        }
        if ($('#row-Quantity').dxNumberBox('option', 'value') == 0)
        {
            $.alert({
                title: 'Stop',
                content: "Please enter quantity.",
            });
            $('#row-Quantity').dxNumberBox('focus');
            return;
        }
        if (isNewRow == true)
        {
            InsertNewRow();
        } else
        {
            SaveRowEdit();
        }
    }
