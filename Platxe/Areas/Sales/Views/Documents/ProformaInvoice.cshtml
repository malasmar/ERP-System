    function EditAmount ()
    {
        if (IsLoading == 1)
            return;
        var selectedvat = $("#row-vatKey").dxSelectBox('instance').option('selectedItem');
        var vatRate = 0;
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var UnitPrice = $('#row-UnitPrice').dxNumberBox('option', 'value');
        var Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Numbert(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        var Total = 0;
        Total = Number(Number((Amount - Discount) + vatAmount).toFixed(4));
        //$("#edADis").dxNumberBox("option", "value", Number(Number(discount).toFixed(4)));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Amount.toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(vatAmount.toFixed(4)));
        $('#row-Total').dxNumberBox('option', 'value', Number(Total.toFixed(4)));
    }
    function RefelectAmount ()
    {
        var vatRate = 0;
        var selectedvat = $('#row-vatKey').dxSelectBox('instance').option('selectedItem');
        if (selectedvat.Key == null)
        {
            vatRate = 0;
        } else
        {
            vatRate = selectedvat.Rate;
        }
        var Quantity = 0;
        var Total = 0;
        var UnitPrice = 0;
        Quantity = $('#row-Quantity').dxNumberBox('option', 'value');
        Total = $('#row-Total').dxNumberBox('option', 'value');
        UnitPrice = ((100 * Total) / Quantity) / (100 + vatRate);
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (DiscountKind == false)
        {
            Discount = $('#row-Discount').dxNumberBox('option', 'value');
        } else
        {
            Discount = Number(Number($('#row-Discount').dxNumberBox('option', 'value') * (UnitPrice * Quantity) / 100).toFixed(4));
        }
        var vatAmount = 0;
        vatAmount = Number(Number(((Amount - Discount) * vatRate) / 100).toFixed(4));
        $('#row-UnitPrice').dxNumberBox('option', 'value', Number(Number(UnitPrice).toFixed(4)));
        $('#row-Discount').dxNumberBox('option', 'value', Number(Number(Discount).toFixed(4)));
        $('#row-Amount').dxNumberBox('option', 'value', Number(Number(Amount).toFixed(4)));
        $('#row-vatAmount').dxNumberBox('option', 'value', Number(Number(vatAmount).toFixed(4)));
    }
