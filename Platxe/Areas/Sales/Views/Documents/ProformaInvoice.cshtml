        });
    }
    function DeleteRow (key)
    {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure to delete row?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Delete',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                        $('#tr-' + key).remove();
                        CalcAmount();
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return;
                    }
                }
            }
        });
    }
    function CalcAmount ()
    {
        var amount = 0;
        var vat = 0;
        var total = 0;
        $('#tb-rows').find('tr').each(function ()
        {
            amount += $(this).find('[id="td-Amount"]').data('value');
            vat += $(this).find('[id="td-vatAmount"]').data('value');
            total += $(this).find('[id="td-Total"]').data('value');
        });
        $('#txt-Amount').text(comma(amount));
        $('#txt-vatAmount').text(comma(vat));
        $('#txt-Total').text(comma(total));
        $('#txt-xTotal').text(comma(total));
    }
    function GetItemKind (kind, Type)
    {
        var strKind = '';
        switch (kind)
        {
            case 0:
                strKind = '<span  class="badge bg-yellow text-dark badg-plx me-1">' + 'C/A' + '</span>';
                break;
            case 1:
                strKind = '<span  class="badge bg-danger text-dark badg-plx me-1">' + 'Employee' + '</span>';
                break;
            case 2:
                strKind = '<span  class="badge bg-info text-dark badg-plx me-1">' + 'Cash' + '</span>';
                break;
            case 3:
                strKind = '<span  class="badge bg-success text-dark badg-plx me-1">' + 'Bank' + '</span>';
                break;
            case 4:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Fixture' + '</span>';
                break;
            case 6:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Revenue' + '</span>';
                break;
            case 5:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Expenses' + '</span>';
                break;
            case 7:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Account' + '</span>';
                break;
            case 8:
                strKind = '<span  class="badge bg-yellow text-dark badg-plx me-1">' + 'Stock' + '</span>';
                break;
        }
        return '<div class="d-flex">' + strKind + '</div>'
    }
    function ValidateSave ()
    {
        var rowscount = $('#tb-rows tr').length;
        if (rowscount == 0)
        {
            $.alert({
                title: 'Stop',
                icon: 'fa fa-warning',
                type: 'red',
                content: 'There is no data in General Ledger!',
                buttons: {
                    Ok: {
                        text: 'ok'
                    }
                }
            });
            return false;
        }
        if ($('#frm-Client').dxLookup('option', 'value') == null)
        {
            $.alert({
                title: 'Stop',
                icon: 'fa fa-warning',
                type: 'red',
                content: 'Please select Client!',
                buttons: {
                    Ok: {
                        text: 'ok'
                    }
                }
            });
            return false;
        }
        return true;
    }
    function SaveGeneralLedger ()
    {
        if (ValidateSave() == false)
        {
            return;
        }
        if (InPosting == true)
            return;

        InPosting = true;
        $('.PLSave').prop('disabled', true);
        $.confirm({
            title: 'Confirm',
            content: 'Save/update Transaction confirmation?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Save/Update',
                    btnClass: 'btn-red',
                    action: function ()
                    {
                        //Start Update
                        var values = [];
                        $('#tb-rows').find('tr').each(function ()
                        {
                            values.push({
                                Key: $(this).find('[id="td-Key"]').data('value'),
                                Index: $(this).find('[id="td-Index"]').data('value'),
                                ItemKind: $(this).find('[id="td-ItemKind"]').data('value'),
                                ItemKey: $(this).find('[id="td-ItemKey"]').data('value'),
                                Color: $(this).find('[id="td-Color"]').data('value'),
                                Size: $(this).find('[id="td-Size"]').data('value'),
                                Unit: $(this).find('[id="td-Unit"]').data('value'),
                                UnitPrice: $(this).find('[id="td-UnitPrice"]').data('value'),
                                Quantity: $(this).find('[id="td-Quantity"]').data('value'),
                                Bonus: $(this).find('[id="td-Bonus"]').data('value'),
                                Amount: $(this).find('[id="td-Amount"]').data('value'),
                                Discount: $(this).find('[id="td-Discount"]').data('value'),
                                vatAmount: $(this).find('[id="td-vatAmount"]').data('value'),
                                UnitCost: $(this).find('[id="td-UnitCost"]').data('value'),
                                vatKey: $(this).find('[id="td-vatKey"]').data('value'),
                                vatRate: $(this).find('[id="td-vatRate"]').data('value'),
                                Total: $(this).find('[id="td-Total"]').data('value'),
                                Description: $(this).find('[id="td-Description"]').data('value'),
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/Sales/idocuments/UpdateProformaInvoice",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus,
                            dataType: "json",
                            success: function (response)
                            {
                                if (response.Status == true)
                                {
                                    exDocumentError(response);
                                    return;
                                }
                                $('#No').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info');
                                $('#inf-Status').addClass('bg-danger');
                               $('#txt-Status').text(iShll.update);
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                  InPosting = false;
                                $('.PLSave').prop('disabled', false);
                                PrintDocument();
                            },
                            failure: function (response)
                            {
                                alert(response);
                            },
                            error: function (response)
                            {
                                alert(response.responseText);
                            }
                        });
                        //End Update
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function ()
                    {
                        return;
                    }
                }
            }
        });
    }
    //Other Details show or hid
    function ChangeDueDays (e)
    {
        var vd = new Date();
        vd = $('#frm-InvoiceDate').dxDateBox('option', 'value');
        var due = new Date();
        $('#frm-DueDate').dxDateBox('option', 'value', due.setDate(vd.getDate() + e.value));
    }

      function PrintDocument ()
    {
        ProformaInvoicePrintTemplates(101, opk);
    }
