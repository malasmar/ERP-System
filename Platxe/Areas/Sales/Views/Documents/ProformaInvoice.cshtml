@model CLiSales.Documents.Proforma
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    string Currency = CLiCore.VoucherOperation.DefaultCurrency(DB);

    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
   
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }

    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    .xd > tr:hover .ccp {
        display: block !important;
    }

    .xd .ccp {
        display: block !important;
    }
    .xd > tr:hover {
        cursor: pointer;
    }

    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }

    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }

    .width-20 {
        width: 20px !important;
        min-width: 20px !important;
    }
</style>
<div class="invoice">
    <div class="invoice-company">
        <div class="float-end hidden-print">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
        <div class="shl-invoice-header">
            @iT.T(xLan,"2148","Proforma Invoice") <span id="inf-Status" class="badge bg-info text-dark"><small class="f-s-9 me-1">@iT.T(xLan,"2141","Status")</small><span id="txt-Status" class="me-1">Update</span></span><span id="txt-VoucherNo" class="text-danger"># @Model.InvoiceNo </span> 
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
        </div>
    </div>
    <form id="frm-Voucher">
        @Html.HiddenFor(m=>m.OperationKey)
        @Html.HiddenFor(m=>m.InvoiceNo)
        @Html.HiddenFor(m=>m.MonthlyNo)
        @Html.HiddenFor(m=>m.CreateUser)
        @Html.HiddenFor(m=>m.CreateDate)
        <div class="invoice-header">
            <div class="invoice-from">
                <div class="row">
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1624","Invoice Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().DateBoxFor(m => m.InvoiceDate).ID("frm-InvoiceDate").Width(125).DisplayFormat("dd.MM.yyyy").Min(new DateTime(xYear,1,1)).Max(DateTime.UtcNow.AddMinutes(180))
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1355","Client")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.Client).ID("frm-Client").DataSourceOptions(o=>o.Paginate(true).PageSize(50)).DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, PLenums.TransactionAccount.CurrentAccount, PLenums.CurrentAccountKind.Client)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1212","Description")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextAreaFor(m => m.Description).ID("frm-Description").Height(55)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1731","Person")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SalesPerson).ID("frm-SalesPerson").DataSource(CLiHR.Selections.Employees.GetList(DB,xLan,2)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1287","Source")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SalesHand).ID("frm-SalesHand").ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1636","Invoice No")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.ReferenceNo).ID("frm-ReferenceNo").Width(125)
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1373","Due Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBox().ID("frm-DueDays").Width(75).OnValueChanged("ChangeDueDays").ShowSpinButtons(true)
                                    @Html.DevExtreme().DateBoxFor(m => m.DueDate).ID("frm-DueDate").Width(110).DisplayFormat("dd.MM.yyyy")
                                </div>
                            </div>
                        </div>
                               <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1328","Prefix")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Prefix).ID("frm-Prefix").DataSource(CLiFinancial.Selections.Prefix.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1220","Project")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.Project).ID("frm-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1332","Cst.Center")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.CostCenter).ID("frm-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>

                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark" style="height:225px">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-3 ">
                                    <b class="mb-3">@iT.T(xLan,"2154","Voucher Details")</b>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1347","Subtotal")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.SubTotal.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2153","Discount")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Discount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2146","VAT")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.vatAmount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-1">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1120","Total")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Total.ToString("n2")</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark" style="height:225px">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-3 ">
                                    <b class="mb-3">@iT.T(xLan,"2154","Voucher Details")</b>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2155","Create User")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10"><span>@Model.CreateUserInfo.Display</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2156","Create Date")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10" style="direction:ltr">@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy hh:mm tt") : "")</div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2157","Update User")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10"><span>@Model.CreateUserInfo.Display</span></div>
                                    </div>
                                </div>
                                <div class="mb-2">
                                    <div class="d-block ">
                                        @iT.T(xLan,"2158","Update Date")
                                    </div>
                                    <div class="d-block  ms-auto">
                                        <div class="ps-2 f-s-10" style="direction:ltr">@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy hh:mm tt") : "")</div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <div class="invoice-content mt-3">
        <div class="sticky">
            <button type="button" id="btn-add" class="btn btn-yellow btn-sm text-dark" onclick="AddNewRow()">@iT.T(xLan,"1214","Add New Row")</button>
        </div>
        <div class="table-responsive">
            <table class="table table-invoice table-hover">
                <thead>
                    <tr>
                        <th style="width:100px;max-width:100px">@iT.T(xLan,"1215","Actions")</th>
                        <th style="width:65px;min-width:65px;max-width:65px">@iT.T(xLan,"1158","Kind")</th>
                        <th style="width:120px;min-width:120px;max-width:120px">@iT.T(xLan,"1164","Code")</th>
                        <th style="width:100%;min-width:150px">@iT.T(xLan,"1586","Item Name")</th>
                        <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1076","Quantity")</th>
                        <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1639","Bonus")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1629","Unit Price")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>
                        <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1097","Discount")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1345","VAT")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1120","Total")</th>
                    </tr>
                </thead>
                <tbody class="xd" id="tb-rows">
                </tbody>
            </table>
        </div>
        <div class="invoice-price">
            <div class="invoice-price-left">
                <div class="invoice-price-row">
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1347","Subtotal")</small>
                        <span id="txt-Amount" class="text-dark">0.00</span>
                    </div>
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1348","VAT Total")</small>
                        <span id="txt-vatAmount" class="text-dark">0.00</span>
                    </div>
                    <div class="sub-price">
                        <small>@iT.T(xLan,"1120","Total")</small>
                        <span id="txt-Total" class="text-red me-2">0.00</span>
                    </div>
                </div>
            </div>
            <div class="invoice-price-right">
                <small>@iT.T(xLan,"1120","TOTAL")</small> <span class="fw-bold" id="txt-xTotal">0.00</span>
            </div>
        </div>
    </div>
    <div class="invoice-note">
        <hr>
        <div class="text-left">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px PLSave" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
    </div>
</div>
<div id="mod-Row" class="modal">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h4 class="modal-title">@iT.T(xLan,"1218","Row Details")</h4>
            </div>
            <div class="modal-body">
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1333","Account Kind")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-ItemKind").DataSource(iReplacer.invSalesItems(xLan)).ValueExpr("Value").DisplayExpr("Display").Width(150).Value(8).OnValueChanged("ChangeItemKind")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"","Item/Account")</label>
                    <div class="col-lg-9 col-sm-12">
                        <div class="input-group">
                            @Html.DevExtreme().Lookup().ID("row-Account").ValueExpr("Key").DisplayExpr("Display").Width("90%").OnValueChanged("SelectedItemChanged")
                            <button type="button" class="btn btn-white f-s-10" onclick="RefelectAmount()"><i id="i-account" class="fas fa-plus"></i></button>
                        </div>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1587","Unit")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-Unit").ValueExpr("Code").DisplayExpr("Code").Width(150)
                    </div>
                </div>
                <div>
                    <div id="div-color" class="form-group row" hidden>
                        <label class="col-lg-3 col-sm-12  ">Item Color <span class="text-red right">*</span></label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().SelectBox().ID("row-Color").Width(132).DataSource(CLiInventory.Selections.Properties.Colors(DB, xLan)).ValueExpr("No").DisplayExpr("Display").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                    <div id="div-size" class="form-group row" hidden>
                        <label class="col-lg-3 col-sm-12  ">Item Size<span class="text-red right">*</span></label>
                        <div class="col-lg-9 col-sm-12">
                            @Html.DevExtreme().SelectBox().ID("row-Size").Width(132).DataSource(CLiInventory.Selections.Properties.Sizes(DB, xLan)).ValueExpr("No").DisplayExpr("Display").ElementAttr("class", "plxenter")
                        </div>
                    </div>
                </div>
                <hr class="p-0 m-2" />
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1076","Quantity")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Quantity").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.##").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1639","Bonus")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Bonus").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.##")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1989","UnitPrice")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-UnitPrice").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.####").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1077","Amount")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-Amount").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.####").ReadOnly(true)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1097","Discount")</label>
                    <div class="col-9">
                        <div class="input-group">
                            @Html.DevExtreme().NumberBox().ID("row-Discount").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.##").OnValueChanged("EditAmount")
                            <button type="button" class="btn btn-white btn-xs" onclick="SearchBatchLot()"><i class="fa fa-percent width-20"></i></button>
                        </div>
                        <p  hidden class="text-dark f-s-10 m-0 p-0 mt-1 mb-1">Amount after discount: <b class="me-2">4,000</b></p>
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1977","vatKey")</label>
                    <div class="col-lg-9 col-sm-12">
                        @Html.DevExtreme().SelectBox().ID("row-vatKey").Width(132).DataSource(CLiFinancial.Selections.vatRate.vatRates(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").OnValueChanged("EditAmount")
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1350","vat Amount")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("row-vatAmount").ShowSpinButtons(true).Width(132).Min(0).Format("0,###.##").ReadOnly(true)
                    </div>
                </div>
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1120","Total")</label>
                    <div class="col-9">
                        <div class="input-group">
                            @Html.DevExtreme().NumberBox().ID("row-Total").Width(130).ShowSpinButtons(true).Format("0,###.####")
                            <button type="button" class="btn btn-white f-s-10" onclick="RefelectAmount()">@iT.T(xLan, "1326","Reflect Amount")</button>
                        </div>
                    </div>
                </div>
                <hr class="p-0 m-2" />
                <div class="form-group row">
                    <label class="col-3">@iT.T(xLan,"1212","Description")</label>
                    <div class="col-9">
                        @Html.DevExtreme().TextBox().ID("row-Description")
                    </div>
                </div>
            </div>
            <div class="modal-footer sticky-bottom">
                <div class="btn-group">
                    <button type="submit" class="btn btn-yellow text-dark" onclick="SaveRowChange()">@iT.T(xLan,"1197","Save Change")</button>
                    <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"1198","Cancel")</button>
                </div>
            </div>
        </div>
    </div>
</div>
<div id="mod-AdvancePayments" class="modal"><div class="modal-dialog modal-lg" id="con-AdvancePayments"></div></div>
<script class="append-on-ajax-script">
    var clcDebitCredit = 0;
    var isNewRow;
    var currentRow;
    var opk = null;
    var VoucherStatus = false;
    var Currency;
    var rowCurrentItemKey = null;
    var RowKey = null;
    var RowItemDetails;
    var IsLoading;
    var DiscountKind = false;
    var AdvancePayments = [];
    var InPosting = false;
    $(document).ready(function ()
    {
        Currency = '@Currency';
        if ('@ViewBag.Status' == 'True')
        {
            opk = '@Model.OperationKey';
            VoucherStatus = false;
            $('#inf-Status').removeClass('bg-info');
            $('#inf-Status').addClass('bg-danger');
            $('#txt-Status').text(iShll.update);
            LoadData(opk);
        } else
        {
            $('#inf-Status').addClass('bg-info');
            $('#inf-Status').removeClass('bg-danger');
            $('#txt-Status').text(iShll.new);
            VoucherStatus = true;
        }
        $('#tb-rows').on('click', '#btn-edit', function ()
        {
            IsLoading = 1;
            $('#tb-rows').find('[id="tr-' + $(this).data('key') + '"]').each(function ()
            {
                RowKey = $(this).find('[id="td-Key"]').data('value');
                rowCurrentItemKey = $(this).find('[id="td-ItemKey"]').data('value');
                $('#row-ItemKind').dxSelectBox('option', 'value', $(this).find('[id="td-ItemKind"]').data('value'));
                $('#row-Account').dxLookup('option', 'value', $(this).find('[id="td-ItemKey"]').data('value'));
                $('#row-Unit').dxSelectBox('option', 'value', $(this).find('[id="td-Unit"]').data('value'));
                $('#row-Color').dxSelectBox('option', 'value', $(this).find('[id="td-Color"]').data('value'));
                $('#row-Size').dxSelectBox('option', 'value', $(this).find('[id="td-Size"]').data('value'));
                $('#row-Quantity').dxNumberBox('option', 'value', $(this).find('[id="td-Quantity"]').data('value'));
                $('#row-Bonus').dxNumberBox('option', 'value', $(this).find('[id="td-Bonus"]').data('value'));
