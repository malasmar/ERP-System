    function SaveGeneralLedger() {
        //if (ValidateSave() == false) {
        //    return;
        //}
        $.confirm({
            title: 'Confirm',
            content: 'Save and update General Ledger confirmation?',
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Save/Update GL',
                    btnClass: 'btn-red',
                    action: function() {
                        //Start Update
                        var values = [];
                        $('#tb-rows').find('tr').each(function() {
                            values.push({
                                Account: $(this).find('[id="td-Account"]').data('value'),
                                Description: $(this).find('[id="td-Description"]').data('value'),
                                Debit: $(this).find('[id="td-Debit"]').data('value'),
                                Credit: $(this).find('[id="td-Credit"]').data('value'),
                                CostCenter: $(this).find('[id="td-CostCenter"]').data('value'),
                                Project: $(this).find('[id="td-Project"]').data('value')
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/acc/idocuments/UpdateGeneralLedger",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus,
                            dataType: "json",
                            success: function(response) {
                                if (response.Status == true) {
                                    exDocumentError(response);
                                    return;
                                }
                                $('#No').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info');
                                $('#inf-Status').addClass('bg-danger');
                               $('#txt-Status').text(iShll.update);
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                //ShowPrintTemplate();
                            },
                            failure: function(response) {
                                alert(response);
                            },
                            error: function(response) {
                                alert(response.responseText);
                            }
                        });
                        //End Update
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function() {
                        return;
                    }
                }
            }
        });
    }
</script>