@model CLiAccounting.Documents.GeneralLedger
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool isRtl = xLan == "ar";
}

<div class="content-header mb-4">
    <div class="container-fluid">
        <div class="row align-items-center">
            <div class="col-md-6">
                <h1 class="page-header h3 mb-1">
                    @iT.T(xLan, "1209", "General Ledger")
                    <span id="inf-Status" class="badge rounded-pill bg-info ms-2 fs-7 fw-medium">
                        <i class="bx bxs-circle me-1 small"></i>
                        <span id="txt-Status">New</span>
                    </span>
                    <span class="ms-2 text-muted fw-normal fs-6">#<span id="txt-VoucherNo">@Model.No</span></span>
                </h1>
                <nav aria-label="breadcrumb">
                    <ol class="breadcrumb mb-0">
                        <li class="breadcrumb-item"><a href="/Accounting">@iT.T(xLan, "1142", "Home")</a></li>
                        <li class="breadcrumb-item"><a href="/Accounting/Documents/GeneralLedgerList">@iT.T(xLan, "1221", "General Ledger List")</a></li>
                        <li class="breadcrumb-item active">@iT.T(xLan, "1209", "General Ledger")</li>
                    </ol>
                </nav>
            </div>
            <div class="col-md-6 text-md-end">
                <div class="btn-group shadow-sm">
                    <button type="button" class="btn btn-primary" onclick="SaveGeneralLedger()">
                        <i class="bx bx-save me-1"></i> @iT.T(xLan, "", "Save/Update")
                    </button>
                    <button type="button" onclick="window.print()" class="btn btn-light border">
                        <i class="bx bx-printer me-1"></i> @iT.T(xLan, "1208", "Print")
                    </button>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="container-fluid" id="gl-entry-container">
    <!-- Summary Cards -->
    <div class="row mb-4 g-3">
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-primary border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "1008", "Total Debit")</div>
                            <div class="h4 mb-0 fw-bold" id="txt-Debit">0.00</div>
                        </div>
                        <div class="ms-3 bg-light rounded-circle p-3">
                            <i class="bx bx-trending-up text-primary fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-danger border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "1009", "Total Credit")</div>
                            <div class="h4 mb-0 fw-bold" id="txt-Credit">0.00</div>
                        </div>
                        <div class="ms-3 bg-light rounded-circle p-3">
                            <i class="bx bx-trending-down text-danger fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card border-0 shadow-sm border-start border-warning border-4">
                <div class="card-body">
                    <div class="d-flex align-items-center">
                        <div class="flex-grow-1">
                            <div class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "1217", "Balance / Difference")</div>
                            <div class="h4 mb-0 fw-bold" id="txt-Diff">0.00</div>
                        </div>
                        <div class="ms-3 bg-light rounded-circle p-3">
                            <i class="bx bx-calculator text-warning fs-3"></i>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Header / Filter Card -->
    <div class="card border-0 shadow-sm mb-4">
        <div class="card-header bg-white border-bottom py-3">
            <h5 class="card-title mb-0 fw-bold text-dark">
                <i class="bx bx-info-circle me-2 text-primary"></i>@iT.T(xLan, "1225", "Document Information")
            </h5>
        </div>
        <div class="card-body">
            <form id="frm-Voucher">
                @Html.HiddenFor(m => m.OperationKey)
                @Html.HiddenFor(m => m.No)
                <div class="row g-4">
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label fw-semibold">@iT.T(xLan, "1210", "Date")</label>
                        @Html.DevExtreme().DateBoxFor(m => m.Date).ID("frm-Date").Width("100%").DisplayFormat("dd.MM.yyyy").Value(DateTime.Now).ElementAttr("class", "modern-dx-box")
                    </div>
                    <div class="col-lg-3 col-md-6">
                        <label class="form-label fw-semibold">@iT.T(xLan, "1211", "Document Kind")</label>
                        @Html.DevExtreme().SelectBoxFor(m => m.DocumentKind).ID("frm-DocumentKind").DataSource(iReplacer.accGeneralLedgerKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").ElementAttr("class", "modern-dx-box")
                    </div>
                    <div class="col-lg-6 col-md-12">
                        <label class="form-label fw-semibold">@iT.T(xLan, "1212", "Description")</label>
                        @Html.DevExtreme().TextAreaFor(m => m.Description).ID("frm-Description").Height(36).Width("100%").Placeholder(iT.T(xLan, "", "Enter document description...")).ElementAttr("class", "modern-dx-box")
                    </div>
                </div>
            </form>
        </div>
        <div class="card-footer bg-light-soft py-2 px-3">
            <div class="d-flex align-items-center small text-muted">
                <i class="bx bx-bulb me-2 text-warning fs-5"></i>
                @iT.T(xLan, "", "Tip: Use General Ledger for opening balances and special adjustments only.")
            </div>
        </div>
    </div>

    <!-- Transactions Card -->
    <div class="card border-0 shadow-sm mb-5">
        <div class="card-header bg-white border-bottom py-3 d-flex align-items-center justify-content-between">
            <h5 class="card-title mb-0 fw-bold text-dark">
                <i class="bx bx-list-ul me-2 text-primary"></i>@iT.T(xLan, "1226", "Ledger Entries")
            </h5>
            <button type="button" class="btn btn-sm btn-yellow text-dark fw-bold px-3 shadow-sm" onclick="AddNewRow()">
                <i class="bx bx-plus me-1"></i> @iT.T(xLan, "1214", "Add New Row")
            </button>
        </div>
        <div class="card-body p-0">
            <!-- Loading Spinner Area -->
            <div id="gl-loading" class="text-center py-5 d-none">
                <div class="spinner-border text-primary" role="status">
                    <span class="visually-hidden">Loading...</span>
                </div>
                <p class="mt-2 text-muted">@iT.T(xLan, "", "Processing data...")</p>
            </div>

            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" id="gl-table">
                    <thead class="bg-light sticky-top">
                        <tr>
                            <th class="ps-3" style="width:120px">@iT.T(xLan, "1215", "Actions")</th>
                            <th style="width:100px">@iT.T(xLan, "1158", "Kind")</th>
                            <th style="width:120px">@iT.T(xLan, "1164", "Code")</th>
                            <th style="width:250px">@iT.T(xLan, "1216", "Account Name")</th>
                            <th class="min-w-200">@iT.T(xLan, "1212", "Description")</th>
                            <th class="text-end" style="width:120px">@iT.T(xLan, "1008", "Debit")</th>
                            <th class="text-end pe-3" style="width:120px">@iT.T(xLan, "1009", "Credit")</th>
                        </tr>
                    </thead>
                    <tbody id="tb-rows">
                        <!-- Rows populated by JS -->
                    </tbody>
                </table>
            </div>

            <!-- Empty State Area -->
            <div id="gl-empty" class="text-center py-5 @(Model.OperationKey == Guid.Empty ? "" : "d-none")">
                <i class="bx bx-collection display-4 text-muted opacity-25"></i>
                <p class="text-muted mt-2">@iT.T(xLan, "", "No entries added yet.")</p>
            </div>
        </div>
        <div class="card-footer bg-white border-top py-3 text-end">
             <div class="d-inline-block">
                 <span class="text-muted me-3">@iT.T(xLan, "1120", "Total"):</span>
                 <span class="h4 mb-0 fw-bold text-primary" id="txt-Total">0.00</span>
             </div>
        </div>
    </div>
</div>

<!-- Row Details Modal -->
<div id="mod-Row" class="modal fade" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">
            <div class="modal-header bg-primary text-white border-0">
                <h5 class="modal-title fw-bold">
                    <i class="bx bx-edit-alt me-2"></i>@iT.T(xLan, "1218", "Row Details")
                </h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <div class="mb-3">
                    <label class="form-label fw-bold">@iT.T(xLan, "1219", "Account")</label>
                    @Html.DevExtreme().Lookup().ID("row-Account").DataSource(CLiAccounting.Selections.AccountTransactionLevel.GetList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display").SearchEnabled(true).Placeholder(iT.T(xLan, "", "Search account...")).ElementAttr("class", "modern-dx-box")
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">@iT.T(xLan, "1212", "Description")</label>
                    @Html.DevExtreme().TextBox().ID("row-Description").Placeholder(iT.T(xLan, "", "Entry description...")).ElementAttr("class", "modern-dx-box")
                </div>
                <div class="row g-3 mb-3">
                    <div class="col-6">
                        <label class="form-label fw-bold">@iT.T(xLan, "1008", "Debit")</label>
                        @Html.DevExtreme().NumberBox().ID("row-Debit").ShowSpinButtons(true).Width("100%").Min(0).OnValueChanged("ChangeDebit").ElementAttr("class", "modern-dx-box text-primary fw-bold")
                    </div>
                    <div class="col-6">
                        <label class="form-label fw-bold">@iT.T(xLan, "1009", "Credit")</label>
                        @Html.DevExtreme().NumberBox().ID("row-Credit").ShowSpinButtons(true).Width("100%").Min(0).OnValueChanged("ChangeCredit").ElementAttr("class", "modern-dx-box text-danger fw-bold")
                    </div>
                </div>
                <div class="mb-3">
                    <label class="form-label fw-bold">@iT.T(xLan, "1199", "Cost Center")</label>
                    @Html.DevExtreme().Lookup().ID("row-Costcenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true).Placeholder(iT.T(xLan, "", "Optional...")).ElementAttr("class", "modern-dx-box")
                </div>
                <div class="mb-0">
                    <label class="form-label fw-bold">@iT.T(xLan, "1220", "Project")</label>
                    @Html.DevExtreme().Lookup().ID("row-Project").DataSource(CLiAccounting.Selections.Project.FullList(DB, xLan)).ValueExpr("Key").DisplayExpr("Display").ShowClearButton(true).Placeholder(iT.T(xLan, "", "Optional...")).ElementAttr("class", "modern-dx-box")
                </div>
            </div>
            <div class="modal-footer bg-light border-0">
                <button type="button" class="btn btn-light" data-bs-dismiss="modal">@iT.T(xLan, "1198", "Cancel")</button>
                <button type="button" class="btn btn-primary px-4 shadow-sm" onclick="SaveRowChange()">
                    <i class="bx bx-check me-1"></i> @iT.T(xLan, "1197", "Apply Change")
                </button>
            </div>
        </div>
    </div>
</div>

<style>
    .bg-light-soft { background-color: #f8fafc; }
    .fs-7 { font-size: 0.85rem; }
    .badg-soft-primary { background: rgba(37, 99, 235, 0.1); color: #2563eb; }
    .badg-soft-danger { background: rgba(220, 38, 38, 0.1); color: #dc2626; }
    .modern-dx-box .dx-texteditor-input { padding: 8px 12px; }
    .sticky-top { top: -1px; z-index: 100; }
    #gl-table thead th { border-top: 0; font-weight: 600; text-transform: uppercase; font-size: 0.75rem; letter-spacing: 0.5px; color: #64748b; }
    .btn-yellow { background-color: #fbbf24; border-color: #fbbf24; }
    .btn-yellow:hover { background-color: #f59e0b; border-color: #f59e0b; }
    
    /* Soft shadows and rounded corners */
    .card { border-radius: 12px; }
    .btn { border-radius: 8px; }
    
    /* RTL adjustments */
    [dir="rtl"] .ms-2 { margin-right: 0.5rem !important; margin-left: 0 !important; }
    [dir="rtl"] .me-2 { margin-left: 0.5rem !important; margin-right: 0 !important; }
    [dir="rtl"] .text-end { text-align: left !important; }
    [dir="rtl"] .ps-3 { padding-right: 1rem !important; padding-left: 0 !important; }
</style>

<script class="append-on-ajax-script">
    var clcDebitCredit = 0;
    var isNewRow;
    var currentRow;
    var opk = null;
    var VoucherStatus = false;

    $(document).ready(function() {
        if ('@ViewBag.Status' == 'True') {
            opk = '@Model.OperationKey';
            VoucherStatus = false;
            $('#inf-Status').removeClass('bg-info').addClass('bg-warning text-dark');
            $('#txt-Status').text(iShll.update || 'Update');
            LoadData(opk);
        } else {
            $('#inf-Status').addClass('bg-info');
            $('#txt-Status').text('New');
            VoucherStatus = true;
        }

        $('#tb-rows').on('click', '#btn-edit', function() {
            var key = $(this).data('key');
            var tr = $('#tr-' + key);
            
            $('#row-Account').dxLookup('option', 'value', tr.find('#td-Account').data('value'));
            $('#row-Description').dxTextBox('option', 'value', tr.find('#td-Description').data('value'));
            $('#row-Debit').dxNumberBox('option', 'value', tr.find('#td-Debit').data('value'));
            $('#row-Credit').dxNumberBox('option', 'value', tr.find('#td-Credit').data('value'));
            $('#row-Costcenter').dxLookup('option', 'value', tr.find('#td-Costcenter').data('value'));
            $('#row-Project').dxLookup('option', 'value', tr.find('#td-Project').data('value'));
            
            currentRow = key;
            isNewRow = false;
            $("#mod-Row").modal('show');
        });

        $('#tb-rows').on('click', '#btn-delete', function() {
            DeleteRow($(this).data('key'));
        });
    });

    function ChangeDebit() {
        if (clcDebitCredit == 1) return;
        clcDebitCredit = 1;
        $('#row-Credit').dxNumberBox('option', 'value', 0);
        clcDebitCredit = 0;
    }

    function ChangeCredit() {
        if (clcDebitCredit == 1) return;
        clcDebitCredit = 1;
        $('#row-Debit').dxNumberBox('option', 'value', 0);
        clcDebitCredit = 0;
    }

    function AddNewRow() {
        isNewRow = true;
        $('#row-Account').dxLookup('reset');
        $('#row-Description').dxTextBox('option', 'value', $('#frm-Description').dxTextArea('option', 'value'));
        $('#row-Debit').dxNumberBox('option', 'value', 0);
        $('#row-Credit').dxNumberBox('option', 'value', 0);
        $('#row-Costcenter').dxLookup('reset');
        $('#row-Project').dxLookup('reset');
        $("#mod-Row").modal('show');
    }

    function SaveRowChange() {
        if ($('#row-Account').dxLookup('option', 'value') == null) {
            $.alert({ title: 'Attention', content: "Please select an account.", theme: 'material' });
            return;
        }
        if ($('#row-Debit').dxNumberBox('option', 'value') + $('#row-Credit').dxNumberBox('option', 'value') == 0) {
            $.alert({ title: 'Attention', content: "Please enter a Debit or Credit value.", theme: 'material' });
            return;
        }
        
        if (isNewRow) InsertNewRow(); else SaveRowEdit();
        $('#gl-empty').addClass('d-none');
    }

    function GetRowHtml(count, account, description, debit, credit, costcenter, project, costcenterText, projectText) {
        var kindHtml = GetAccountKind(account.Kind);
        var trId = 'tr-' + count;
        var str = '<tr id="' + trId + '" class="row-entry animation-fade-in">';
        str += '<td class="ps-3"><div class="btn-group btn-group-sm rounded-pill border bg-white shadow-xs p-1">';
        str += '<button id="btn-edit" data-key="' + count + '" type="button" class="btn btn-link btn-sm text-primary p-1"><i class="bx bx-edit fs-6"></i></button>';
        str += '<button id="btn-delete" data-key="' + count + '" type="button" class="btn btn-link btn-sm text-danger p-1"><i class="bx bx-trash fs-6"></i></button>';
        str += '</div></td>';
        str += '<td>' + kindHtml + '</td>';
        str += '<td><code class="text-dark fw-medium">' + account.Code + '</code></td>';
        str += '<td><div class="fw-bold text-dark">' + (account.Name1 || account.Display) + '</div></td>';
        str += '<td><div class="text-muted small">' + description + '</div>';
        if (costcenterText || projectText) {
            str += '<div class="mt-1 d-flex gap-2">';
            if (costcenterText) str += '<span class="badge bg-light text-dark border-0 fs-8"><i class="bx bx-target-lock me-1"></i>' + costcenterText + '</span>';
            if (projectText) str += '<span class="badge bg-light text-dark border-0 fs-8"><i class="bx bx-briefcase me-1"></i>' + projectText + '</span>';
            str += '</div>';
        }
        str += '</td>';
        str += '<td class="text-end fw-bold text-primary">' + comma(debit) + '</td>';
        str += '<td class="text-end pe-3 fw-bold text-danger">' + comma(credit) + '</td>';
        
        // Hidden data fields for form submission and editing
        str += '<td hidden id="td-Account" data-value="' + account.Key + '"></td>';
        str += '<td hidden id="td-Description" data-value="' + description + '"></td>';
        str += '<td hidden id="td-Debit" data-value="' + debit + '"></td>';
        str += '<td hidden id="td-Credit" data-value="' + credit + '"></td>';
        str += '<td hidden id="td-Costcenter" data-value="' + costcenter + '"></td>';
        str += '<td hidden id="td-Project" data-value="' + project + '"></td>';
        str += '</tr>';
        return str;
    }

    function InsertNewRow() {
        var account = $("#row-Account").dxLookup('instance').option('selectedItem');
        var count = $('#tb-rows tr').length + 1;
        var html = GetRowHtml(count, account, $('#row-Description').dxTextBox('option', 'value'), $('#row-Debit').dxNumberBox('option', 'value'), $('#row-Credit').dxNumberBox('option', 'value'), $('#row-Costcenter').dxLookup('option', 'value'), $('#row-Project').dxLookup('option', 'value'), $('#row-Costcenter').dxLookup('option', 'text'), $('#row-Project').dxLookup('option', 'text'));
        
        $("#tb-rows").append(html);
        $("#mod-Row").modal('hide');
        CalcAmount();
    }

    function SaveRowEdit() {
        var account = $("#row-Account").dxLookup('instance').option('selectedItem');
        var html = GetRowHtml(currentRow, account, $('#row-Description').dxTextBox('option', 'value'), $('#row-Debit').dxNumberBox('option', 'value'), $('#row-Credit').dxNumberBox('option', 'value'), $('#row-Costcenter').dxLookup('option', 'value'), $('#row-Project').dxLookup('option', 'value'), $('#row-Costcenter').dxLookup('option', 'text'), $('#row-Project').dxLookup('option', 'text'));
        
        $('#tr-' + currentRow).replaceWith(html);
        $("#mod-Row").modal('hide');
        CalcAmount();
    }

    function LoadData(key) {
        $('#gl-loading').removeClass('d-none');
        $.ajax({
            type: "get",
            url: "/api/acc/idocuments/LoadGeneralLedger",
            data: { key: key },
            success: function(response) {
                $('#gl-loading').addClass('d-none');
                var count = 1;
                for (const item of response) {
                    var account = item.jnAccount;
                    account.Key = item.Account; // Standardize for GetRowHtml
                    var html = GetRowHtml(count, account, item.Description, item.Debit, item.Credit, item.CostCenter, item.Project, item.jnCostCenter.Display, item.jnProject.Display);
                    $("#tb-rows").append(html);
                    count++;
                }
                if (count > 1) $('#gl-empty').addClass('d-none');
                CalcAmount();
            }
        });
    }

    function DeleteRow(key) {
        $.confirm({
            title: 'Delete Entry?',
            content: 'Are you sure you want to remove this row from the ledger?',
            type: 'red',
            buttons: {
                Delete: { btnClass: 'btn-danger', action: function() { $('#tr-' + key).remove(); CalcAmount(); if ($('#tb-rows tr').length == 0) $('#gl-empty').removeClass('d-none'); } },
                Cancel: { action: function() {} }
            }
        });
    }

    function CalcAmount() {
        var db = 0, cr = 0;
        $('#tb-rows tr').each(function() {
            db += parseFloat($(this).find('#td-Debit').data('value')) || 0;
            cr += parseFloat($(this).find('#td-Credit').data('value')) || 0;
        });
        $('#txt-Diff').text(comma(db - cr)).toggleClass('text-danger', (db - cr) != 0).toggleClass('text-success', (db - cr) == 0);
        $('#txt-Debit').text(comma(db));
        $('#txt-Credit').text(comma(cr));
        $('#txt-Total').text(comma(db));
    }

    function GetAccountKind(kind) {
        var labels = ['Assets', 'Liability', 'Equity', 'Revenue', 'Expenses'];
        var colors = ['bg-primary', 'bg-danger', 'bg-info text-dark', 'bg-success', 'bg-warning text-dark'];
        return '<span class="badge ' + colors[kind] + ' w-100 opacity-75">' + labels[kind] + '</span>';
    }

    function SaveGeneralLedger() {
        if ($('#tb-rows tr').length == 0) {
            $.alert({ title: 'Error', content: 'There is no data to save!', type: 'red' });
            return;
        }

        $.confirm({
            title: 'Save Changes?',
            content: 'Save and update this General Ledger document?',
            type: 'blue',
            buttons: {
                Save: {
                    btnClass: 'btn-primary',
                    action: function() {
                        var values = [];
                        $('#tb-rows tr').each(function() {
                            values.push({
                                Account: $(this).find('#td-Account').data('value'),
                                Description: $(this).find('#td-Description').data('value'),
                                Debit: $(this).find('#td-Debit').data('value'),
                                Credit: $(this).find('#td-Credit').data('value'),
                                CostCenter: $(this).find('#td-Costcenter').data('value'),
                                Project: $(this).find('#td-Project').data('value')
                            });
                        });
                        var voucher = $('#frm-Voucher').serialize();
                        $.ajax({
                            type: "post",
                            url: "/api/acc/idocuments/UpdateGeneralLedger",
                            data: voucher + '&Data=' + JSON.stringify(values) + '&isNew=' + VoucherStatus,
                            success: function(response) {
                                if (response.Status == true) { // Error
                                    exDocumentError(response);
                                    return;
                                }
                                $('#txt-VoucherNo').text(response.VoucherNo);
                                $('#OperationKey').val(response.OperationKey);
                                $('#inf-Status').removeClass('bg-info').addClass('bg-warning text-dark');
                                $('#txt-Status').text(iShll.update || 'Update');
                                opk = response.OperationKey;
                                VoucherStatus = false;
                                $.alert({ title: 'Success', content: 'Document saved successfully!', type: 'green' });
                            }
                        });
                    }
                },
                Cancel: {}
            }
        });
    }
</script>