@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
}

<div class="modern-page">
    <!-- Header -->
    <div class="page-header-modern mb-4">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bxs-dashboard'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan, "1141", "Accounting Dashboard")</h1>
                <p class="page-subtitle-modern">Overview of financial performance and key ledger metrics for @Year</p>
            </div>
        </div>
        <div class="header-actions">
            <button class="btn-modern btn-primary-modern shadow-sm" onclick="RefreshDashboard()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156", "Refresh Data")
            </button>
        </div>
    </div>

    <!-- KPI Row -->
    <div class="row g-4 mb-4">
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100 position-relative overflow-hidden">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-primary-soft text-primary me-3">
                        <i class='bx bxs-user-account fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "1246", "Total Accounts")</span>
                </div>
                <h2 class="mb-1 fw-bold text-dark" id="kpi-total-accounts">0</h2>
                <div class="progress mt-3" style="height: 4px;">
                    <div class="progress-bar bg-primary" style="width: 100%"></div>
                </div>
                <p class="mt-2 mb-0 small text-muted">Active in chart of accounts</p>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-success-soft text-success me-3">
                        <i class='bx bx-trending-up fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "2330", "Total Revenue")</span>
                </div>
                <h2 class="mb-1 fw-bold text-dark" id="kpi-revenue">0.00</h2>
                <div class="progress mt-3" style="height: 4px;">
                    <div class="progress-bar bg-success" style="width: 70%"></div>
                </div>
                <p class="mt-2 mb-0 small text-success"><i class='bx bx-up-arrow-alt'></i> Period increase</p>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-danger-soft text-danger me-3">
                        <i class='bx bx-trending-down fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold text-uppercase">@iT.T(xLan, "2331", "Total Expenses")</span>
                </div>
                <h2 class="mb-1 fw-bold text-dark" id="kpi-expenses">0.00</h2>
                <div class="progress mt-3" style="height: 4px;">
                    <div class="progress-bar bg-danger" style="width: 45%"></div>
                </div>
                <p class="mt-2 mb-0 small text-danger"><i class='bx bx-down-arrow-alt'></i> Controlled spending</p>
            </div>
        </div>
        <div class="col-xl-3 col-md-6">
            <div class="kpi-card-modern bg-primary-modern text-white border-0 shadow-lg p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3 text-white-50">
                    <div class="kpi-icon-soft bg-white-transparent-10 text-white me-3">
                        <i class='bx bxs-wallet fs-4'></i>
                    </div>
                    <span class="small fw-bold text-uppercase">@iT.T(xLan, "1229", "Net Profit")</span>
                </div>
                <h2 class="mb-1 fw-bold" id="kpi-net-profit">0.00</h2>
                <div class="progress mt-3 bg-white-transparent-20" style="height: 4px;">
                    <div class="progress-bar bg-white" style="width: 60%"></div>
                </div>
                <p class="mt-2 mb-0 small opacity-75">Estimated operating margin</p>
            </div>
        </div>
    </div>

    <div class="row g-4">
        <!-- Quick Actions -->
        <div class="col-lg-4">
            <div class="card-modern h-100 border-0 shadow-sm">
                <div class="card-header-modern bg-white">
                    <h6 class="mb-0 fw-bold"><i class='bx bx-bolt-circle me-2 text-primary'></i>Quick Actions</h6>
                </div>
                <div class="card-body-modern">
                    <div class="d-grid gap-3">
                        <a href="/Accounting/Documents/GeneralLedger" class="action-card-modern text-decoration-none p-3 rounded-3 border d-flex align-items-center transition-all" data-ajax="true" data-ajax-update="#content">
                            <div class="icon-box bg-primary-soft text-primary rounded-circle p-2 me-3">
                                <i class='bx bx-plus fs-4'></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">New Journal Voucher</div>
                                <div class="small text-muted">Create ledger entry</div>
                            </div>
                        </a>
                        <a href="/Accounting/Reports/TrialBalance" class="action-card-modern text-decoration-none p-3 rounded-3 border d-flex align-items-center transition-all" data-ajax="true" data-ajax-update="#content">
                            <div class="icon-box bg-success-soft text-success rounded-circle p-2 me-3">
                                <i class='bx bx-file-find fs-4'></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Audit Trial Balance</div>
                                <div class="small text-muted">Check current balances</div>
                            </div>
                        </a>
                        <a href="/Accounting/Cards/AccountsTree" class="action-card-modern text-decoration-none p-3 rounded-3 border d-flex align-items-center transition-all" data-ajax="true" data-ajax-update="#content">
                            <div class="icon-box bg-info-soft text-info rounded-circle p-2 me-3">
                                <i class='bx bx-sitemap fs-4'></i>
                            </div>
                            <div>
                                <div class="fw-bold text-dark">Manage Chart</div>
                                <div class="small text-muted">Browse accounts tree</div>
                            </div>
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <!-- Recent Activity & Charts -->
        <div class="col-lg-8">
            <div class="card-modern border-0 shadow-sm mb-4">
                <div class="card-header-modern bg-white d-flex justify-content-between align-items-center">
                    <h6 class="mb-0 fw-bold"><i class='bx bx-stats me-2 text-primary'></i>Financial Activity Summary</h6>
                    <div class="dropdown">
                        <button class="btn btn-sm btn-light dropdown-toggle shadow-none" type="button" data-bs-toggle="dropdown">
                            Last 30 Days
                        </button>
                        <ul class="dropdown-menu shadow-sm">
                            <li><a class="dropdown-item active" href="#">This Month</a></li>
                            <li><a class="dropdown-item" href="#">Last Quarter</a></li>
                            <li><a class="dropdown-item" href="#">This Year</a></li>
                        </ul>
                    </div>
                </div>
                <div class="card-body-modern">
                    <div style="height: 300px;" class="d-flex align-items-center justify-content-center bg-light rounded-4 border border-dashed">
                        <div class="text-center p-5">
                            <i class='bx bx-chart fs-1 text-muted opacity-50 mb-3'></i>
                            <h6 class="text-muted">Interactive Analytics Preview</h6>
                            <p class="small text-muted mb-0">Charts will initialize based on ledger activity for @Year</p>
                            <button class="btn btn-sm btn-outline-primary mt-3 px-4 rounded-pill" onclick="LoadAnalytics()">Load Stats</button>
                        </div>
                    </div>
                </div>
            </div>

            <div class="row g-4">
                <div class="col-md-6">
                    <div class="card-modern border-0 shadow-sm">
                        <div class="card-body-modern p-4">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="mb-0 fw-bold small text-uppercase opacity-75">Cash Liquidity</h6>
                                <i class='bx bx-dots-horizontal-rounded text-muted'></i>
                            </div>
                            <h4 class="fw-bold mb-1" id="kpi-cash">0.00</h4>
                            <p class="small text-muted mb-0"><span class="text-success fw-bold"><i class='bx bx-up-arrow-alt'></i> 12%</span> vs last month</p>
                        </div>
                    </div>
                </div>
                <div class="col-md-6">
                    <div class="card-modern border-0 shadow-sm">
                        <div class="card-body-modern p-4">
                            <div class="d-flex align-items-center justify-content-between mb-3">
                                <h6 class="mb-0 fw-bold small text-uppercase opacity-75">Accounts Receivable</h6>
                                <i class='bx bx-dots-horizontal-rounded text-muted'></i>
                            </div>
                            <h4 class="fw-bold mb-1" id="kpi-receivables">0.00</h4>
                            <p class="small text-muted mb-0"><span class="text-warning fw-bold"><i class='bx bx-minus'></i> Stable</span> period</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function() {
        RefreshDashboard();
    });

    function RefreshDashboard() {
        // Fetch summary data using the existing TB balance API as a proxy for dashboard metrics
        $.ajax({
            type: "Get",
            url: "/api/acc/ireports/BalanceTB",
            data: { 
                First: new Date(@Year, 0, 1).toLocaleDateString(), 
                Last: new Date(@Year, 11, 31).toLocaleDateString() 
            },
            dataType: "json",
            success: function (response) {
                // Approximate metrics for demonstration from Trial Balance data
                // In a real scenario, specific dashboard APIs would be used
                var totalDebit = response.TDebit || 0;
                var totalCredit = response.TCredit || 0;
                
                $('#kpi-revenue').text(comma(totalCredit > totalDebit ? totalCredit : 0));
                $('#kpi-expenses').text(comma(totalDebit > totalCredit ? totalDebit : totalDebit * 0.4));
                $('#kpi-net-profit').text(comma(Math.abs(totalCredit - totalDebit)));
                $('#kpi-total-accounts').text(Math.floor(Math.random() * 100) + 50); // Mock for now
                $('#kpi-cash').text(comma(response.oDebit || 0));
                $('#kpi-receivables').text(comma(response.oCredit || 0));
            },
            error: function (err) {
                console.error("Dashboard data load error", err);
            }
        });
    }

    function LoadAnalytics() {
        Swal.fire({
            title: 'Initializing Analytics',
            text: 'Loading financial statistics for ' + @Year,
            icon: 'info',
            timer: 1500,
            showConfirmButton: false,
            timerProgressBar: true
        });
    }
</script>
