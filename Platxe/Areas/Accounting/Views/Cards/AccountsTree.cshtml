@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;

    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<div class="modern-page">
    <div class="page-header-modern">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-git-merge'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan, "1155", "Chart of Accounts Tree")</h1>
                <p class="page-subtitle-modern">Hierarchical view of your financial accounts and groupings</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156", "Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern" onclick="GetDetails(null)">
                <i class='bx bx-plus'></i> @iT.T(xLan, "1157", "Create New Account")
            </button>
        </div>
    </div>

    <div class="card-modern">
        <div id="widget"></div>
        <div class="card-body-modern p-0 modern-grid">
            @(
                Html.DevExtreme().TreeList<CLiAccounting.Cards.ChartofAccounts>().ID("grd-Accounts")
                    .ShowBorders(false)
                    .Width("100%")
                    .DataSource(d => d.WebApi()
                        .Controller("icards").Area("Accounting")
                        .Key("Key")
                        .LoadAction("ChartofAccount")
                        .InsertAction("CreateChartofAccount")
                        .OnBeforeSend("onBeforeSend")
                    )
                    .KeyExpr("Key")
                    .ParentIdExpr("ParentKey")
                    .DataStructure(TreeListDataStructure.Plain)
                    .ColumnAutoWidth(true)
                    .HoverStateEnabled(true)
                    .FocusedRowEnabled(true)
                    .Editing(editing =>
                    {
                        editing.Mode(GridEditMode.Row);
                        editing.AllowUpdating(false);
                        editing.AllowAdding(true);
                        editing.AllowDeleting(false);
                        editing.UseIcons(true);
                    })
                    .OnRowDblClick("rowDbClick")
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption("#").Width(100).AllowFiltering(false).CellTemplate(new JS("ct4Action")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(180).CssClass("fw-bold text-dark");
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).CssClass("fw-medium");
                        columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166", "English Name")).CssClass("text-secondary");
                        columns.AddFor(m => m.Level).Caption(iT.T(xLan, "1163", "Level")).Width(80).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Transactions).Caption(iT.T(xLan, "1161", "Trans.")).Width(80).CellTemplate(new JS("ct4Transactions")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Category).Caption(iT.T(xLan, "1162", "Category")).Width(110).Lookup(L => L.DataSource(iReplacer.accCategory(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Category"));
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                        sp.Placeholder("Search tree...");
                    })
                    .RowAlternationEnabled(true)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    .RtlEnabled(devRtl)
                    .OnToolbarPreparing("onToolbarPreparing")
                    .OnRowPrepared("OnRowPrepared")
                    .OnInitNewRow("onInitNewRow")
                )
        </div>
    </div>
</div>
<div id="mod-Account" class="modal"><div class="modal-dialog" id="con-Account"></div></div>
<div id="mod-Root" class="modal"><div class="modal-dialog" id="con-Root"></div></div>
<script class="append-on-ajax-script">

                let lastFocusedKey = null;
                let isLoadingCode = false;
                let newRowCodeValue = null;
                let NewLevel = null;
                let Parent = null;

        function xxxxx ()
        {
            return Document.title;
        }
    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        
        var editBtn = $('<button type="button" class="grid-action-btn" title="Edit"><i class="bx bx-edit-alt"></i></button>');
        editBtn.on('click', function() { 
            if (options.data.Level == 1) {
                $.alert({ title: 'Notice', content: "Cannot open root account here. Please use the root page to edit it.", type: 'blue' });
                return;
            }
            GetDetails(options.data.Key); 
        });

        var delBtn = $('<button type="button" class="grid-action-btn delete" title="Delete"><i class="bx bx-trash"></i></button>');
        delBtn.on('click', function() { DeleteRow(options.data.Key, options.data.Name1); });

        actionDiv.append(editBtn).append(delBtn);
        container.append(actionDiv);
    }
        function RefreshGrid ()
        {
            $('#grd-Accounts').dxTreeList("instance").refresh();
        }
        function GetDetails (Key)
        {
            $('#con-Account').empty();
            $("#con-Account").load('/Accounting/Cards/GetAccount?Key=' + Key);
            $("#mod-Account").modal({ backdrop: 'static' }).modal('toggle');
        }

        function GetDetailsRoot (Key)
        {
            $('#con-Root').empty();
            $("#con-Root").load('/Accounting/Cards/GetRoot?Key=' + Key);
            $("#mod-Root").modal({ backdrop: 'static' }).modal('toggle');
        }
        function DeleteRow (Key, Display)
        {
            $.confirm({
                title: 'Confirm',
                content: 'Are you sure to delete Account: ' + Display,
                type: 'red',
                buttons: {
                    Delete: {
                        text: 'Delete',
                        btnClass: 'btn-red',
                        action: function ()
                        {
                            $.ajax({
                                type: "Delete",
                                url: "/api/acc/icards/DeleteRoot",
                                data: { Key: Key },
                                dataType: "json",
                                success: function (response)
                                {
                                    if (response == 0)
                                    {
                                        $.alert({
                                            title: 'Stop',
                                            content: "Cannot delete account,It is have a child's",
                                        });
                                    } else
                                    {
                                        RefreshGrid();
                                    }
                                },
                                failure: function (response)
                                {
                                    alert(response);
                                },
                                error: function (response)
                                {
                                    alert(response.responseText);
                                }
                            });
                        }
                    },
                    Cancel: {
                        text: 'Cancel',
                        action: function ()
                        {
                            return;
                        }
                    }
                }
            });
        }
        function ct4Kind (container, options)
        {
            var str = '';
            switch (options.value)
            {
                case 0:
                    str = '<div class="text-center"><span class="badge bg-yellow text-dark">' + options.text + '</span></div>';
                    break;
                case 1:
                    str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                    break;
                case 2:
                    str = '<div class="text-center"><span class="badge bg-info text-dark">' + options.text + '</span></div>';
                    break;
                case 3:
                    str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                    break;
                case 4:
                    str = '<div class="text-center"><span class="badge bg-warning text-dark">' + options.text + '</span></div>';
                    break;
            }
            $(str).appendTo(container)
        }
        function ct4isParent (container, options)
        {
            var str = '';
            if (options.data.Level == 1)
            {
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                $(str).appendTo(container)
                return;
            }
            switch (options.value)
            {
                case false:
                    str = '<div class="text-center"><span class="badge bg-info">' + options.text + '</span></div>';
                    break;
                case true:
                    str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                    break;
            }
            $(str).appendTo(container);
        }
        function ct4Financial (container, options)
        {
            var str = '';
            switch (options.value)
            {
                case false:
                    str = '<div class="text-center"><span class="badge bg-default text-dark">' + options.text + '</span></div>';
                    break;
                case true:
                    str = '<div class="text-center"><span class="badge bg-yellow text-dark">' + options.text + '</span></div>';
                    break;
            }
            $(str).appendTo(container)
        }
        function ct4Status (container, options)
        {
            var str = '';
            switch (options.value)
            {
                case 0:
                    str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                    break;
                case 1:
                    str = '<div class="text-center"><span class="badge bg-success">' + options.text + '</span></div>';
                    break;
                case 2:
                    str = '<div class="text-center"><span class="badge bg-danger text-dark">' + options.text + '</span></div>';
                    break;
            }
            $(str).appendTo(container)
        }
        function ct4Transactions (container, options) {
            var val = options.value || 0;
            var text = options.text || '0';
            var wrapper = $('<div class="badge-modern"></div>').text(text);
            
            if (val > 0) {
                wrapper.css({ 'background-color': 'var(--erp-gray-soft)', 'color': '#0F172A', 'border': '1px solid var(--erp-border)' });
            } else {
                wrapper.css({ 'background-color': 'transparent', 'color': '#94A3B8', 'border': '1px solid transparent' });
            }
            $('<div class="w-100 text-center"></div>').append(wrapper).appendTo(container);
        }
        function ct4Category (container, options)
        {
            switch (options.value)
            {
                case 1:
                    container.append('<div>' + options.text + '</div>')
                        .css('color', '#CD4325');
                    break;
                default:
                    container.append('<div>' + options.text + '</div>')
                    break;
            }
        }
        function rowDbClick (e)
        {
            if (e.data.Level == 1)
            {
                GetDetailsRoot(e.data.Key);
            } else
            {
                GetDetails(e.data.Key);
            }
        }
        function GeneralToast(type, message) {

                    //https://js.devexpress.com/Documentation/ApiReference/UI_Components/dxToast/
                    //type success  info  error  warning

                    new DevExpress.ui.dxToast(document.getElementById("widget"), {
                        "width": "80vw", "displayAbsenceTypes": 2000, "message": message, "visible": true, "type": type, "maxWidth": 568,
                        "position": "top center', { at: 'bottom left', my: 'bottom left', offset: '20 -20'} (Android), { at: 'bottom center', my: 'bottom center', offset: '0 0' } (phones on Android)",
                    });

                }



         function onBeforeSend(method, ajaxOptions) {
            if (method === "insert") {
                let data = ajaxOptions.data.values
                    ? JSON.parse(ajaxOptions.data.values)
                    : ajaxOptions.data;

                const tree = $("#grd-Accounts").dxTreeList("instance");

                const focusedKey = tree.option("focusedRowKey");

                if (ajaxOptions.data.parentId !== undefined) {
                    data.ParentKey = ajaxOptions.data.parentId;
                } else if (focusedKey) {
                    const node = tree.getNodeByKey(focusedKey);
                    data.ParentKey = node ? node.key : null;
                    data.Level=NewParent;
                    data.Parent=NewParent;
                } else {
                    data.ParentKey = null;
                }

                ajaxOptions.data.ParentKey = data.ParentKey;
            }
        }

  

        function onToolbarPreparing(e) {
      
        const treeList = e.component;

           e.toolbarOptions.items = e.toolbarOptions.items.filter(item => {
            return item.name !== "addRowButton";
        });

        e.toolbarOptions.items.forEach(item => {
            if (item.name === "addRowButton") {
                item.options.onClick = function() {
                    const focusedRowKey = treeList.option("focusedRowKey");
                   
                    if (!focusedRowKey) {
                         GeneralToast('warning', 'Please select a row first');
                        return;
                    }

                };
            }
        });

    }




        function OnRowPrepared(e) {
            if (e.rowType !== "data") return;

            const treeList = e.component;
            const focusedRowKey = treeList.option("focusedRowKey");

      
            if (e.key !== focusedRowKey) return;

            if (lastFocusedKey === focusedRowKey) return;
            if (isLoadingCode) return;

            lastFocusedKey = focusedRowKey;
            isLoadingCode = true;

            const rowData = e.data;

            console.log("Focused Row Data:", rowData.Level);

           
            $.ajax({
                type: "get",
                url: "/api/acc/icards/AccountCode",
                data: { Parent: rowData.Code },
                dataType: "json",
                success: function (res) {

                    console.log("New Row Data:", res);

                    newRowCodeValue = res;
                    NewLevel        =rowData.Level+1;
                    NewParent        =rowData.Parent;
                },
                error: function (response) {
                    alert(response.responseText);
                },
                complete: function () {
                    isLoadingCode = false;
                }
            });
        }

           function onInitNewRow(e) {
            if (newRowCodeValue !== null) {
                    e.data.Code = newRowCodeValue;
                    e.data.Category = 0;
                    e.data.Level = NewLevel;
                    e.data.Parent = NewParent;
            }
            e.Cancel=true;
        }

    
</script>
    