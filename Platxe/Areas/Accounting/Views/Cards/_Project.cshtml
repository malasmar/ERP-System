@model CLiAccounting.Cards.Project
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content border-0 shadow-lg modern-modal-content">
    <div class="modal-header border-bottom-0 pb-0">
        <div class="d-flex align-items-center">
            <div class="bg-primary-soft p-2 rounded-3 me-3">
                <i class='bx bx-briefcase text-primary fs-4'></i>
            </div>
            <div>
                <h5 class="modal-title fw-bold mb-0">@iT.T(xLan,"1203","Project Card")</h5>
                <p class="text-muted small mb-0">Define and track project-specific accounting data</p>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <form id="frm-Project" data-parsley-validate="true" class="modern-form">
        <div class="modal-body p-4">
            @Html.HiddenFor(m => m.Key)
            
            <div class="row g-3">
                <!-- Basic Info -->
                <div class="col-md-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1164","Project Code")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Code).ID("cnt-Code").InputAttr("required", true).Placeholder("Unique project ID...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1183","Project Name (Local)")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true).Placeholder("Local display name...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1166","English Name")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2").Placeholder("International name...")
                    </div>
                </div>

                <div class="col-12"><hr class="my-2 opacity-10"></div>

                <!-- Timeline & Budget -->
                <div class="col-md-4">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1184","Contract Date")</label>
                        @Html.DevExtreme().DateBoxFor(m => m.ContractDate).Width("100%").ID("cnt-ContractDate").DisplayFormat("dd.MM.yyyy").Placeholder("Pick date")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1185","Start Date")</label>
                        @Html.DevExtreme().DateBoxFor(m => m.StartDate).Width("100%").ID("cnt-StartDate").DisplayFormat("dd.MM.yyyy").Placeholder("Pick date")
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1186","End Date")</label>
                        @Html.DevExtreme().DateBoxFor(m => m.EndDate).Width("100%").ID("cnt-EndDate").DisplayFormat("dd.MM.yyyy").Placeholder("Pick date")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1187","Contract Price")</label>
                        @Html.DevExtreme().NumberBoxFor(m => m.Price).Width("100%").ID("cnt-Price").ShowSpinButtons(true).Value(0).Min(0).Format("#,##0.##")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1973","Contact Person")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.ContactPerson).ID("cnt-ContactPerson").Placeholder("Name of contact...")
                    </div>
                </div>

                <div class="col-12"><hr class="my-2 opacity-10"></div>

                <!-- Contact & Notes -->
                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1189","Mobile Number")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Mobile).ID("cnt-Mobile").Placeholder("+000-00000000")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1190","Landline Phone")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Phone).ID("cnt-Phone").Placeholder("000-000000")
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1206","Project Address")</label>
                        @Html.DevExtreme().TextAreaFor(m => m.Address).ID("cnt-Address").Height(60).Placeholder("Location details...")
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1204","Internal Notes")</label>
                        @Html.DevExtreme().TextAreaFor(m => m.Note).ID("cnt-Note").Height(60).Placeholder("Any additional project details...")
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer border-top-0 pt-0 p-4">
            <button type="button" class="btn-modern btn-secondary-modern" data-bs-dismiss="modal">
                @iT.T(xLan,"1198","Cancel")
            </button>
            <button type="submit" class="btn-modern btn-primary-modern px-5">
                <i class='bx bx-save me-1'></i> @iT.T(xLan,"1197","Save Project")
            </button>
        </div>
    </form>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function() {
        $("#frm-Project").submit(function(event) {
            event.preventDefault();
            SaveProject();
        });
    });

    function SaveProject() {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Project Code!' });
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Project Name!' });
            return;
        }

        var data = $('#frm-Project').serialize();
        $.ajax({
            type: "POST",
            url: "/api/acc/icards/UpdateProject",
            data: data,
            dataType: "json",
            success: function(response) {
                $("#mod-Project").modal('hide');
                if (typeof RefreshGrid === "function") RefreshGrid();
            },
            error: function(response) {
                Swal.fire({ icon: 'error', title: 'Error', text: response.responseText || 'An error occurred while saving.' });
            }
        });
    }
</script>
