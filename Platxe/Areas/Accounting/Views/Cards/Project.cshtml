@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<div class="modern-page">
    <div class="page-header-modern">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-briefcase'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan,"1182","Projects")</h1>
                <p class="page-subtitle-modern">Track and manage project-specific accounting and dimensions</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156","Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern" onclick="GetDetails(null)">
                <i class='bx bx-plus'></i> @iT.T(xLan, "1171","Create New Item")
            </button>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Cards.Project>().ID("grd-Project")
                .ShowBorders(false)
                .Width("100%")
                .DataSource(d => d.WebApi()
                    .Controller("icards").Area("Accounting")
                    .Key("Key")
                    .LoadAction("Project"))
                .ColumnAutoWidth(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .Columns(columns =>
                {
                    columns.Add().Name("act").Caption("#").Width(100).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action")).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164","Code")).Width(120).CssClass("fw-bold text-dark");
                    columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1183","Project Name")).CssClass("fw-medium");
                    columns.AddFor(m => m.Name2).Caption(iT.T(xLan, "1166","English Name")).CssClass("text-secondary");
                    columns.AddFor(m => m.ContractDate).Caption(iT.T(xLan, "1184","Contract Date")).Width(110).Format("dd.MM.yyyy");
                    columns.AddFor(m => m.StartDate).Caption(iT.T(xLan, "1185","Start Date")).Width(110).Format("dd.MM.yyyy");
                    columns.AddFor(m => m.EndDate).Caption(iT.T(xLan, "1186","End Date")).Width(110).Format("dd.MM.yyyy");
                    columns.AddFor(m => m.Price).Caption(iT.T(xLan, "1187","Price")).Width(100).Format("#,##0.##");
                    columns.AddFor(m => m.ContactPerson).Caption(iT.T(xLan, "1188","Contact Person"));
                    columns.AddFor(m => m.Mobile).Caption(iT.T(xLan, "1189","Mobile"));
                    columns.AddFor(m => m.Phone).Caption(iT.T(xLan, "1190","Phone"));
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search projects...");
                })
                .RtlEnabled(devRtl)
            )
        </div>
    </div>
</div>
<div id="mod-Project" class="modal"><div class="modal-dialog" id="con-Project"></div></div>
<script class="append-on-ajax-script">
    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        
        var editBtn = $('<button type="button" class="grid-action-btn" title="Edit"><i class="bx bx-edit-alt"></i></button>');
        editBtn.on('click', function() { GetDetails(options.data.Key); });

        var delBtn = $('<button type="button" class="grid-action-btn delete" title="Delete"><i class="bx bx-trash"></i></button>');
        delBtn.on('click', function() { DeleteRow(options.data.Key, options.data.Name1); });

        actionDiv.append(editBtn).append(delBtn);
        container.append(actionDiv);
    }
    function RefreshGrid() {
        $('#grd-Project').dxDataGrid("instance").refresh();
    }
    function GetDetails(Key) {
        $('#con-Project').empty();
        $("#con-Project").load('/Accounting/Cards/ProjectDetails?Key=' + Key);
        $("#mod-Project").modal({ backdrop: 'static' }).modal('toggle');
    }
    function DeleteRow(Key, Display) {
        $.confirm({
            title: 'Confirm',
            content: 'Are you sure to delete Project: ' + Display,
            type: 'red',
            buttons: {
                Delete: {
                    text: 'Delete',
                    btnClass: 'btn-red',
                    action: function() {
                        $.ajax({
                            type: "Delete",
                            url: "/api/acc/icards/DeleteProject",
                            data: { Key: Key },
                            dataType: "json",
                            success: function(response) {
                                if (response == 0) {
                                    $.alert({
                                        title: 'Stop',
                                        content: "Cannot delete Project,It is have a child's",
                                    });
                                } else {
                                    RefreshGrid();
                                }
                            },
                            failure: function(response) {
                                alert(response);
                            },
                            error: function(response) {
                                alert(response.responseText);
                            }
                        });
                    }
                },
                Cancel: {
                    text: 'Cancel',
                    action: function() {
                        return;
                    }
                }
            }
        });
    }
</script>
