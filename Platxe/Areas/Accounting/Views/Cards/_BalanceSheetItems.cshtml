@model CLiAccounting.Cards.BalanceSheetItems
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}

<div class="modal-content border-0 shadow-lg modern-modal-content">
    <div class="modal-header border-bottom-0 pb-0">
        <div class="d-flex align-items-center">
            <div class="bg-primary-soft p-2 rounded-3 me-3">
                <i class='bx bx-list-check text-primary fs-4'></i>
            </div>
            <div>
                <h5 class="modal-title fw-bold mb-0">@iT.T(xLan,"1170","Balance Sheet Item")</h5>
                <p class="text-muted small mb-0">Define reporting structures for financial statements</p>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <form id="frm-BalanceSheetItems" data-parsley-validate="true" class="modern-form">
        <div class="modal-body p-4">
            @Html.HiddenFor(m => m.Key)
            
            <div class="row g-3">
                <div class="col-md-12">
                    <div class="form-group-modern mb-3">
                        <label class="form-label-modern required">@iT.T(xLan,"1172","Parent Item")</label>
                        @Html.DevExtreme().LookupFor(m => m.Parent).ID("cnt-Parent").DataSource(CLiAccounting.Selections.BalanceSheetItems.GetList(DB,xLan)).ValueExpr("Code").DisplayExpr("Display").Placeholder("Select parent category...").SearchEnabled(true)
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1164","Item Code")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Code).ID("cnt-Code").InputAttr("required", true).Placeholder("Unique identifier...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1158","Account Kind")</label>
                        @Html.DevExtreme().SelectBoxFor(m => m.Kind).ID("cnt-Kind").DataSource(iReplacer.accAccountKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Placeholder("Select kind...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1165","Account Name (Local)")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true).Placeholder("Local display name...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1166","English Name")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2").Placeholder("International name...")
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1011","Transaction Type")</label>
                        @Html.DevExtreme().SelectBoxFor(m => m.Transaction).ID("cnt-Transaction").DataSource(iReplacer.accBalanceItemKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Placeholder("Balance behavior...")
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer border-top-0 pt-0 p-4">
            <button type="button" class="btn-modern btn-secondary-modern" data-bs-dismiss="modal">@iT.T(xLan,"1198","Cancel")</button>
            <button type="submit" class="btn-modern btn-primary-modern px-5">
                <i class='bx bx-save me-1'></i> @iT.T(xLan,"1197","Save Item")
            </button>
        </div>
    </form>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function() {
        $("#frm-BalanceSheetItems").on("submit", function(event) {
            event.preventDefault();
            
            var code = $("#cnt-Code").dxTextBox("instance").option("value");
            var name = $("#cnt-Name1").dxTextBox("instance").option("value");
            
            if (!code || !name) {
                Swal.fire('Validation', 'Code and Name are required.', 'warning');
                return;
            }

            $.ajax({
                type: "POST",
                url: "/api/acc/icards/UpdateBalanceSheetItems",
                data: $(this).serialize(),
                success: function(response) {
                    $("#mod-BalanceSheetItems").modal('hide');
                    if (typeof RefreshGrid === "function") RefreshGrid();
                    if (typeof RefreshTree === "function") RefreshTree();
                    Swal.fire('Success', 'Item saved successfully.', 'success');
                },
                error: function(response) {
                    Swal.fire('Error', response.responseText || 'Failed to save item.', 'error');
                }
            });
        });
    });
</script>
