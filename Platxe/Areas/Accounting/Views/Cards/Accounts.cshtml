@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl = User.FindFirstValue("aiwLan") != "en";
}

<div class="modern-page animate__animated animate__fadeIn">
    <div class="page-header-modern mb-4">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-book-content'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan,"1155","Chart of Accounts")</h1>
                <p class="page-subtitle-modern">Financial ledger management and organization</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156","Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern shadow-sm" onclick="GetAccountDetails(null)">
                <i class='bx bx-plus'></i> @iT.T(xLan, "1157","New Account")
            </button>
        </div>
    </div>

    <div class="card-modern border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Cards.ChartofAccounts>().ID("grd-Accounts")
                .ShowBorders(false)
                .Width("100%")
                .DataSource(d => d.WebApi()
                    .Controller("icards").Area("Accounting")
                    .Key("Key")
                    .LoadAction("ChartofAccount")
                    .OnLoaded("onDataLoaded")
                )
                .ColumnAutoWidth(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                .Columns(columns =>
                {
                    columns.Add().Name("act").Caption("#").Width(100).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action")).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code")).Width(120).CssClass("fw-bold text-dark");
                    columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).CssClass("fw-medium");
                    columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "1158", "Kind")).Width(100).Lookup(L => L.DataSource(iReplacer.accAccountKind(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Kind")).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.isParent).Caption(iT.T(xLan, "1159", "Type")).Width(100).Lookup(L => L.DataSource(iReplacer.accParent(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4isParent")).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.Level).Caption(iT.T(xLan, "1163", "Level")).Width(70).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.ParentName1).Caption(iT.T(xLan, "1168", "Parent Account")).MinWidth(150).CssClass("text-muted small");
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search accounts...");
                })
                .RtlEnabled(devRtl)
            )
        </div>
    </div>
</div>

<div id="mod-Account" class="modal fade"><div class="modal-dialog modal-lg modal-dialog-centered" id="con-Account"></div></div>

<script class="append-on-ajax-script">
    function decodeHtml(html) {
        if (!html) return "";
        var txt = document.createElement("textarea");
        txt.innerHTML = html;
        return txt.value;
    }

    function onDataLoaded(data) {
        if (data && Array.isArray(data)) {
            data.forEach(function(item) {
                if (item.Name1) item.Name1 = decodeHtml(item.Name1);
                if (item.Name2) item.Name2 = decodeHtml(item.Name2);
                if (item.ParentName1) item.ParentName1 = decodeHtml(item.ParentName1);
            });
        }
    }

    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        var editBtn = $('<button type="button" class="grid-action-btn" title="Edit"><i class="bx bx-edit-alt"></i></button>');
        editBtn.on('click', function() { GetAccountDetails(options.data.Key); });
        var delBtn = $('<button type="button" class="grid-action-btn delete" title="Delete"><i class="bx bx-trash"></i></button>');
        delBtn.on('click', function() { DeleteAccount(options.data.Key, options.data.Name1); });
        actionDiv.append(editBtn).append(delBtn);
        container.append(actionDiv);
    }

    function RefreshGrid() {
        var grid = $("#grd-Accounts").dxDataGrid("instance");
        if(grid) grid.refresh();
    }

    function GetAccountDetails(Key) {
        $('#con-Account').empty();
        $("#con-Account").load('/Accounting/Cards/GetAccount?Key=' + Key, function() {
            $("#mod-Account").modal({ backdrop: 'static' }).modal('show');
        });
    }

    function DeleteAccount(Key, Display) {
        Swal.fire({
            title: 'Are you sure?',
            text: "Delete account: " + Display,
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            confirmButtonText: 'Yes, delete it!'
        }).then((result) => {
            if (result.isConfirmed) {
                $.ajax({
                    type: "Delete",
                    url: "/api/acc/icards/DeleteRoot",
                    data: { Key: Key },
                    success: function(response) {
                        if (response == 0) {
                            Swal.fire('Error', 'Cannot delete account with children.', 'error');
                        } else {
                            RefreshGrid();
                            Swal.fire('Deleted!', 'Account has been deleted.', 'success');
                        }
                    }
                });
            }
        });
    }

    function ct4Kind(container, options) {
        var badgeClass = 'badge-modern';
        switch (options.value) {
            case 0: badgeClass += ' badge-primary-modern'; break;
            case 1: badgeClass += ' badge-danger-modern'; break;
            case 2: badgeClass += ' badge-warning-modern'; break;
            case 3: badgeClass += ' badge-success-modern'; break;
            default: badgeClass += ' badge-primary-modern';
        }
        $('<div class="text-center"></div>').append($('<span class="' + badgeClass + '"></span>').text(options.text)).appendTo(container);
    }

    function ct4isParent(container, options) {
        var badgeClass = options.value ? 'badge-primary-modern' : 'badge-secondary-modern';
        var icon = options.value ? 'bx-folder' : 'bx-file';
        $('<div class="text-center"></div>').append($('<span class="badge-modern ' + badgeClass + '"><i class="bx ' + icon + ' me-1"></i>' + options.text + '</span>')).appendTo(container);
    }
</script>
