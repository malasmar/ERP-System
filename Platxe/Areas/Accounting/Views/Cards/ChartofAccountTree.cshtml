@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    bool devRtl = User.FindFirstValue("aiwLan") != "en";
}

<div class="modern-page animate__animated animate__fadeIn">
    <!-- Page Header -->
    <div class="page-header-modern mb-4">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-git-repo-forked'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan, "1177", "Chart of Account Tree")</h1>
                <p class="page-subtitle-modern">@iT.T(xLan, "1178", "Accounts") - @iT.T(xLan, "2024", "Interactive ledger hierarchy explorer")</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-outline-modern" onclick="RefreshTree()">
                <i class='bx bx-refresh me-1'></i> @iT.T(xLan, "1156", "Refresh")
            </button>
            <div class="btn-group shadow-sm rounded-3 overflow-hidden">
                <button type="button" class="btn btn-primary-modern border-end" onclick="ExpandAllNodes()" title="@iT.T(xLan, "1174", "Open All")">
                    <i class='bx bx-expand-alt'></i>
                </button>
                <button type="button" class="btn btn-primary-modern" onclick="CollapseAllNodes()" title="@iT.T(xLan, "1175", "Close All")">
                    <i class='bx bx-collapse-alt'></i>
                </button>
            </div>
        </div>
    </div>

    <!-- Tree Card -->
    <div class="card-modern border-0 shadow-sm rounded-4 overflow-hidden">
        <div class="card-header-modern bg-white border-bottom p-3 d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center gap-3">
                <h6 class="mb-0 fw-bold text-dark"><i class='bx bx-network-chart me-2 text-primary'></i>@iT.T(xLan, "1178", "Accounts Hierarchy")</h6>
                <div class="search-wrapper-modern d-none d-md-flex align-items-center">
                    <i class='bx bx-search text-muted'></i>
                    <input type="text" id="tree-search-input" class="form-control-modern" placeholder="@iT.T(xLan, "1179", "Search account...")" onkeyup="HandleTreeSearch(this.value)">
                </div>
            </div>
            <div class="header-badge">
                <span class="badge bg-primary-soft text-primary rounded-pill px-3" id="node-count">-- Nodes</span>
            </div>
        </div>
        
        <div class="card-body-modern p-0 modern-grid" style="min-height: 600px;">
            <div id="account-treelist"></div>
        </div>
    </div>
</div>

<style>
    .search-wrapper-modern {
        background: var(--erp-gray-soft);
        border-radius: 8px;
        padding: 4px 12px;
        width: 300px;
        border: 1px solid var(--erp-border);
        transition: all 0.2s;
    }
    .search-wrapper-modern:focus-within {
        background: #fff;
        border-color: var(--erp-primary);
        box-shadow: 0 0 0 3px rgba(var(--erp-primary-rgb), 0.1);
    }
    .form-control-modern {
        border: none;
        background: transparent;
        font-size: 0.875rem;
        padding: 4px 8px;
        width: 100%;
        outline: none;
    }
    .grid-action-btn-modern {
        width: 32px;
        height: 32px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        border-radius: 8px;
        border: 1px solid var(--erp-border);
        background: #fff;
        color: var(--erp-gray);
        transition: all 0.2s;
        text-decoration: none !important;
    }
    .grid-action-btn-modern:hover {
        background: var(--erp-gray-soft);
        color: var(--erp-primary);
        border-color: var(--erp-primary);
        transform: translateY(-1px);
    }
    .grid-action-btn-modern.edit:hover { background: var(--erp-primary-soft); color: var(--erp-primary); }
    .grid-action-btn-modern.view:hover { background: var(--erp-success-soft); color: var(--erp-success); }
    
    .badge-primary-soft {
        background-color: rgba(var(--erp-primary-rgb), 0.1);
        color: var(--erp-primary);
    }

    .dx-treelist-cell-expandable {
        display: flex;
        align-items: center;
    }
</style>

<script class="append-on-ajax-script">
    var treeListInstance = null;

    function decodeHtml(html) {
        if (!html) return "";
        var txt = document.createElement("textarea");
        txt.innerHTML = html;
        return txt.value;
    }

    function processTreeData(items) {
        if (!items) return;
        items.forEach(function(item) {
            item.text = decodeHtml(item.text);
            if (item.children) processTreeData(item.children);
        });
    }

    $(document).ready(function() {
        InitializeTreeList();
    });

    function InitializeTreeList() {
        var container = $("#account-treelist");
        
        // --- FIX AJAX RE-INITIALIZATION ---
        if (container.data("dxTreeList")) {
            container.dxTreeList("dispose");
            container.empty();
        }

        treeListInstance = container.dxTreeList({
            dataSource: new DevExpress.data.DataSource({
                load: function() {
                    var d = $.Deferred();
                    $.getJSON("/api/acc/icards/ChartOfAccountTree")
                        .done(function(data) {
                            processTreeData(data);
                            d.resolve(data);
                        })
                        .fail(function() { d.reject("Failed to load data"); });
                    return d.promise();
                }
            }),
            
            dataStructure: "tree",
            itemsExpr: "children",
            keyExpr: "id",
            
            expandedRowKeys: [],
            autoExpandAll: false,
            focusedRowEnabled: false, 
            hoverStateEnabled: true,

            showBorders: false,
            showRowLines: true,
            columnAutoWidth: true,
            wordWrapEnabled: false,
            allowColumnResizing: true,
            columnResizingMode: "nextColumn",
            
            loadPanel: { enabled: true, text: "@iT.T(xLan, "1100", "Loading Chart Of Accounts...")" },
            noDataText: "@iT.T(xLan, "2027", "No accounts found")",
            
            scrolling: { mode: "virtual" },
            height: "calc(100vh - 350px)",
            
            rtlEnabled: @(devRtl ? "true" : "false"),

            columns: [
                {
                    dataField: "text",
                    caption: "@iT.T(xLan, "1178", "Account Name")",
                    minWidth: 400,
                    cellTemplate: function(container, options) {
                        var hasChildren = options.data.children && options.data.children.length > 0;
                        var icon = hasChildren ? "bx bxs-folder text-warning" : "bx bxs-file text-primary";
                        var html = `<div class="d-flex align-items-center py-1">
                                        <i class='${icon} fs-4 me-3' style="width: 24px;"></i>
                                        <span class="${hasChildren ? 'fw-bold text-dark' : 'text-muted'}">${options.text}</span>
                                    </div>`;
                        container.append(html);
                    }
                },
                {
                    dataField: "id",
                    caption: "@iT.T(xLan, "1164", "Account Code")",
                    width: 160,
                    alignment: "center",
                    cssClass: "fw-bold text-muted small"
                },
                {
                    caption: "@iT.T(xLan, "1234", "Actions")",
                    width: 120,
                    alignment: "center",
                    cellTemplate: function(container, options) {
                        var actions = $('<div class="d-flex justify-content-center gap-2"></div>');
                        var viewBtn = $(`<a href="javascript:;" class="grid-action-btn-modern view" title="View"><i class='bx bx-show'></i></a>`);
                        viewBtn.on('click', function() { ViewAccount(options.data.id); });
                        var editBtn = $(`<a href="javascript:;" class="grid-action-btn-modern edit" title="Edit"><i class='bx bx-edit-alt'></i></a>`);
                        editBtn.on('click', function() { EditAccount(options.data.id); });
                        actions.append(viewBtn).append(editBtn);
                        container.append(actions);
                    }
                }
            ],
            
            onContentReady: function(e) {
                var count = e.component.getVisibleRows().length;
                $("#node-count").text(count + " @iT.T(xLan, "2025", "Nodes")");
            }
        }).dxTreeList("instance");

        console.log("TreeList initialized", treeListInstance);
    }

    // --- ACTIONS ---

    function HandleTreeSearch(val) {
        if (treeListInstance) treeListInstance.searchByText(val);
    }

    function RefreshTree() {
        if (treeListInstance) treeListInstance.refresh();
    }

    function ExpandAllNodes() {
        console.log("ExpandAllNodes called", treeListInstance);
        if (!treeListInstance) {
            console.error("TreeList instance not initialized");
            return;
        }
        treeListInstance.beginUpdate();
        treeListInstance.getRootNode().children.forEach(function(node) {
            expandRecursive(node);
        });
        treeListInstance.endUpdate();
    }

    function expandRecursive(node) {
        treeListInstance.expandRow(node.key);
        if (node.children && node.children.length) {
            node.children.forEach(function(child) {
                expandRecursive(child);
            });
        }
    }

    function CollapseAllNodes() {
        console.log("CollapseAllNodes called", treeListInstance);
        if (!treeListInstance) {
            console.error("TreeList instance not initialized");
            return;
        }
        treeListInstance.beginUpdate();
        treeListInstance.getRootNode().children.forEach(function(node) {
            collapseRecursive(node);
        });
        treeListInstance.endUpdate();
    }

    function collapseRecursive(node) {
        if (node.children && node.children.length) {
            node.children.forEach(function(child) {
                collapseRecursive(child);
            });
            treeListInstance.collapseRow(node.key);
        }
    }

    function ViewAccount(id) { console.log("View Account:", id); }
    function EditAccount(id) { console.log("Edit Account:", id); }
</script>
