@model CLiAccounting.Cards.CostCenter
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content border-0 shadow-lg modern-modal-content">
    <div class="modal-header border-bottom-0 pb-0">
        <div class="d-flex align-items-center">
            <div class="bg-primary-soft p-2 rounded-3 me-3">
                <i class='bx bx-calculator text-primary fs-4'></i>
            </div>
            <div>
                <h5 class="modal-title fw-bold mb-0">@iT.T(xLan,"1199","Cost Center Card")</h5>
                <p class="text-muted small mb-0">Configure departmental tracking and expense centers</p>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <form id="frm-CostCenter" data-parsley-validate="true" class="modern-form">
        <div class="modal-body p-4">
            @Html.HiddenFor(m => m.Key)
            
            <div class="row g-3">
                <div class="col-md-12">
                    <div class="form-group-modern mb-3">
                        <label class="form-label-modern required">@iT.T(xLan,"1172","Parent Center")</label>
                        @Html.DevExtreme().LookupFor(m => m.Parent).ID("cnt-Parent").InputAttr("required", true).DataSource(CLiAccounting.Selections.CostCenter.ParentLevel(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").Placeholder("Select parent...")
                    </div>
                    <hr class="my-4 opacity-10">
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1158","Category")</label>
                        @Html.DevExtreme().SelectBoxFor(m => m.Kind).ID("cnt-Kind").DataSource(iReplacer.finCostCenterKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").Placeholder("Select kind...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1011","Transaction Type")</label>
                        @Html.DevExtreme().SelectBoxFor(m => m.Transaction).ID("cnt-Transaction").DataSource(iReplacer.accBalanceItemKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").Placeholder("Balance behavior...")
                    </div>
                </div>

                <div class="col-md-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1164","Code")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Code).ID("cnt-Code").InputAttr("required", true).Placeholder("Unique identifier...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern required">@iT.T(xLan,"1181","Center Name (Local)")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true).Placeholder("Local display name...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1166","English Name")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2").Placeholder("International name...")
                    </div>
                </div>

                <div class="col-12">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1200","Notes & Comments")</label>
                        @Html.DevExtreme().TextAreaFor(m => m.Comment).ID("cnt-Comment").Height(80).Placeholder("Optional description...")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1201","Primary Phone")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Phone1).ID("cnt-Phone1").Width("100%").Placeholder("000-000000")
                    </div>
                </div>

                <div class="col-md-6">
                    <div class="form-group-modern">
                        <label class="form-label-modern">@iT.T(xLan,"1202","Secondary Phone")</label>
                        @Html.DevExtreme().TextBoxFor(m => m.Phone2).ID("cnt-Phone2").Width("100%").Placeholder("000-000000")
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer border-top-0 pt-0 p-4">
            <button type="button" class="btn-modern btn-secondary-modern" data-bs-dismiss="modal">
                @iT.T(xLan,"1198","Cancel")
            </button>
            <button type="submit" class="btn-modern btn-primary-modern px-5">
                <i class='bx bx-save me-1'></i> @iT.T(xLan,"1197","Save Center")
            </button>
        </div>
    </form>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function() {
        $("#frm-CostCenter").submit(function(event) {
            event.preventDefault();
            SaveCostCenter();
        });
    });

    function SaveCostCenter() {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Code!' });
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Cost Center Name!' });
            return;
        }

        var data = $('#frm-CostCenter').serialize();
        $.ajax({
            type: "POST",
            url: "/api/acc/icards/UpdateCostCenter",
            data: data,
            dataType: "json",
            success: function(response) {
                $("#mod-CostCenter").modal('hide');
                if (typeof RefreshGrid === "function") RefreshGrid();
            },
            error: function(response) {
                Swal.fire({ icon: 'error', title: 'Error', text: response.responseText || 'An error occurred while saving.' });
            }
        });
    }
</script>
