@model CLiAccounting.Cards.Account
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content border-0 shadow-lg modern-modal-content">
    <div class="modal-header border-bottom-0 pb-0">
        <div class="d-flex align-items-center">
            <div class="bg-primary-soft p-2 rounded-3 me-3">
                <i class='bx bx-book-content text-primary fs-4'></i>
            </div>
            <div>
                <h5 class="modal-title fw-bold mb-0">@iT.T(xLan,"1193","Account Card")</h5>
                <p class="text-muted small mb-0">Manage account ledger details and hierarchy</p>
            </div>
        </div>
        <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Close"></button>
    </div>

    <form id="frm-Account" data-parsley-validate="true" class="modern-form">
        <div class="modal-body p-4">
            @Html.HiddenFor(m => m.Key)
            @Html.HiddenFor(m => m.Source)
            
            <div class="row g-4">
                <!-- Left Column: Hierarchy & Parent Info -->
                <div class="col-lg-5">
                    <div class="card bg-light border-0 rounded-4 h-100">
                        <div class="card-body p-4">
                            <div class="form-group-modern mb-4">
                                <label class="form-label-modern required">@iT.T(xLan,"1172","Parent Account")</label>
                                @Html.DevExtreme().LookupFor(m => m.Parent).ID("cnt-Parent").InputAttr("required", true).DataSource(CLiAccounting.Selections.AccountsParentLevel.GetList(DB,xLan)).ValueExpr("Code").DisplayExpr("Display").Placeholder("Select parent...")
                            </div>

                            <div class="parent-summary-card p-3 bg-white rounded-3 border border-dashed shadow-sm">
                                <h6 class="text-primary small fw-bold mb-3 border-bottom pb-2">Parent Details Preview</h6>
                                <div class="row g-2">
                                    <div class="col-6"><div class="text-muted x-small">@iT.T(xLan,"1164","Code")</div><div class="fw-bold small" id="txt-Code">---</div></div>
                                    <div class="col-6"><div class="text-muted x-small">@iT.T(xLan,"1163","Level")</div><div class="fw-bold small" id="txt-Level">---</div></div>
                                    <div class="col-12 mt-2"><div class="text-muted x-small">@iT.T(xLan,"1165","Name")</div><div class="fw-bold small" id="txt-Name1">---</div></div>
                                    <div class="col-12"><div class="text-muted x-small">@iT.T(xLan,"1158","Type")</div><div class="fw-bold small text-info" id="txt-Kind">---</div></div>
                                </div>
                            </div>
                            
                            @if (Model.Key != null) {
                                <div class="mt-4 p-2 bg-dark rounded text-white x-small opacity-50 text-center">
                                    <i class='bx bx-key me-1'></i> @iT.T(xLan,"1299","System Key"): @Model.Key
                                </div>
                            }
                        </div>
                    </div>
                </div>

                <!-- Right Column: Account Configuration -->
                <div class="col-lg-7">
                    <div class="row g-3">
                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern required">@iT.T(xLan,"1164","Code")</label>
                                @Html.DevExtreme().TextBoxFor(m => m.Code).ID("cnt-Code").InputAttr("required", true).Placeholder("Enter code...")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern">@iT.T(xLan,"1194","Hierarchy Kind")</label>
                                @Html.DevExtreme().SelectBoxFor(m => m.IsParent).ID("cnt-IsParent").DataSource(iReplacer.accLevelKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").ReadOnly(Model.Source==true)
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-group-modern">
                                <label class="form-label-modern required">@iT.T(xLan,"1165","Account Name (Local)")</label>
                                @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true).Placeholder("Local display name...")
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="form-group-modern">
                                <label class="form-label-modern">@iT.T(xLan,"1166","English Name")</label>
                                @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2").Placeholder("International display name...")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern">@iT.T(xLan,"2323","DC Side")</label>
                                @Html.DevExtreme().SelectBoxFor(m => m.DC).ID("cnt-DC").DataSource(iReplacer.accDCKind(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").Placeholder("Select side...")
                            </div>
                        </div>

                        <div class="col-md-6">
                            <div class="form-group-modern">
                                <label class="form-label-modern">@iT.T(xLan,"1162","Category")</label>
                                @Html.DevExtreme().SelectBoxFor(m => m.Category).ID("cnt-Category").DataSource(iReplacer.accCategory(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").Placeholder("Select category...")
                            </div>
                        </div>

                        <div class="col-md-12">
                            <div class="form-group-modern">
                                <label class="form-label-modern">@iT.T(xLan,"1196","Transaction Type")</label>
                                @Html.DevExtreme().SelectBoxFor(m => m.Financial).ID("cnt-Financial").DataSource(iReplacer.accFinancial(xLan)).ValueExpr("Value").DisplayExpr("Display").Width("100%").ReadOnly(Model.Source==true || Model.IsParent==true).Placeholder("Integration type...")
                            </div>
                        </div>

                        <div class="col-12">
                            <div class="d-flex align-items-center p-3 bg-light rounded-3 mt-2">
                                @Html.DevExtreme().CheckBoxFor(m=>m.CloseSubAccounts).ID("chk-CloseSub")
                                <div class="ms-3">
                                    <label class="fw-bold small mb-0" for="chk-CloseSub">@iT.T(xLan,"","Closed Sub Accounts")</label>
                                    <p class="text-muted x-small mb-0">@iT.T(xLan,"2525","Enable integration group level for financial modules")</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="modal-footer border-top-0 pt-0 p-4">
            <button type="button" class="btn-modern btn-secondary-modern" data-bs-dismiss="modal">
                @iT.T(xLan,"1198","Cancel")
            </button>
            <button type="submit" class="btn-modern btn-primary-modern px-5">
                <i class='bx bx-save me-1'></i> @iT.T(xLan,"1197","Save Account")
            </button>
        </div>
    </form>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function () {
        $("#frm-Account").submit(function (event) {
            event.preventDefault();
            SaveAccount();
        });

        $('#cnt-Parent').dxLookup({
            onValueChanged: function (e) {
                ParentDetails(e.value, true);
            }
        });

        ParentDetails($('#cnt-Parent').dxLookup('option', 'value'), false);

        if ($('#Source').val() == 'True') {
            $('#cnt-Financial').dxSelectBox('option', 'readOnly', true);
        }
    });

    function SaveAccount() {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Account Code!' });
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "") {
            Swal.fire({ icon: 'warning', title: 'Validation', text: 'Please enter Account Name!' });
            return;
        }
        if ($('#cnt-Parent').dxLookup('option', 'text') == "" || $('#cnt-Parent').dxLookup('option', 'value') == null) {
            Swal.fire({ icon: 'error', title: 'Missing Parent', text: "Please select a parent account from the list." });
            return;
        }

        var data = $('#frm-Account').serialize();
        $.ajax({
            type: "POST",
            url: "/api/acc/icards/UpdateAccount",
            data: data,
            dataType: "json",
            success: function (response) {
                $("#mod-Account").modal('hide');
                if (typeof RefreshGrid === "function") RefreshGrid();
            },
            error: function (response) {
                Swal.fire({ icon: 'error', title: 'Execution Failed', text: response.responseText || 'Error saving account.' });
            }
        });
    }

    function ParentDetails(code, autocode) {
        if (!code) return;
        $.ajax({
            type: "get",
            url: "/api/acc/icards/AccountDetails",
            data: { Key: code },
            dataType: "json",
            success: function (response) {
                if (response != null) {
                    $('#txt-Code').text(response.Code);
                    $('#txt-Name1').text(response.Name1);
                    $('#txt-Name2').text(response.Name2 || '---');
                    $('#txt-Level').text(response.Level);
                    $('#txt-Kind').text(response.Kind);
                    if (autocode == true) {
                        $('#cnt-BalanceItem').dxSelectBox('option', 'value', response.BalanceItem);
                        $.ajax({
                            type: "get",
                            url: "/api/acc/icards/AccountCode",
                            data: { Parent: code },
                            dataType: "json",
                            success: function (res) {
                                $('#cnt-Code').dxTextBox('option', 'value', res);
                            },
                            error: function (err) { console.error("Code generation error", err); }
                        });
                    }
                }
            },
            error: function (err) { console.error("Parent details fetch error", err); }
        });
    }
</script>
