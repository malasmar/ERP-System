@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }
    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<h1 class="page-header">@iT.T(xLan,"1241","Full Yearly Statment")<small> @iT.T(xLan,"","")</small></h1>
<div class="panel panel-inverse">
    <div class="panel-body">
        <div class="row">
            <div class="col-lg-3 col-md-12">
                <div class="form-group row">
                    <label class="col-3 ">@iT.T(xLan, "1222","Year")</label>
                    <div class="col-9">
                        @Html.DevExtreme().NumberBox().ID("edYear").ShowSpinButtons(true).Width(130).Value(Year).OnValueChanged("ChangeYear")
                    </div>
                </div>
            </div>
            <div class="col-lg-4"></div>
            <div class="col-lg-5">
                <div class="card border-0 mb-1 bg-yellow text-dark acc">
                    <div class="card-body">
                        <div class="d-flex">
                            <h2 class="mb-0 me-2">@iT.T(xLan,"1227","Balance")<span id="txt-Balance">0.00</span></h2>
                        </div>
                        <hr class="bg-white-transparent-2 m-1 p-0">
                        <div class="text-truncate">
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>@iT.T(xLan, "1052","Debit Balance")</td><td id="txt-Debit"></td></tr>
                                    <tr><td>@iT.T(xLan, "1053","Credit Balance")</td><td id="txt-Credit"></td></tr>
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                <hr />
                <div class="btn-group">
                    <button type="button" class="btn btn-primary btn-sm" onclick="RefreshGrid()">@iT.T(xLan, "1156","Refresh")</button>
                </div>
            </div>
        </div>
        <div class="row">
            <div class="col-12">
                @(Html.DevExtreme().DataGrid<CLiAccounting.Reports.ParentStatment>().ID("grd-CurrentAccount")
                    .ShowBorders(true).Width("100%")
                    .DataSource(d => d.WebApi()
                    .Controller("ireports").Area("Accounting")
                    .Key("Key")
                    .LoadAction("YearlyStatment")
                    .LoadParams(new
                    {
                     Year=new JS("getYear")
                    })
                    )
                    .FocusedRowEnabled(true)
                    .ColumnAutoWidth(true)
                    .Columns(columns =>
                    {
                        columns.Add().Name("act").Caption(iT.T(xLan, "", "#")).Width(65).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action"));
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1164", "Code"));
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1216", "Name"));
                        columns.AddFor(m => m.DocumentKind).Caption(iT.T(xLan, "1975", "DocumentKind")).Width(110).Lookup(L => L.DataSource(iReplacer.DocumentsName(xLan, true)).ValueExpr("Value").DisplayExpr("Display"));
                        columns.AddFor(m => m.Date).Caption(iT.T(xLan, "1210", "Date")).Width(100).Format("dd.MM.yyyy");
                        columns.AddFor(m => m.No).Caption(iT.T(xLan, "1265", "No")).Width(80);
                        columns.AddFor(m => m.Description).Caption(iT.T(xLan, "1212", "Description")).Width("100%").MinWidth(180).CellTemplate(new JS("ct4Description"));
                        columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.DebitBalance).Caption(iT.T(xLan, "1052", "Debit Balance")).Width(100).Format("0,###.##");
                        columns.AddFor(m => m.CreditBalance).Caption(iT.T(xLan, "1053", "Credit Balance")).Width(100).Format("0,###.##");
                    })
                    .Summary(tot =>
                    {
                        tot.TotalItems(item =>
                        {
                            item.AddFor(m => m.DocumentKind).SummaryType(SummaryType.Count);
                            item.AddFor(m => m.Debit).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                            item.AddFor(m => m.Credit).SummaryType(SummaryType.Sum).ValueFormat("0,###.##");
                        });
                        tot.Texts(txt => { txt.Sum(""); });
                    })
                    .Pager(pg =>
                    {
                        pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                        pg.ShowNavigationButtons(true);
                        pg.ShowPageSizeSelector(true);
                        pg.ShowInfo(true);
                        pg.InfoText("{0} of {1} | {2} Rows");
                    })
                    .Paging(p => { p.PageSize(50); })
                    .FilterRow(f => f.Visible(true))
                    .HeaderFilter(f => f.Visible(true))
                    .SearchPanel(sp =>
                    {
                        sp.Width(250);
                        sp.Visible(true);
                    })
                    .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "1241", "Full Yearly Statment")))
                    .RowAlternationEnabled(true)
                    .RtlEnabled(devRtl)
                    .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                    )
            </div>
        </div>
    </div>
</div>
<script class="append-on-ajax-script">
    function ct4Action (container, options)
    {
        $('<div>').appendTo(container).dxMenu({
            items: [
                { icon: 'edit' },
                { icon: 'tips' }
            ],
            showFirstSubmenuMode: 'onClick',
            hideSubmenuOnMouseLeave: false,
            onItemClick: function (e)
            {
                switch (e.itemIndex)
                {
                    case 0:
                        if (e.itemData.icon == 'tips')
                        {
                            GetDetails(options.data.Key);
                        }
                        break;
                }
            },
        });
    }
    function RefreshGrid ()
    {
        $('#grd-CurrentAccount').dxDataGrid("instance").refresh().done(function ()
        {
            var debit = 0;
            var credit = 0;
            var balance = 0;
            var dataGridInstance = $('#grd-CurrentAccount').dxDataGrid("instance");
            debit = dataGridInstance.getTotalSummaryValue('Debit');
            credit = dataGridInstance.getTotalSummaryValue('Credit');
            balance = debit - credit;
            $('#txt-Debit').text(comma(debit));
            $('#txt-Credit').text(comma(credit));
            $('#txt-Balance').text(comma(balance));
        });
    }
    function getYear(){
        return $('#edYear').dxNumberBox('option','value');
    }
    function ChangeYear ()
    {
       RefreshGrid();
    }
    function ct4Description (container, options)
    {
        var str = '';
        str = '<p class="m-0 p-0 f-s-10" style="white-space:normal;">' + options.value + '</p>';
        $(str).appendTo(container)
    }
</script>
