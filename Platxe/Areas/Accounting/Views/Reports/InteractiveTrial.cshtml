@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }
    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<div class="modern-page">
    <div class="page-header-modern">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-git-branch'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan,"1237","Interactive Trial Balance")</h1>
                <p class="page-subtitle-modern">Drill-down interactive trial balance for hierarchical financial analysis</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156","Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern" onclick="window.print()">
                <i class='bx bx-printer'></i> @iT.T(xLan, "1361","Print")
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-7">
            <div class="card-modern h-100">
                <div class="card-header-modern">
                    <h6 class="mb-0 fw-bold"><i class='bx bx-filter-alt me-2'></i>Report Filters</h6>
                </div>
                <div class="card-body-modern">
                    <div class="row g-3">
                        <div class="col-md-4">
                            <label class="form-label small text-muted">@iT.T(xLan, "1222","Year")</label>
                            @Html.DevExtreme().NumberBox().ID("edYear").ShowSpinButtons(true).Width("100%").Value(Year).OnValueChanged("ChangeYear")
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">@iT.T(xLan, "1224","First Date")</label>
                            @Html.DevExtreme().DateBox().ID("edFirstDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,1,1))
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">@iT.T(xLan, "1225","Last Date")</label>
                            @Html.DevExtreme().DateBox().ID("edLastDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,12,31))
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="card-modern h-100 bg-primary-modern text-white">
                <div class="card-body-modern p-4">
                    <div class="row g-4 h-100 align-items-center">
                        <div class="col-12 border-bottom border-white-10 pb-3 mb-2">
                             <p class="text-white-50 small mb-0">@iT.T(xLan,"1007","Opening Balance")</p>
                             <div class="d-flex justify-content-between align-items-baseline">
                                 <h3 class="mb-0" id="txt-TotalTrial">0.00</h3>
                                 <div class="small opacity-75">
                                     DR: <span id="txt-oDebit">0.00</span> | CR: <span id="txt-oCredit">0.00</span>
                                 </div>
                             </div>
                        </div>
                        <div class="col-6">
                            <p class="text-white-50 small mb-1">@iT.T(xLan,"1011","Transactions")</p>
                            <div class="small mb-1">DR: <span class="fw-bold" id="txt-tDebit">0.00</span></div>
                            <div class="small">CR: <span class="fw-bold" id="txt-tCredit">0.00</span></div>
                        </div>
                        <div class="col-6 border-start border-white-10">
                            <p class="text-white-50 small mb-1">@iT.T(xLan,"1227","Closing Balance")</p>
                            <div class="small mb-1">DR: <span class="fw-bold" id="txt-bDebit">0.00</span></div>
                            <div class="small">CR: <span class="fw-bold" id="txt-bCredit">0.00</span></div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Reports.TrialBalance>().ID("grd-TrialBalance")
                .ShowBorders(false)
                .Width("100%")
                .ColumnAutoWidth(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .Columns(c =>
                {
                    c.Add().Name("act").Caption("#").Width(70).CellTemplate(new JS("ct4Action")).AllowExporting(false).Fixed(true).FixedPosition((HorizontalEdge)devFixd).Alignment(HorizontalAlignment.Center);
                    
                    c.Add().Caption("Account Details").Columns(columns =>
                    {
                        columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "1158", "Kind")).Width(90).Lookup(L => { L.DataSource(iReplacer.accAccountKind(xLan)).ValueExpr("Value").DisplayExpr("Display"); }).CellTemplate(new JS("ct4Kind")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.T).Caption(iT.T(xLan, "1161", "Trans.")).Width(90).Lookup(L => { L.DataSource(iReplacer.accTransaction(xLan)).ValueExpr("Value").DisplayExpr("Display"); }).CellTemplate(new JS("ct4T")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Level).Caption(iT.T(xLan, "1163", "Lv.")).Width(60).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1228", "Code")).Width(120).CssClass("fw-bold text-dark");
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).CssClass("fw-medium");
                    });

                    c.Add().Caption(iT.T(xLan, "1007", "Opening")).Columns(columns =>
                    {
                        columns.AddFor(m => m.oDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##");
                        columns.AddFor(m => m.oCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##");
                    });

                    c.Add().Caption(iT.T(xLan, "1011", "Period Transactions")).Columns(columns =>
                    {
                        columns.AddFor(m => m.tDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##");
                        columns.AddFor(m => m.tCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##");
                        columns.AddFor(m => m.tbDebit).Caption(iT.T(xLan, "1052", "DR Bal.")).Width(110).Format("#,##0.##");
                        columns.AddFor(m => m.tbCredit).Caption(iT.T(xLan, "1053", "CR Bal.")).Width(110).Format("#,##0.##");
                    });

                    c.Add().Caption(iT.T(xLan, "1227", "Closing Balance")).Columns(columns =>
                    {
                        columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##").CssClass("fw-bold");
                        columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##").CssClass("fw-bold");
                    });
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search results...");
                })
                .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "1237", "Analytical Trial Balance")))
                .RtlEnabled(devRtl)
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
            )
        </div>
    </div>
</div>
<div id="mod-xInteractiveTrial" class="modal fade modern-modal" tabindex="-1" role="dialog">
    <div class="modal-dialog modal-xl modal-dialog-centered" role="document">
        <div class="modal-content border-0 shadow-lg" id="con-xInteractiveTrial"></div>
    </div>
</div>
<script class="append-on-ajax-script">
    var TrialBalanceData;
    var data;
    $(document).ready(function ()
    {
        LoadDash();
    })
    async function LoadDash ()
    {
        $.ajax({
            type: "Get",
            url: "/api/acc/ixreports/TrialBalance",
            data: { First: getFirst(), Last: getLast() },
            dataType: "json",
            success: function (response)
            {
                TrialBalanceData = response;
                var LevelOneTB = response.filter(function (el)
                {
                    return el.Level == 1;
                });
                $('#grd-TrialBalance').dxDataGrid({
                    dataSource: LevelOneTB
                });
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
        $.ajax({
            type: "Get",
            url: "/api/acc/ireports/BalanceTB",
            data: { First: getFirst(), Last: getLast() },
            dataType: "json",
            success: function (response)
            {
                $('#txt-oDebit').text(comma(response.oDebit));
                $('#txt-oCredit').text(comma(response.oCredit));
                $('#txt-oBalance').text(comma(response.oDebit - response.oCredit));
                $('#txt-tDebit').text(comma(response.TDebit));
                $('#txt-tCredit').text(comma(response.TCredit));
                $('#txt-tBalance').text(comma(response.TDebit - response.TCredit));
                $('#txt-bDebit').text(comma(response.oDebit + response.TDebit));
                $('#txt-bCredit').text(comma(response.oCredit + response.TCredit));
                $('#txt-bBalance').text(comma((response.oDebit + response.TDebit) - (response.oCredit + response.TCredit)));
                $('#txt-TotalTrial').text(comma(response.oDebit + response.TDebit));
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        
        var drillBtn = $('<button type="button" class="grid-action-btn drill" title="Drill Down"><i class="bx bx-chevron-down-circle"></i></button>');
        drillBtn.on('click', function() { 
            data = options.data;
            $('#con-xInteractiveTrial').empty().html('<div class="p-5 text-center"><div class="spinner-border text-primary" role="status"></div><p class="mt-2">Loading drill-down data...</p></div>');
            $("#con-xInteractiveTrial").load('/Accounting/Reports/xInteractiveTrial?Code=' + options.data.Code, function() {
                $("#mod-xInteractiveTrial").modal('show');
            });
        });

        actionDiv.append(drillBtn);
        container.append(actionDiv);
    }
    function RefreshGrid ()
    {
        LoadDash();
        $('#grd-TrialBalance').dxDataGrid("instance").refresh();
    }
    function getYear ()
    {
        return $('#edYear').dxNumberBox('option', 'value')
    }
    function getFirst ()
    {
        var fd = new Date($('#edFirstDate').dxDateBox('option', 'value'));
        return fd.toLocaleDateString();
    }
    function getLast ()
    {
        var ld = new Date($('#edLastDate').dxDateBox('option', 'value'));
        return ld.toLocaleDateString();
    }
    function ChangeYear ()
    {
        $('#edFirstDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 0, 1));
        $('#edLastDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 11, 31));
    }
    function ct4Kind (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge bg-yellow text-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
                break;
            case 2:
                str = '<div class="text-center"><span class="badge bg-info text-dark">' + options.text + '</span></div>';
                break;
            case 3:
                str = '<div class="text-center"><span class="badge bg-success text-dark">' + options.text + '</span></div>';
                break;
            case 4:
                str = '<div class="text-center"><span class="badge bg-warning text-dark">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ct4T (container, options)
    {
        var str = '';
        if (options.data.Level == 1)
        {
            str = '<div class="text-center"><span class="badge bg-danger">' + options.text + '</span></div>';
            $(str).appendTo(container)
            return;
        }
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge bg-info">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge bg-gray">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container);
    }
</script>
