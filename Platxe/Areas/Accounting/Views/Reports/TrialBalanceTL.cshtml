@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }
    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>

<div class="modern-page">
    <div class="page-header-modern">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-list-ul'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan,"1006","Trial Balance")</h1>
                <p class="page-subtitle-modern">@iT.T(xLan,"1233","Transaction Level") - Detailed analytical view of all account movements</p>
            </div>
        </div>
        
        <div class="header-actions">
            <button type="button" class="btn-modern btn-primary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156","Refresh")
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-4">
            <div class="card-modern h-100">
                <div class="card-header-modern">
                    <h6 class="mb-0 fw-bold"><i class='bx bx-filter-alt me-2'></i>Report Filters</h6>
                </div>
                <div class="card-body-modern">
                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label small text-muted">@iT.T(xLan, "1222","Year")</label>
                            @Html.DevExtreme().NumberBox().ID("edYear").ShowSpinButtons(true).Width("100%").Value(Year).OnValueChanged("ChangeYear")
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-muted">@iT.T(xLan, "1224","First Date")</label>
                            @Html.DevExtreme().DateBox().ID("edFirstDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,1,1))
                        </div>
                        <div class="col-md-6">
                            <label class="form-label small text-muted">@iT.T(xLan, "1225","Last Date")</label>
                            @Html.DevExtreme().DateBox().ID("edLastDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,12,31))
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-lg-8">
            <div class="row g-3 h-100">
                <div class="col-md-4">
                    <div class="card-modern kpi-card-modern bg-primary-modern text-white border-0 h-100">
                        <div class="card-body-modern">
                            <p class="small opacity-75 mb-1">@iT.T(xLan,"1007","Opening")</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0 fw-bold" id="txt-oDebit">0.00</h4>
                                <span class="badge-modern bg-white-transparent-20 small">Dr</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="mb-0 fw-bold" id="txt-oCredit">0.00</h4>
                                <span class="badge-modern bg-white-transparent-20 small">Cr</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-modern kpi-card-modern bg-white h-100">
                        <div class="card-body-modern">
                            <p class="small text-muted mb-1">@iT.T(xLan, "1011","Transaction")</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0 fw-bold text-primary" id="txt-tDebit">0.00</h4>
                                <span class="badge-modern bg-primary-soft small text-primary">Dr</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="mb-0 fw-bold text-primary" id="txt-tCredit">0.00</h4>
                                <span class="badge-modern bg-primary-soft small text-primary">Cr</span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-md-4">
                    <div class="card-modern kpi-card-modern bg-success-soft h-100 border-0">
                        <div class="card-body-modern">
                            <p class="small text-success mb-1">@iT.T(xLan, "1227","Closing Balance")</p>
                            <div class="d-flex justify-content-between align-items-center mb-3">
                                <h4 class="mb-0 fw-bold text-success" id="txt-bDebit">0.00</h4>
                                <span class="badge-modern bg-success-soft small text-success">Dr</span>
                            </div>
                            <div class="d-flex justify-content-between align-items-center">
                                <h4 class="mb-0 fw-bold text-success" id="txt-bCredit">0.00</h4>
                                <span class="badge-modern bg-success-soft small text-success">Cr</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Reports.TrialBalance>().ID("grd-TrialBalance")
                .ShowBorders(false)
                .Width("100%")
                .DataSource(d => d.WebApi()
                .Controller("ireports").Area("Accounting")
                .Key("Code")
                .LoadAction("TrialBalance_TL")
                .LoadParams(new
                {
                    First = new JS("getFirst"),
                    Last = new JS("getLast")
                }))
                .ColumnAutoWidth(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .Columns(c =>
                {
                    c.Add().Caption("Account Info").Fixed(true).FixedPosition((HorizontalEdge)devFixd).Columns(columns =>
                    {
                        columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "1158", "Kind")).Width(80).Lookup(L => { L.DataSource(iReplacer.accAccountKind(xLan)).ValueExpr("Value").DisplayExpr("Display"); }).CellTemplate(new JS("ct4Kind")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.T).Caption(iT.T(xLan, "1161", "Trans.")).Width(80).Lookup(L => { L.DataSource(iReplacer.accTransaction(xLan)).ValueExpr("Value").DisplayExpr("Display"); }).CellTemplate(new JS("ct4T")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1228", "Code")).Width(100).CssClass("fw-bold");
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).MinWidth(200);
                    });
                    
                    c.Add().Caption(iT.T(xLan, "1007", "Opening")).Columns(columns =>
                    {
                        columns.AddFor(m => m.oDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##").CssClass("text-end");
                        columns.AddFor(m => m.oCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##").CssClass("text-end");
                    });
                    
                    c.Add().Caption(iT.T(xLan, "1011", "Transaction")).Columns(columns =>
                    {
                        columns.AddFor(m => m.tDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##").CssClass("text-end fw-medium");
                        columns.AddFor(m => m.tCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##").CssClass("text-end fw-medium");
                        columns.AddFor(m => m.tbDebit).Caption(iT.T(xLan, "1052", "Dr Bal.")).Width(110).Format("#,##0.##").Visible(true).CssClass("text-end text-muted small");
                        columns.AddFor(m => m.tbCredit).Caption(iT.T(xLan, "1053", "Cr Bal.")).Width(110).Format("#,##0.##").Visible(true).CssClass("text-end text-muted small");
                    });
                    
                    c.Add().Caption(iT.T(xLan, "1227", "Closing")).Columns(columns =>
                    {
                        columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.##").CssClass("text-end fw-bold text-primary");
                        columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.##").CssClass("text-end fw-bold text-primary");
                    });
                })
                .Summary(tot =>
                {
                    tot.TotalItems(item =>
                    {
                        item.AddFor(m => m.Code).SummaryType(SummaryType.Count);
                        item.AddFor(m => m.oDebit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.oCredit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.tDebit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.tCredit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.tbDebit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.tbCredit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.Debit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                        item.AddFor(m => m.Credit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##");
                    });
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search accounts...");
                })
                .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "1006", "Trial Balance")))
                .RtlEnabled(devRtl)
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
            )
        </div>
    </div>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function ()
    {
        LoadDash();
    })
    async function LoadDash ()
    {
        $.ajax({
            type: "Get",
            url: "/api/acc/ireports/BalanceTB",
            data: { First: getFirst(), Last: getLast() },
            dataType: "json",
            success: function (response)
            {
                $('#txt-oDebit').text(comma(response.oDebit));
                $('#txt-oCredit').text(comma(response.oCredit));
                $('#txt-tDebit').text(comma(response.TDebit));
                $('#txt-tCredit').text(comma(response.TCredit));
                $('#txt-bDebit').text(comma(response.oDebit + response.TDebit));
                $('#txt-bCredit').text(comma(response.oCredit + response.TCredit));
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
    function RefreshGrid ()
    {
        LoadDash();
        $('#grd-TrialBalance').dxDataGrid("instance").refresh();
    }
    function getFirst ()
    {
        var fd = new Date($('#edFirstDate').dxDateBox('option', 'value'));
        return fd.toLocaleDateString();
    }
    function getLast ()
    {
        var ld = new Date($('#edLastDate').dxDateBox('option', 'value'));
        return ld.toLocaleDateString();
    }
    function ChangeYear ()
    {
        $('#edFirstDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 0, 1));
        $('#edLastDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 11, 31));
    }
    function ct4Kind (container, options)
    {
        var str = '';
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge-modern bg-yellow-soft text-yellow-dark">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge-modern bg-danger-soft text-danger">' + options.text + '</span></div>';
                break;
            case 2:
                str = '<div class="text-center"><span class="badge-modern bg-info-soft text-info">' + options.text + '</span></div>';
                break;
            case 3:
                str = '<div class="text-center"><span class="badge-modern bg-success-soft text-success">' + options.text + '</span></div>';
                break;
            case 4:
                str = '<div class="text-center"><span class="badge-modern bg-warning-soft text-warning">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container)
    }
    function ct4T (container, options)
    {
        var str = '';
        if (options.data.Level == 1)
        {
            str = '<div class="text-center"><span class="badge-modern bg-danger-soft text-danger">' + options.text + '</span></div>';
            $(str).appendTo(container)
            return;
        }
        switch (options.value)
        {
            case 0:
                str = '<div class="text-center"><span class="badge-modern bg-info-soft text-info">' + options.text + '</span></div>';
                break;
            case 1:
                str = '<div class="text-center"><span class="badge-modern bg-secondary-soft text-secondary">' + options.text + '</span></div>';
                break;
        }
        $(str).appendTo(container);
    }
</script>
