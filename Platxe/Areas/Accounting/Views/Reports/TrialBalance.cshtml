@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}

<div class="modern-page">
    <!-- Breadcrumb & Header -->
    <div class="page-header-modern mb-4">
        <div class="header-left-modern">
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-2 small">
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">@iT.T(xLan,"1000","Accounting")</a></li>
                    <li class="breadcrumb-item"><a href="#" class="text-decoration-none text-muted">@iT.T(xLan,"1005","Reports")</a></li>
                    <li class="breadcrumb-item active fw-bold text-primary" aria-current="page">@iT.T(xLan,"1237","Analytical Trial Balance")</li>
                </ol>
            </nav>
            <div class="d-flex align-items-center">
                <div class="header-icon-modern">
                    <i class='bx bx-bar-chart-alt-2'></i>
                </div>
                <div>
                    <h1 class="page-title-modern">@iT.T(xLan,"1237","Analytical Trial Balance")</h1>
                    <p class="page-subtitle-modern text-muted">Summarized ledger balances and financial audit controls</p>
                </div>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()" title="Reload Data">
                <i class='bx bx-refresh'></i> @iT.T(xLan,"1156","Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern shadow-sm" onclick="PrintReport()">
                <i class='bx bx-printer'></i> @iT.T(xLan, "1361","Print Report")
            </button>
        </div>
    </div>

    <!-- Filter Section -->
    <div class="card-modern border-0 shadow-sm mb-4">
        <div class="card-header-modern bg-white d-flex align-items-center py-3">
            <h6 class="mb-0 fw-bold text-dark"><i class='bx bx-filter-alt me-2 text-primary'></i>@iT.T(xLan,"1221","Report Filters")</h6>
        </div>
        <div class="card-body-modern p-4">
            <div class="row g-4 align-items-end">
                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted mb-2">@iT.T(xLan,"1222","Year")</label>
                    @Html.DevExtreme().NumberBox().ID("edYear").ShowSpinButtons(true).Width("100%").Value(Year).OnValueChanged("ChangeYear")
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted mb-2">@iT.T(xLan,"1224","From Date")</label>
                    @Html.DevExtreme().DateBox().ID("edFirstDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,1,1)).OnValueChanged("RefreshGrid")
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted mb-2">@iT.T(xLan,"1225","To Date")</label>
                    @Html.DevExtreme().DateBox().ID("edLastDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,12,31)).OnValueChanged("RefreshGrid")
                </div>
                <div class="col-lg-2 col-md-4">
                    <label class="form-label small fw-bold text-muted mb-2">@iT.T(xLan,"1163","Account Level")</label>
                    @Html.DevExtreme().NumberBox().ID("edLevel").ShowSpinButtons(true).Width("100%").Min(0).Value(0).OnValueChanged("RefreshGrid")
                </div>
                <div class="col-lg-4 col-md-12">
                    <div class="d-flex gap-4 flex-wrap pb-2">
                        <div class="d-flex align-items-center">
                            @Html.DevExtreme().CheckBox().ID("ed-HideZero").Text(iT.T(xLan,"2690","Show Zero Balances")).Value(false).OnValueChanged("RefreshGrid")
                        </div>
                        <div class="d-flex align-items-center">
                            @Html.DevExtreme().CheckBox().ID("ed-ExpensesDetails").Text(iT.T(xLan,"2421","Show Expenses")).Value(false).OnValueChanged("RefreshGrid")
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Summary KPI Cards -->
    <div class="row g-4 mb-4">
        <div class="col-md-3">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-success-soft text-success me-3">
                        <i class='bx bx-plus-circle fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold">@iT.T(xLan,"1008","Total Debit")</span>
                </div>
                <h3 class="mb-0 fw-bold text-dark" id="txt-bDebit">0.00</h3>
                <div class="mt-2 small text-muted">Closing cumulative debit</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-danger-soft text-danger me-3">
                        <i class='bx bx-minus-circle fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold">@iT.T(xLan,"1009","Total Credit")</span>
                </div>
                <h3 class="mb-0 fw-bold text-dark" id="txt-bCredit">0.00</h3>
                <div class="mt-2 small text-muted">Closing cumulative credit</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-modern bg-white border-0 shadow-sm p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3">
                    <div class="kpi-icon-soft bg-primary-soft text-primary me-3">
                        <i class='bx bx-transfer fs-4'></i>
                    </div>
                    <span class="text-muted small fw-bold">@iT.T(xLan,"1011","Net Activity")</span>
                </div>
                <h3 class="mb-0 fw-bold text-dark" id="txt-TotalTrial">0.00</h3>
                <div class="mt-2 small text-muted">Opening + Transactions</div>
            </div>
        </div>
        <div class="col-md-3">
            <div class="kpi-card-modern bg-primary-modern text-white border-0 shadow-lg p-4 rounded-4 h-100">
                <div class="d-flex align-items-center mb-3 text-white-50">
                    <div class="kpi-icon-soft bg-white-transparent-10 text-white me-3">
                        <i class='bx bx-wallet fs-4'></i>
                    </div>
                    <span class="small fw-bold">@iT.T(xLan,"1227","Closing Diff.")</span>
                </div>
                <h3 class="mb-0 fw-bold" id="txt-bBalance">0.00</h3>
                <div class="mt-2 small opacity-75">Final period net balance</div>
            </div>
        </div>
    </div>

    <!-- Main Grid Card -->
    <div class="card-modern border-0 shadow-sm">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Reports.TrialBalance>().ID("grd-TrialBalance")
                .ShowBorders(false)
                .Width("100%")
                .DataSource(d => d.WebApi()
                .Controller("ireports").Area("Accounting")
                .Key("Row")
                .LoadAction("TrialBalance")
                .LoadParams(new
                {
                    First = new JS("getFirst"),
                    Last = new JS("getLast"),
                    Level = new JS("getLevel"),
                    ExpKind = new JS("getExpKind"),
                    HideZero = new JS("getHideZero")
                }))
                .FocusedRowEnabled(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .ColumnAutoWidth(true)
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
                .Columns(c =>
                {
                    c.Add().Name("act").Caption("#").Width(70).CellTemplate(new JS("ct4Action")).AllowExporting(false).Fixed(true).FixedPosition((HorizontalEdge)devFixd);
                    
                    c.Add().Caption(iT.T(xLan, "1273", "Account Details")).Columns(columns =>
                    {
                        columns.AddFor(m => m.Kind).Caption(iT.T(xLan, "1158", "Kind")).Width(90).Lookup(L => L.DataSource(iReplacer.accAccountKind(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4Kind")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.T).Caption(iT.T(xLan, "1161", "Trans.")).Width(90).Lookup(L => L.DataSource(iReplacer.accTransaction(xLan)).ValueExpr("Value").DisplayExpr("Display")).CellTemplate(new JS("ct4T")).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Level).Caption(iT.T(xLan, "1163", "Lv.")).Width(60).Alignment(HorizontalAlignment.Center);
                        columns.AddFor(m => m.Code).Caption(iT.T(xLan, "1228", "Code")).Width(120).CssClass("fw-bold text-dark");
                        columns.AddFor(m => m.Name1).Caption(iT.T(xLan, "1165", "Account Name")).CssClass("fw-medium");
                    });

                    c.Add().Caption(iT.T(xLan, "1007", "Opening Balance")).Columns(columns =>
                    {
                        columns.AddFor(m => m.oDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.00").Alignment(HorizontalAlignment.Right);
                        columns.AddFor(m => m.oCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.00").Alignment(HorizontalAlignment.Right);
                    });

                    c.Add().Caption(iT.T(xLan, "1011", "Period Transactions")).Columns(columns =>
                    {
                        columns.AddFor(m => m.tDebit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.00").Alignment(HorizontalAlignment.Right);
                        columns.AddFor(m => m.tCredit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.00").Alignment(HorizontalAlignment.Right);
                    });

                    c.Add().Caption(iT.T(xLan, "1227", "Closing Balance")).Columns(columns =>
                    {
                        columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(110).Format("#,##0.00").CellTemplate(new JS("ct4CheckD")).Alignment(HorizontalAlignment.Right);
                        columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(110).Format("#,##0.00").CellTemplate(new JS("ct4CheckC")).Alignment(HorizontalAlignment.Right);
                    });
                })
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search accounts...");
                })
                .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "1237", "Analytical Trial Balance")))
                .RtlEnabled(devRtl)
            )
        </div>
    </div>
</div>

<!-- Loading Spinner Overlay -->
<div id="grid-loader" class="grid-loader-overlay d-none">
    <div class="spinner-border text-primary" role="status">
        <span class="visually-hidden">Loading...</span>
    </div>
</div>

<script class="append-on-ajax-script">
    $(document).ready(function () {
        LoadDash();
    });

    async function LoadDash() {
        $('#grid-loader').removeClass('d-none');
        $.ajax({
            type: "Get",
            url: "/api/acc/ireports/BalanceTB",
            data: { First: getFirst(), Last: getLast() },
            dataType: "json",
            success: function (response) {
                $('#txt-oDebit').text(comma(response.oDebit));
                $('#txt-oCredit').text(comma(response.oCredit));
                $('#txt-tDebit').text(comma(response.TDebit));
                $('#txt-tCredit').text(comma(response.TCredit));
                
                var totalDebit = response.oDebit + response.TDebit;
                var totalCredit = response.oCredit + response.TCredit;
                
                $('#txt-bDebit').text(comma(totalDebit));
                $('#txt-bCredit').text(comma(totalCredit));
                $('#txt-bBalance').text(comma(totalDebit - totalCredit));
                $('#txt-TotalTrial').text(comma(response.oDebit + response.TDebit));
                
                $('#grid-loader').addClass('d-none');
            },
            error: function (response) {
                $('#grid-loader').addClass('d-none');
                Swal.fire({ icon: 'error', title: 'Fetch Error', text: response.responseText || 'Failed to load summary.' });
            }
        });
    }

    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        var viewBtn = $('<button type="button" class="grid-action-btn view" title="Quick View"><i class="bx bx-show"></i></button>');
        viewBtn.on('click', function() { GetDetails(options.data.Key); });
        actionDiv.append(viewBtn);
        container.append(actionDiv);
    }

    function RefreshGrid() {
        LoadDash();
        var grid = $('#grd-TrialBalance').dxDataGrid("instance");
        if(grid) grid.refresh();
    }

    function getFirst() {
        var fd = new Date($('#edFirstDate').dxDateBox('option', 'value'));
        return fd.toLocaleDateString();
    }

    function getLast() {
        var ld = new Date($('#edLastDate').dxDateBox('option', 'value'));
        return ld.toLocaleDateString();
    }

    function getLevel() {
        return $('#edLevel').dxNumberBox('option', 'value');
    }

    function getHideZero() {
        return $('#ed-HideZero').dxCheckBox('option', 'value');
    }

    function getExpKind() {
        return $('#ed-ExpensesDetails').dxCheckBox('option', 'value');
    }

    function ChangeYear() {
        var year = $('#edYear').dxNumberBox('option', 'value');
        $('#edFirstDate').dxDateBox('option', 'value', new Date(year, 0, 1));
        $('#edLastDate').dxDateBox('option', 'value', new Date(year, 11, 31));
        RefreshGrid();
    }

    function ct4Kind(container, options) {
        var badgeClass = 'bg-primary-soft text-primary';
        switch (options.value) {
            case 0: badgeClass = 'bg-yellow-soft text-yellow-dark'; break;
            case 1: badgeClass = 'bg-danger-soft text-danger'; break;
            case 2: badgeClass = 'bg-info-soft text-info'; break;
            case 3: badgeClass = 'bg-success-soft text-success'; break;
        }
        $('<span class="badge ' + badgeClass + ' rounded-pill px-3 py-2">').text(options.text).appendTo(container);
    }

    function ct4T(container, options) {
        var badgeClass = options.value == 0 ? 'bg-info-soft text-info' : 'bg-secondary-soft text-secondary';
        $('<span class="badge ' + badgeClass + ' rounded-pill px-2 py-1 small">').text(options.text).appendTo(container);
    }

    function ct4CheckD(container, options) {
        var val = options.value || 0;
        if (options.data.DC == true && val > 0) {
            $('<span class="fw-bold text-danger">').text(options.text).appendTo(container);
        } else {
            $('<span>').text(options.text).appendTo(container);
        }
    }

    function ct4CheckC(container, options) {
        var val = options.value || 0;
        if (options.data.DC == false && val > 0) {
            $('<span class="fw-bold text-danger">').text(options.text).appendTo(container);
        } else {
            $('<span>').text(options.text).appendTo(container);
        }
    }

    function PrintReport() {
        window.open('/Print/Financial/TrialBalance?First=' + getFirst() + '&Last=' + getLast() + '&Level=' + getLevel() + '&ExpKind=' + getExpKind());
    }
</script>
