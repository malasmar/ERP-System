@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int Year = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    bool showMonthlyNo = xConfig.ShowMonthlyNo(DB);
    bool devRtl;
    DevExtreme.AspNet.Mvc.HorizontalEdge devFixd;
    if (User.FindFirstValue("aiwLan") == "en")
    {
        devRtl = false;
        devFixd = HorizontalEdge.Left;
    }
    else
    {
        devRtl = true;
        devFixd = HorizontalEdge.Right;
    }
}
<style>
    .acc .widget {
        margin-bottom: 4px;
    }
    .acc hr {
        margin-top: 8px;
        margin-bottom: 8px;
    }
</style>
<div class="modern-page">
    <div class="page-header-modern">
        <div class="header-left-modern">
            <div class="header-icon-modern">
                <i class='bx bx-file-find'></i>
            </div>
            <div>
                <h1 class="page-title-modern">@iT.T(xLan,"1223","Account Statement")</h1>
                <p class="page-subtitle-modern">Detailed ledger of transactions for a specific account and period</p>
            </div>
        </div>
        
        <div class="header-actions d-flex gap-2">
            <button type="button" class="btn-modern btn-secondary-modern" onclick="RefreshGrid()">
                <i class='bx bx-refresh'></i> @iT.T(xLan, "1156","Refresh")
            </button>
            <button type="button" class="btn-modern btn-primary-modern" onclick="PrintReport()">
                <i class='bx bx-printer'></i> @iT.T(xLan, "1361","Print Report")
            </button>
        </div>
    </div>

    <div class="row g-4 mb-4">
        <div class="col-lg-8">
            <div class="card-modern h-100">
                <div class="card-header-modern">
                    <h6 class="mb-0 fw-bold"><i class='bx bx-filter-alt me-2'></i>Report Filters</h6>
                </div>
                <div class="card-body-modern">
                    <div class="row g-3">
                        <div class="col-md-3">
                            <label class="form-label small text-muted">@iT.T(xLan, "1222","Year")</label>
                            @Html.DevExtreme().NumberBox().ID("edYear").ShowSpinButtons(true).Width("100%").Value(Year).OnValueChanged("ChangeYear")
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">@iT.T(xLan, "1224","First Date")</label>
                            @Html.DevExtreme().DateBox().ID("edFirstDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,1,1))
                        </div>
                        <div class="col-md-4">
                            <label class="form-label small text-muted">@iT.T(xLan, "1225","Last Date")</label>
                            @Html.DevExtreme().DateBox().ID("edLastDate").Width("100%").DisplayFormat("dd.MM.yyyy").Value(new DateTime(Year,12,31))
                        </div>
                        <div class="col-md-12 mt-3">
                            <label class="form-label small text-muted">@iT.T(xLan, "1219","Account Selection")</label>
                            @Html.DevExtreme().Lookup().ID("edKey").Width("100%").DataSourceOptions(o=>o.Paginate(true).PageSize(50)).DataSource(CLiAccounting.Selections.AccountTransactionLevel.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").OnValueChanged("ChangeAccount").Placeholder("Select an account to view statement...")
                        </div>
                        <div class="col-md-12 mt-2">
                             @Html.DevExtreme().CheckBox().ID("edOpening").Text(iT.T(xLan, "1226","Exclude Opening Balance")).Value(false)
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="col-lg-4">
            <div class="card-modern h-100 bg-primary-modern text-white">
                <div class="card-body-modern d-flex flex-column justify-content-between p-4">
                    <div>
                        <p class="text-white-50 small mb-1">@iT.T(xLan, "1227","Current Balance")</p>
                        <h2 class="mb-4 display-6 fw-bold" id="txt-Balance">0.00</h2>
                    </div>
                    <div class="mt-auto pt-3 border-top border-white-10">
                        <div class="d-flex justify-content-between mb-2">
                            <span class="small opacity-75">@iT.T(xLan, "1052","Total Debit")</span>
                            <span class="fw-bold" id="txt-Debit">0.00</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <span class="small opacity-75">@iT.T(xLan, "1053","Total Credit")</span>
                            <span class="fw-bold" id="txt-Credit">0.00</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <div class="card-modern">
        <div class="card-body-modern p-0 modern-grid">
            @(Html.DevExtreme().DataGrid<CLiAccounting.Reports.AccountStatment>().ID("grd-CurrentAccount")
                .ShowBorders(false)
                .Width("100%")
                .DataSource(d => d.WebApi()
                .Controller("ireports").Area("Accounting")
                .LoadAction("AccountStatement")
                .Key("Key")
                .LoadParams(new
                {
                    Key = new JS("getKey"),
                    FirstDate = new JS("getFirst"),
                    LastDate = new JS("getLast"),
                    Opening = new JS("getOpening")
                }))
                .ColumnAutoWidth(true)
                .HoverStateEnabled(true)
                .RowAlternationEnabled(true)
                .Columns(columns =>
                {
                    columns.Add().Name("act").Caption("#").Width(80).AllowExporting(false).AllowFiltering(false).CellTemplate(new JS("ct4Action")).Alignment(HorizontalAlignment.Center);
                    columns.AddFor(m => m.DocumentKind).Caption(iT.T(xLan, "1975", "Type")).Width(120).Lookup(L => L.DataSource(iReplacer.DocumentsName(xLan, true)).ValueExpr("Value").DisplayExpr("Display"));
                    columns.AddFor(m => m.Date).Caption(iT.T(xLan, "1210", "Date")).Width(110).Format("dd.MM.yyyy");
                    columns.AddFor(m => m.No).Caption(iT.T(xLan, "1265", "No")).Width(90).CssClass("fw-medium");
                    columns.AddFor(m => m.Description).Caption(iT.T(xLan, "1212", "Description")).Width("100%").MinWidth(200).CellTemplate(new JS("ct4Description"));
                    columns.AddFor(m => m.Debit).Caption(iT.T(xLan, "1008", "Debit")).Width(120).Format("#,##0.##").CssClass("text-success");
                    columns.AddFor(m => m.Credit).Caption(iT.T(xLan, "1009", "Credit")).Width(120).Format("#,##0.##").CssClass("text-danger");
                    columns.AddFor(m => m.DebitBalance).Caption(iT.T(xLan, "1052", "Debit Bal.")).Width(120).Format("#,##0.##");
                    columns.AddFor(m => m.CreditBalance).Caption(iT.T(xLan, "1053", "Credit Bal.")).Width(120).Format("#,##0.##");
                })
                .Summary(tot =>
                {
                    tot.TotalItems(item =>
                    {
                        item.AddFor(m => m.Debit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##").DisplayFormat("{0}");
                        item.AddFor(m => m.Credit).SummaryType(SummaryType.Sum).ValueFormat("#,##0.##").DisplayFormat("{0}");
                    });
                })
                .Grouping(g => g.AutoExpandAll(false).AllowCollapsing(true))
                .GroupPanel(gp => gp.Visible(true)//.PlaceholderDragPart("Drag a column header here to group")
                )
                .Pager(pg =>
                {
                    pg.AllowedPageSizes(new List<int> { 50, 100, 200 });
                    pg.ShowNavigationButtons(true);
                    pg.ShowPageSizeSelector(true);
                    pg.ShowInfo(true);
                })
                .Paging(p => { p.PageSize(50); })
                .FilterRow(f => f.Visible(true))
                .HeaderFilter(f => f.Visible(true))
                .SearchPanel(sp =>
                {
                    sp.Width(250);
                    sp.Visible(true);
                    sp.Placeholder("Search results...");
                })
                .Export(exp => exp.Enabled(true).Option("fileName", iT.T(xLan, "1223", "Account Statement")))
                .RtlEnabled(devRtl)
                .Scrolling(s => s.ScrollByContent(true).ScrollByThumb(true))
            )
        </div>
    </div>
</div>
<script class="append-on-ajax-script">
    function ct4Action(container, options) {
        var actionDiv = $('<div class="d-flex justify-content-center align-items-center gap-2"></div>');
        
        var openBtn = $('<button type="button" class="grid-action-btn" title="Open Transaction"><i class="bx bx-link-external"></i></button>');
        openBtn.on('click', function() { OpenTransaction(options.data.DocumentKind, options.data.OperationKey); });

        var viewBtn = $('<button type="button" class="grid-action-btn view" title="Quick View"><i class="bx bx-show"></i></button>');
        viewBtn.on('click', function() { ShowTransaction(options.data.DocumentKind, options.data.OperationKey); });

        actionDiv.append(openBtn).append(viewBtn);
        container.append(actionDiv);
    }
    function RefreshGrid ()
    {
        $('#grd-CurrentAccount').dxDataGrid("instance").refresh().done(function ()
        {
            var debit = 0;
            var credit = 0;
            var balance = 0;
            var dataGridInstance = $('#grd-CurrentAccount').dxDataGrid("instance");
            debit = dataGridInstance.getTotalSummaryValue('Debit');
            credit = dataGridInstance.getTotalSummaryValue('Credit');
            balance = debit - credit;
            $('#txt-Debit').text(comma(debit));
            $('#txt-Credit').text(comma(credit));
            $('#txt-Balance').text(comma(balance));
        });
    }
    function getKey ()
    {
        return $('#edKey').dxLookup('option', 'value')
    }
    function getFirst ()
    {
        var fd = new Date($('#edFirstDate').dxDateBox('option', 'value'));
        return fd.toLocaleDateString();
    }
    function getLast ()
    {
        var ld = new Date($('#edLastDate').dxDateBox('option', 'value'));
        return ld.toLocaleDateString();
    }
    function getOpening ()
    {
        return $('#edOpening').dxCheckBox('option', 'value')
    }
    function ChangeYear ()
    {
        $('#edFirstDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 0, 1));
        $('#edLastDate').dxDateBox('option', 'value', new Date($('#edYear').dxNumberBox('option', 'value'), 11, 31));
    }
    function ct4Description (container, options)
    {
        var str = '';
        str = '<p class="m-0 p-0 f-s-10" style="white-space:normal;">' + options.value + '</p>';
        $(str).appendTo(container)
    }
    function ChangeAccount ()
    {
        var AccountSelection = $("#edKey").dxLookup('instance').option('selectedItem');
        $('#txt-Code').text(AccountSelection.Code);
        $('#txt-Arabic').text(AccountSelection.Name1);
        $('#txt-English').text(AccountSelection.Name2);
        $('#txt-Debit').text('0.00');
        $('#txt-Credit').text('0.00');
        $('#txt-Balance').text('0.00');
        RefreshGrid();
    }
    function PrintReport ()
    {
        window.open('/Print/Financial/ChartAccountStatment?Key=' + getKey() + '&FirstDate=' + getFirst() + '&LastDate=' + getLast() + '&Opening=' + getOpening());
    }
    function OpenTransaction (Kind, Key)
    {
        switch (Kind)
        {
            case 3:
            case 4:
            case 5:
            case 6:
            case 7:
            case 8:
            case 121:
            case 122:
                window.open('/Financial/Documents/Transaction?Key=' + Key);
                break;
            case 9:
                window.open('/Financial/Documents/JournalVoucher?Key=' + Key);
                break;
            case 80:
                window.open('/Sales/Documents/SalesInvoice?Key=' + Key);
                break;
            case 83:
                window.open('/Sales/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 71:
                window.open('/Purchasing/Documents/PurchaseInvoice?Key=' + Key);
                break;
            case 75:
                window.open('/Purchasing/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 77:
                window.open('/Inventory/Documents/Consumption?Key=' + Key);
                break;
            case 78:
                window.open('/Inventory/Documents/ConsumptionReturn?Key=' + Key);
                break;
            default:

                break;
        }
    }

    function ShowTransaction (Kind, Key)
    {
        switch (Kind)
        {
            case 3:
            case 4:
            case 5:
            case 6:
            case 7:
            case 8:
            case 121:
            case 122:
                ViewFinancialTransaction(Key);
                break;
            case 9:
                ViewJournalVoucher(Key);
                break;
            case 80:
            case 83:
                ViewSalesInvoices(Key);
                break;
            case 71:
            case 75:
                ViewPurchaseInvoice(Key);
                break;

                window.open('/Purchasing/Documents/ReturnInvoice?Key=' + Key);
                break;
            case 77:
                window.open('/Inventory/Documents/Consumption?Key=' + Key);
                break;
            case 78:
                window.open('/Inventory/Documents/ConsumptionReturn?Key=' + Key);
                break;
            default:

                break;
        }
    }
</script>
