            <div class="menu-text">@iT.T(xLan, "1244", "Cards")</div>
            <div class="menu-caret"></div>
        </a>
        <div class="menu-submenu">
            <div class="menu-item @(currentPath.Contains("/roots") ? "active" : "")">
                <a href="/Accounting/Cards/Roots" class="menu-link" data-ajax="true" data-ajax-update="#content">
                    <div class="menu-text">@iT.T(xLan, "1249", "Account Roots")</div>
