    <!-- BEGIN minify-button -->
    <div class="menu-item d-flex mt-auto">
        <a href="javascript:;" class="app-sidebar-minify-btn ms-auto text-decoration-none p-3" onclick="toggleSidebar()">
            <i class='bx bx-chevron-left fs-4'></i>
        </a>
    </div>
    <!-- END minify-button -->
</div>

<script>
(function() {
    "use strict";
    // Capture phase listener on document ensures we catch the click BEFORE Layout.cshtml
    document.addEventListener('click', function(e) {
        const link = e.target.closest('.modern-sidebar-menu .has-sub > .menu-link');
        if (!link) return;

        const href = link.getAttribute('href');
        if (!href || href === '#' || href === 'javascript:;') {
            e.preventDefault();
            e.stopImmediatePropagation(); // Kill other listeners
            
            const item = link.closest('.has-sub');
            const sidebar = item.closest('.modern-sidebar-menu');
            const isExpanded = item.classList.contains('expand');

            // Accordion: Close others
            sidebar.querySelectorAll('.has-sub.expand').forEach(el => {
                if (el !== item) el.classList.remove('expand');
            });

            // Toggle current
            item.classList.toggle('expand', !isExpanded);
        }
    }, true);
})();
</script>
