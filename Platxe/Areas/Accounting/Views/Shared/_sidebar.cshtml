@{
    string xLan = User.FindFirstValue("aiwLan");
    string currentPath = Context.Request.Path.Value.ToLower();
}
<style>
.modern-sidebar-menu .has-sub > .menu-submenu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    display: block !important;
    opacity: 0;
    pointer-events: none;
}

.modern-sidebar-menu .has-sub.expand > .menu-submenu {
    max-height: 1500px;
    opacity: 1;
    pointer-events: all;
    margin-bottom: 10px;
}
</style>
<div class="menu modern-sidebar-menu">

    <!-- DASHBOARD -->
    <div class="menu-item @(currentPath == "/accounting" || currentPath == "/accounting/home/index" ? "active" : "")">
        <a href="/Accounting/Home/Index" class="menu-link" data-ajax="true" data-ajax-update="#content" data-ajax-complete="PushStatus($(this))">
            <div class="menu-icon"><i class="bx bxs-dashboard"></i></div>
            <div class="menu-text">@iT.T(xLan, "1142", "Dashboard")</div>
        </a>
    </div>

    <!-- 1. CARDS -->
    <div class="menu-item has-sub @(currentPath.Contains("/cards") ? "expand active" : "")">
