            }
        });
        $('#xrow-Unit').dxSelectBox('focus');
        EditorWorking = false;
        $('#xrow-Unit').dxSelectBox('focus');
    }

    function Changed_ItemsDiscountText ()
    {
        var disKind = false;
        var disstr = "";
        disstr = $('#frm-ItemsDiscountText').dxTextBox('option', 'value');
        var disValue = 0;
        if (disstr != '')
        {
            disstr = disstr.replace(/ /g, "");
            if (disstr.indexOf('%') >= 0)
            {
                disstr = disstr.replace(/%/g, "");
                disKind = true;
                if ($.isNumeric(disstr) == true)
                {
                    disValue = Number(disstr);
                } else
                {
                    $('#frm-ItemsDiscountText').dxTextBox('option', 'value', '');
                    disValue = 0;
                }
            } else
            {
                disKind = false;
                if ($.isNumeric(disstr) == true)
                {
                    disValue = Number(disstr);
                } else
                {
                    $('#frm-ItemsDiscountText').dxTextBox('option', 'value', '');
                    disValue = 0;
                }
            }
        }
        var discountAmount = 0;
        var total = 0;
        $('#tb-rows').find('tr').each(function ()
        {
            total += ($(this).find('[id="td-UnitPrice"]').data('value') * $(this).find('[id="td-Quantity"]').data('value')) - $(this).find('[id="td-DiscountAmount"]').data('value');
        });
        if (disKind == true)
        {
            discountAmount = total * (disValue / 100);
        } else
        {
            discountAmount = disValue;
        }

           var disPercent=0;
              disPercent=   (discountAmount*100)  / total;

        $('#tb-rows').find('tr').each(function ()
        {
           var lineTot=0;
            lineTot += ($(this).find('[id="td-UnitPrice"]').data('value') * $(this).find('[id="td-Quantity"]').data('value')) - $(this).find('[id="td-DiscountAmount"]').data('value');
            $(this).find('[id="td-ItemsDiscount"]').data('value',(lineTot*(disPercent/100))); 
            var lineVAT=0;
            var linevatRate=0;
            
            linevatRate = $(this).find('[id="td-vatRate"]').data('value');
            lineVAT = ((lineTot - (lineTot * (disPercent / 100))) * (linevatRate/100))  ;

            $(this).find('[id="td-vatAmount"]').data('value', lineVAT);

        });

        var totAmount=0;
        var totVAT=0;
        var totDiscount=0;
        var totItemDiscount=0;

         $('#tb-rows').find('tr').each(function ()
        {
            totAmount +=  ($(this).find('[id="td-UnitPrice"]').data('value') * $(this).find('[id="td-Quantity"]').data('value')) - $(this).find('[id="td-DiscountAmount"]').data('value');
            totVAT +=  $(this).find('[id="td-vatAmount"]').data('value');
            totDiscount += $(this).find('[id="td-DiscountAmount"]').data('value');
            totItemDiscount += $(this).find('[id="td-ItemsDiscount"]').data('value');

        });

        $('#txt-Total').text(comma3(totAmount));
        $('#txt-Net').text(comma3(totAmount - totItemDiscount));
        $('#txt-Tax').text(comma3(totVAT));

        $('#txt-NetTotal').text(comma3(totAmount - totItemDiscount + totVAT - $('#frm-PaymentDiscount').dxNumberBox('option','value')));
        $('#txt-ItemsDiscountText').text(comma3(discountAmount));


    }
