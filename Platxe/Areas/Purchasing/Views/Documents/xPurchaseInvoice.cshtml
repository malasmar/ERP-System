        {
            if (data.length > 0)
            {
                $("#xrow-Unit").dxSelectBox("option", "value", data[ 0 ].Code);
            }
        });
        $.ajax({
            type: "get",
            url: "/api/inv/icore/InvoiceItemDetails",
