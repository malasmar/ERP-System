    function EditAmount ()
    {
        //if (IsLoading == 1)
        //    return;
        var disKind = false;
        var disstr = "";
        disstr = $('#xrow-Discount').dxTextBox('option', 'value');
        var disValue = 0;
        if (disstr != '')
        {
            disstr = disstr.replace(/ /g, "");
            if (disstr.indexOf('%') >= 0)
            {
                disstr = disstr.replace(/%/g, "");
                disKind = true;
                if ($.isNumeric(disstr) == true)
                {
                    disValue = Number(disstr);
                } else
                {
                    $('#xrow-Discount').dxTextBox('option', 'value', '');
                    disValue = 0;
                }
            } else
            {
                disKind = false;
                if ($.isNumeric(disstr) == true)
                {
                    disValue = Number(disstr);
                } else
                {
                    $('#xrow-Discount').dxTextBox('option', 'value', '');
                    disValue = 0;
                }
            }
        }
      
        var UnitPrice = $('#xrow-UnitPrice').dxNumberBox('option', 'value');
        var Quantity = $('#xrow-Quantity').dxNumberBox('option', 'value');
        var Amount = UnitPrice * Quantity;
        var Discount = 0;
        if (disKind == false)
        {
            Discount = disValue;
        } else
        {
            if (BounsDiscount == true)
            {
                Discount = Number(Amount - (Amount / (1 + (disValue / 100)))).toFixed(4);
            } else
            {
                Discount = Number(Number(disValue * (UnitPrice * Quantity) / 100).toFixed(4));
            }
        }
        rowDiscountAmount = Discount;
        var Total = 0;
        Total = Number(Number(Amount - Discount).toFixed(4));
        $('#xrow-Total').dxNumberBox('option', 'value', Number(Total.toFixed(4)));
    }

