@model CLiInventory.Documents.Transaction
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    string Currency = CLiCore.VoucherOperation.DefaultCurrency(DB);
    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
    CLiCore.Shared.UserDefaultData defaultData = CLiCore.Shared.UserDefaultData.GetItem(UserKey);
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }
    .xd > tr:hover {
        cursor: pointer;
    }
    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }
    /*   .xd > tr:hover .ccp {
                                                            display: block !important;
                                                        }
                                                        .xd > tr:hover {
                                                            cursor: pointer;
                                                            height: 85px;
                                                        }*/
    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }
    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }
    .width-20 {
        width: 20px !important;
        min-width: 20px !important;
    }
</style>
<div class="invoice">
    <div class="invoice-company">
        <div class="float-end hidden-print">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
        <div class="shl-invoice-header">
            @CLiCore.iCore.DocumentsName(xLan,Model.DocumentKind) <span id="inf-Status" class="badge bg-info text-dark"><small class="f-s-9 me-1">@iT.T(xLan,"2141","Status")</small><span id="txt-Status" class="me-1">Update</span></span><span id="txt-VoucherNo" class="text-danger"># @Model.InvoiceNo </span> 
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
            <p class="f-s-10 mt-1" hidden><i class="fa fa-exclamation-circle text-danger"></i> Lorem ipsum dolor sit amet, consectetur adipiscing elit. Sed id sagittis arcu.</p>
        </div>
    </div>
    <form id="frm-Voucher">
        @Html.HiddenFor(m=>m.DocumentKind)
        @Html.HiddenFor(m=>m.OperationKey)
        @Html.HiddenFor(m=>m.InvoiceNo)
        @Html.HiddenFor(m=>m.MonthlyNo)
        @Html.HiddenFor(m=>m.CreateUser)
        @Html.HiddenFor(m=>m.CreateDate)
        <div class="invoice-header">
            <div class="invoice-from">
                <div class="row">
                    <div class="col-4">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1624","Invoice Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().DateBoxFor(m => m.InvoiceDate).ID("frm-InvoiceDate").UseMaskBehavior(true).Width(125).DisplayFormat("dd.MM.yyyy").Min(new DateTime(xYear,1,1)).Max(DateTime.UtcNow.AddMinutes(180)).ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1636","Invoice No")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.ReferenceNo).ID("frm-ReferenceNo").Width(125).ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1992","AccountKind")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.AccountKind).ID("frm-AccountKind").Width(125).DataSource(iReplacer.finTransactionAccByDocument(xLan,Model.DocumentKind)).ValueExpr("Value").DisplayExpr("Display").OnValueChanged("ChangefrmAccountKind").ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1219","Account")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.AccountKey).ID("frm-AccountKey").DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, PLenums.TransactionAccount.CurrentAccount, PLenums.CurrentAccountKind.Supplier)).ValueExpr("Key").DisplayExpr("Display").ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1726","Supplier")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m => m.CurrentKey).ID("frm-CurrentKey").DataSource(CLiFinancial.Selections.Dynamic.TransactionAccount(DB,xLan, PLenums.TransactionAccount.CurrentAccount, PLenums.CurrentAccountKind.Supplier)).ValueExpr("Key").DisplayExpr("Display").ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                                   <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display")
                            </div>
                        </div>
                        <div class="form-group row" hidden>
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1328","Prefix")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Prefix).ID("frm-Prefix").DataSource(CLiFinancial.Selections.Prefix.GetList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display").Value(defaultData.Prefix).ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row" hidden>
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1281","Branch")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.Branch).ID("frm-Branch").DataSource(CLiFinancial.Selections.Branches.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display").Value(defaultData.Branch).ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1373","Due Date")</label>
                            <div class="col-lg-9 col-sm-12">
                                <div class="input-group">
                                    @Html.DevExtreme().NumberBox().ID("frm-DueDays").Width(75).OnValueChanged("ChangeDueDays").ShowSpinButtons(true).ElementAttr("class", "enter-fact")
                                    @Html.DevExtreme().DateBoxFor(m => m.DueDate).ID("frm-DueDate").Width(110).DisplayFormat("dd.MM.yyyy").ElementAttr("class", "enter-fact")
                                </div>
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1212","Description")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().TextBoxFor(m => m.Description).ID("frm-Description").ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12"></label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().CheckBoxFor(m => m.IsBounsDiscount).ID("cnt-IsBounsDiscount").Text(iT.T(xLan,"","Bouns Dicount")).OnValueChanged("changeBounsDiscount")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1977","vatKey")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.vatKey).ID("frm-vatKey").ElementAttr("class", "enter-fact").Width(140).DataSource(CLiFinancial.Selections.vatKind.vatRates(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-3">
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1625","Warehouse")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().SelectBoxFor(m => m.SourceWarehouse).ID("frm-SourceWarehouse").DataSource(CLiInventory.Selections.Warehouse.GetList(DB,xLan)).ValueExpr("No").DisplayExpr("Display").Value(defaultData.WarehouseNo).ElementAttr("class", "enter-fact")
                            </div>
                        </div>
                        <div class="form-group row">
                            <label class="col-lg-3 col-sm-12">@iT.T(xLan,"1332","Cst.Center")</label>
                            <div class="col-lg-9 col-sm-12">
                                @Html.DevExtreme().LookupFor(m=>m.CostCenter).ID("frm-CostCenter").DataSource(CLiAccounting.Selections.CostCenter.FullList(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                            </div>
                        </div>
                    </div>
                    <div class="col-2">
                        <div class="card border-0 text-truncate mb-3 text-dark">
                            <!-- BEGIN card-body -->
                            <div class="card-body">
                                <!-- BEGIN title -->
                                <div class="mb-2">
                                    <b class="mb-1">Invoice Total</b>
                                </div>
                                <div class="d-flex align-items-center mb-1">
                                    <h2 class="mb-0"><span>@Model.Total.ToString("n2")</span></h2>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1347","Subtotal")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.SubTotal.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2153","Discount")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Discount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-2">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"2146","VAT")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.vatAmount.ToString("n2")</span></div>
                                    </div>
                                </div>
                                <div class="d-flex mb-1">
                                    <div class="d-flex align-items-center">
                                        <i class="fa fa-circle text-red fs-8px me-2"></i>@iT.T(xLan,"1120","Total")
                                    </div>
                                    <div class="d-flex align-items-center ms-auto">
                                        <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Total.ToString("n2")</span></div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </form>
    <div class="invoice-content mt-3">
        <div class="sticky">
            <button type="button" id="btn-addnew" class="btn btn-yellow btn-sm text-dark" onclick="addnew()"><i class="fa fa-add"></i></button>
        </div>
        <div class="table-responsive">
            <table class="table table-invoice table-hover">
                <thead>
                    <tr>
                        <th style="width:50px;max-width:50px"></th>
                        <th style="width:100%;min-width:200px">@iT.T(xLan,"1586","Item Name")</th>
                        <th style="width:110px;min-width:110px;max-width:110px">@iT.T(xLan,"2379","Unit")</th>
                        <th style="width:110px;min-width:110px;max-width:110px">@iT.T(xLan,"2380","Expiry")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1076","Quantity")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1639","Bonus")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1629","Unit Price") </th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"","Sales Price") </th>
                        @*       <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>*@
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1097","Discount")</th>
                        @*  <th style="width:80px;min-width:80px;max-width:80px"><small class="f-s-9">@iT.T(xLan,"1345","VAT")</small> @iT.T(xLan,"1346","Rate")</th>*@
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1345","VAT")</th>
                        <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1120","Total")</th>
                    </tr>
                </thead>
                <tbody class="xd" id="tb-rows">
                </tbody>
            </table>
        </div>
        <div class="row p-2 me-2" style="background-color:#f4f4f4">
            <div class="col-6">
                <div class="invoice-price">
                    <table class="table-sm">
                        <thead>
                            <tr>
                                <th style="width:100%;min-width:130px"></th>
                                <th style="width:auto"></th>
                                <th style="width:100px;min-width:100px"></th>
                            </tr>
                        </thead>
                        <tbody class="f-s-12 f-w-600" style="padding:0.15rem 0.15rem;">
                            <tr><td>@iT.T(xLan,"","Total")</td><td><span id="txt-Total">0.00</span></td></tr>
                            <tr><td>@iT.T(xLan,"","Discount")</td><td>@Html.DevExtreme().TextBoxFor(m=>m.ItemsDiscountText).ID("frm-ItemsDiscountText").Width(125).OnValueChanged("CalcAmount") </td><td><span id="txt-ItemsDiscountText"></span></td>  </tr>
                            <tr><td>@iT.T(xLan,"","Net")</td><td><span id="txt-Net">0.00</span></td></tr>
                            <tr><td>@iT.T(xLan,"","Tax")</td><td><span id="txt-Tax">0.00</span></td></tr>
                            <tr><td>@iT.T(xLan,"","Extra Discount")</td><td>@Html.DevExtreme().NumberBoxFor(m=>m.PaymentDiscount).ID("frm-PaymentDiscount").ShowSpinButtons(false).Width(125).Min(0).Format("0,###.##").OnValueChanged("CalcAmount") </td></tr>
                            <tr><td>@iT.T(xLan,"","Net Total")</td><td><span id="txt-NetTotal">0.00</span></td></tr>
                        </tbody>
                    </table>
                </div>
            </div>
            <div class="col-6">
                @{
                    if (Model.OperationKey != null)
                    {
                        <div class="float-end" id="qrcode"></div>
                    }
                }
            </div>
        </div>
    </div>
    <div class="invoice-note">
        <hr>
        <div class="text-left">
            <div class="btn-group">
                <button type="button" class="btn btn-yellow mb-10px" onclick="SaveGeneralLedger()"><i class="fa fa-save t-plus-1 text-dark fa-fw fa-lg"></i> @iT.T(xLan,"1622","Save Update")</button>
                <button type="button" onclick="PrintDocument()" class="btn btn-white mb-10px"><i class="fa fa-print t-plus-1 fa-fw fa-lg"></i> @iT.T(xLan,"1208","Print")</button>
            </div>
        </div>
    </div>
</div>
<div id="mod-SearchItems" class="modal"><div class="modal-dialog modal-lg" id="con-SearchItems"></div></div>

<script class="append-on-ajax-script">
    var clcDebitCredit = 0;
    var isNewRow;
    var currentRow;
    var opk = null;
    var VoucherStatus = false;
    var Currency;
    var rowCurrentItemKey = null;
    var RowKey = null;
    var RowItemDetails;
    var IsLoading;
    var DiscountKind = false;
    var InvoiceStatus = 0;
    var EditorStatus = false;
    var EditorID;
    var EditorWorking = false;
    var EditorKey = null;
    var EditorCode = '';
    var EditorDisplay = '';
    var BounsDiscount = false;
    var searchData = null;
    var rowExpiryMandatory = false;
    var rowDiscountAmount = 0;
    var rowvatAmount = 0;
  
    $(document).ready(function ()
    {
        Currency = '@Currency';
        if ('@ViewBag.Status' == 'True')
        {
            opk = '@Model.OperationKey';
            InvoiceStatus = Number('@Model.Status');
            VoucherStatus = false;
            $('#inf-Status').removeClass('bg-info');
            $('#inf-Status').addClass('bg-danger');
            $('#txt-Status').text(iShll.update);
            LoadData(opk);
        } else
        {
            $('#inf-Status').addClass('bg-info');
            $('#inf-Status').removeClass('bg-danger');
            $('#txt-Status').text(iShll.new);
            VoucherStatus = true;
        }
        $('#tb-rows').on('click', '#btn-delete', function ()
        {
           
            DeleteRow($(this).data('key'));
        });
        $('#tb-rows').on('click', 'tr', function ()
        {
            if ($(this).attr('id') == 'btn-delete')
                return;

            if (EditorStatus == true)
                return;
            //if ($(this).attr('id') == 'tr-roweditor')
            //    return;
            //$(this).empty();
            //$('#tr-roweditor').prop('hidden', false);
            // $(this).append($('#tr-roweditor').html());
            //var template = $("tr-roweditor");
            //$(template).prop('hidden', false);
            //var newRow = template.clone();
            //$(this).append(newRow);
            EditorID = $(this).attr('id');
            LoadEditor($(this), $(this).data('key'));
        });
        const lookupKey = $("#frm-AccountKey").dxLookup("instance");
        lookupKey.registerKeyHandler("enter", function (e)
        {
            var $canfocus = $('.enter-fact :focusable');
            var index = $canfocus.index(document.activeElement);
            if (index >= $canfocus.length) index = 0;
            $canfocus.eq(index).focus();
        });
        const lookupKey_Current = $("#frm-CurrentKey").dxLookup("instance");
        lookupKey_Current.registerKeyHandler("enter", function (e)
        {
            var $canfocus = $('.enter-fact :focusable');
            var index = $canfocus.index(document.activeElement);
            if (index >= $canfocus.length) index = 0;
            $canfocus.eq(index).focus();
        });
        $('#frm-InvoiceDate').dxDateBox('focus');
    });
    $(document).on('keypress', '.enter-fact', function (e)
    {
        if (e.which == 13 || e.which == 9)
        {
            //e.preventDefault();
            // Get all focusable elements on the page
            if ($(this).attr('id') == 'frm-vatKey')
            {
                var trc = $('#tb-rows tr').length;
                if (Number(trc) == 0)
                {
                    addnew();
                    $('#xrow-Account').dxTextBox('focus');
                }
                return;
            }
            $('#xrow-ExpDate').dxDateBox('focus');
            var $canfocus = $('.enter-fact :focusable');
            var index = $canfocus.index(document.activeElement) + 1;
            if (index >= $canfocus.length) index = 0;
            $canfocus.eq(index).focus();
        }
    });
    $(document).on('keypress', '.enter-act', function (e)
    {
        if (e.which == 13 || e.which == 9)
        {
            //e.preventDefault();
            // Get all focusable elements on the page
            if ($(this).attr('id') == 'xrow-Total')
            {
                if ($('#xrow-ExpDate').dxDateBox('option', 'value') == null || $('#xrow-ExpDate').dxDateBox('option', 'value') < new Date())
                {
                    if (rowExpiryMandatory == true)
                    {
                        $('#xrow-ExpDate').dxDateBox('focus');
                        return;
                    }
                }
                if ($('#xrow-Quantity').dxNumberBox('option', 'value') == 0)
                {
                    $('#xrow-Quantity').dxNumberBox('focus');
                    return;
                }
                SaveRow();
                var trc = $('#tb-rows tr').length;
                var xc = $('#' + EditorID).data('key');
                if (Number(trc) == Number(xc))
                {
                    addnew();
                    $('#xrow-Account').dxTextBox('focus');
                }
                return;
            }
            if ($(this).attr('id') == 'xrow-ExpDate')
            {
                if ($('#xrow-ExpDate').dxDateBox('option', 'value') == null || $('#xrow-ExpDate').dxDateBox('option', 'value') < new Date())
                {
                    if (rowExpiryMandatory == true)
                    {
                        $('#xrow-ExpDate').dxDateBox('focus');
                        return;
                    }
                }
            }
            var $canfocus = $('.enter-act :focusable');
            var index = $canfocus.index(document.activeElement) + 1;
            if (index >= $canfocus.length) index = 0;
            $canfocus.eq(index).focus();
            $canfocus.eq(index).select();
        }
    });
    $(document).mouseup(function (e)
    {
        var container = $('#' + EditorID);
        if (!container.is(e.target) && container.has(e.target).length === 0)
        {
            if (EditorStatus == false)
                return;
            if (EditorWorking == true)
                return;
            if ($('#xrow-Account').dxTextBox('option', 'value') == '')
            {
                $('#xrow-Account').dxTextBox('focus');
                return;
            }
            if ($('#xrow-Quantity').dxNumberBox('option', 'value') == 0)
            {
                $('#xrow-Quantity').dxNumberBox('focus');
                return;
            }
            if ($('#xrow-ExpDate').dxDateBox('option', 'value') == null || $('#xrow-ExpDate').dxDateBox('option', 'value') < new Date())
            {
                if (rowExpiryMandatory == true)
                {
                    $('#xrow-ExpDate').dxDateBox('focus');
                    return;
                }
            }
            SaveRow();
        }
    });

    function addnew ()
    {
        if (EditorStatus == true)
            return;

         RowItemDetails=null;

        RowKey = GeneratGuid();
        rowExpiryMandatory = false;
        rowDiscountAmount = 0;
        rowvatAmount = 0;
        EditorKey = null;
        var count = $('#tb-rows tr').length + 1;
        var str = '';
        str += '<tr id="tr-' + count + '"  data-key="' + count + '" >'
        str += '<td hidden id="td-ItemKey" data-value="' + null + '"></td>'
        str += '<td hidden id="td-Code" data-value="' + '' + '"></td>'
        str += '<td hidden id="td-Display" data-value=""></td>'
        str += '<td hidden id="td-Unit" data-value=""></td>'
        str += '<td hidden id="td-ExpDate" data-value="' + null + '"></td>'
        str += '<td hidden id="td-UnitPrice" data-value="0"></td>'
        str += '<td hidden id="td-SalesPrice" data-value="0"></td>'
        str += '<td hidden id="td-Quantity" data-value="0"></td>'
        str += '<td hidden id="td-Bonus" data-value="0"></td>'
        str += '<td hidden id="td-Amount" data-value="0"></td>'
        str += '<td hidden id="td-Discount" data-value="0"></td>'
