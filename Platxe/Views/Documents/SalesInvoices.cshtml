@model CLiInventory.Documents.TransactionInfo
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
    int xYear = Convert.ToInt32(User.FindFirstValue("aiwYear"));
    Guid UserKey = Guid.Parse(User.FindFirstValue("Key"));
    CLiCore.Shared.UserRights userRights = new CLiCore.Shared.UserRights().GetItem(UserKey);
}
<style>
    .shl-invoice-header > span {
        margin-left: 4px;
        margin-right: 4px;
    }

    .shl-invoice-header > p {
        margin-top: 4px;
        margin-bottom: 4px;
    }

    .xd .ccp {
        display: block !important;
    }
    .xd > tr:hover {
        cursor: pointer;
    }

    .wd70 {
        width: 65px !important;
        min-width: 65px !important;
        max-width: 65px !important;
    }

    .badg-plx {
        width: 55px !important;
        min-width: 55px !important;
        max-width: 55px !important;
        line-height: 22px !important;
        font-size: 10px;
    }
</style>
<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iCore.DocumentsName(xLan,Model.DocumentKind) <span> # @Model.InvoiceNo</span></h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <div class="modal-body">
                <div class="row">
            <div class="col-12">
                @{
                    if (userRights.CanDelete == true)
                    {

                        <div class="btn-group">
                            <button type="button" class="btn btn-danger btn-sm" onclick="DeleteInventoryTransaction('@Model.Key')">@iT.T(xLan,"","Delete")</button>
                        </div>

                    }
                    if (userRights.ConfirmSales == true)
                    {
                        <div class="btn-group">
                            <button type="button" class="btn btn-success btn-sm" onclick="UpdateFinancialTransaction('@Model.Key',2)">@iT.T(xLan,"","Confirm")</button>
                            <button type="button" class="btn btn-danger btn-sm" onclick="UpdateFinancialTransaction('@Model.Key',3)">@iT.T(xLan,"","ReAudit")</button>
                      
                        </div>
                   
                    }

                    <button type="button" class="btn btn-gray btn-sm" onclick="ViewGeneralLedger('@Model.Key')">@iT.T(xLan,"","GL")</button>
               
                }
            </div>
        </div>
        <div class="invoice">
            <div class="invoice-header">
                <div class="invoice-from">
                    <div class="row">
                        <div class="col-4">
                            <div class="mb-1">
                                <b class="mb-1">Invoice Details</b>
                            </div>
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody class="fw-bold fs-10px">
                                    <tr><td>Invoice No</td><td>@Model.InvoiceNo</td></tr>
                                    <tr><td>Invoice Date</td><td>@Model.InvoiceDate.Value.ToString("dd.MM.yyyy")</td></tr>
                                    <tr><td>Close Kind</td><td id="td-CloseKind"></td></tr>
                                    <tr class="mt-1"><td>Account Name</td><td>@Model.Account.Display</td></tr>
                                    <tr class="mt-1"><td>Description</td><td>@Model.Description</td></tr>
                                </tbody>
                            </table>
                            <div class="mt-2">
                                <button onclick="ShowInvoiceCost()" class="btn btn-xs btn-yellow text-dark">Items Cost</button>
                            </div>
                        </div>
                        <div class="col-3">
                            <table class="table-sm">
                                <thead>
                                    <tr>
                                        <th style="width:auto"></th>
                                        <th style="width:auto"></th>
                                    </tr>
                                </thead>
                                <tbody class="fw-bold fs-10px">
                                    <tr class="mt-1"><td>Client Name</td><td>@Model.Current.Display</td></tr>
                                    <tr><td>Client Phone</td><td>@Model.Current.Phone</td></tr>
                                    <tr><td>Client Email</td><td>@Model.Current.Email</td></tr>
                                </tbody>
                            </table>
                        </div>
                        <div class="col-2">
                            <div class="card border-0 text-truncate mb-3 text-dark">
                                <!-- BEGIN card-body -->
                                <div class="card-body">
                                    <!-- BEGIN title -->
                                    <div class="mb-2">
                                        <b class="mb-3">Invoice Total</b>
                                    </div>
                                    <div class="d-flex align-items-center mb-1">
                                        <h2 class="mb-2"><span>@Model.Total.ToString("n2")</span></h2>
                                    </div>
                                    <div class="d-flex mb-2">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-circle text-red fs-8px me-2"></i>Subtotal
                                        </div>
                                        <div class="d-flex align-items-center ms-auto">
                                            <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Subtotal.ToString("n2")</span></div>
                                        </div>
                                    </div>
                                    <div class="d-flex mb-2">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-circle text-red fs-8px me-2"></i>Discount
                                        </div>
                                        <div class="d-flex align-items-center ms-auto">
                                            <div class="w-50px text-end ps-2 fw-bold"><span>@Model.Discount.ToString("n2")</span></div>
                                        </div>
                                    </div>
                                    <div class="d-flex">
                                        <div class="d-flex align-items-center">
                                            <i class="fa fa-circle text-red fs-8px me-2"></i>VAT
                                        </div>
                                        <div class="d-flex align-items-center ms-auto">
                                            <div class="w-50px text-end ps-2 fw-bold"><span>@Model.vatAmount.ToString("n2")</span></div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-3">
                            <div class="card border-0 text-truncate mb-3 text-dark">
                                <!-- BEGIN card-body -->
                                <div class="card-body">
                                    <!-- BEGIN title -->
                                    <div class="mb-3 ">
                                        <b class="mb-3">Creation Details</b>
                                    </div>
                                    <table class="table-sm">
                                        <thead>
                                            <tr>
                                                <th style="width:auto"></th>
                                                <th style="width:auto"></th>
                                            </tr>
                                        </thead>
                                        <tbody class="fw-bold fs-10px">
                                            <tr><td>Create User</td><td>@Model.CreateUser.Display</td></tr>
                                            <tr><td>Update User</td><td>@Model.LastupUser.Display</td></tr>
                                            <tr class="mt-1"><td>Create Date</td><td>@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy HH:mm") : "")</td></tr>
                                            <tr><td>Update Date</td><td>@(Model.CreateDate.HasValue == true ? Model.CreateDate.Value.ToString("dd.MM.yyyy HH:mm") : "")</td></tr>
                                        </tbody>
                                    </table>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <div class="invoice-content mt-3">
                <div class="table-responsive">
                    <table class="table table-invoice table-hover">
                        <thead>
                            <tr>
                                <th style="width:100px;max-width:100px">@iT.T(xLan,"1215","Actions")</th>
                                <th style="width:65px;min-width:65px;max-width:65px">@iT.T(xLan,"1158","Kind")</th>
                                <th style="width:120px;min-width:120px;max-width:120px">@iT.T(xLan,"1164","Code")</th>
                                <th style="width:100%;min-width:150px">@iT.T(xLan,"1586","Item Name")</th>
                                <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1628","Expiry")</th>
                                <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1076","Quantity")</th>
                                <th style="width:70px;min-width:70px;max-width:70px">@iT.T(xLan,"1639","Bonus")</th>
                                <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1629","Unit Price") </th>
                                <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1077","Amount")</th>
                                <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1097","Discount")</th>
                                <th style="width:80px;min-width:80px;max-width:80px"><small class="f-s-9">@iT.T(xLan,"1345","VAT")</small> @iT.T(xLan,"1346","Rate")</th>
                                <th style="width:80px;min-width:80px;max-width:80px">@iT.T(xLan,"1345","VAT")</th>
                                <th style="width:100px;min-width:100px;max-width:100px">@iT.T(xLan,"1120","Total")</th>
                            </tr>
                        </thead>
                        <tbody class="xd" id="tb-SalesRows">
                        </tbody>
                    </table>
                </div>
                <div class="invoice-price">
                    <div class="invoice-price-left">
                        <div class="invoice-price-row">
                            <div class="sub-price">
                                <small>Subtotal</small>
                                <span id="txt-Amount" class="text-dark">0.00</span>
                            </div>
                            <div class="sub-price">
                                <small>vat Total</small>
                                <span id="txt-vatAmount" class="text-dark">0.00</span>
                            </div>
                            <div class="sub-price">
                                <small>Total</small>
                                <span id="txt-Total" class="text-red me-2">0.00</span>
                            </div>
                        </div>
                    </div>
                    <div class="invoice-price-right">
                        <small>TOTAL</small> <span class="fw-bold" id="txt-xTotal">0.00</span>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="modal-footer">
        <div class="btn-group">
            <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"2315","Close")</button>
        </div>
    </div>
</div>
<div id="mod-ItemDetails" class="modal"><div class="modal-dialog modal-lg modal-x2" id="con-ItemDetails"></div></div>
<script class="append-on-ajax-script">

    var opk = null;
    $(document).ready(function ()
    {
      
        var CloseKind = 0;
        opk = '@Model.Key';
        CloseKind = Number('@Model.AccountKind');
        switch (CloseKind)
        {
            case 0:
                $('#td-CloseKind').empty();
                $('#td-CloseKind').append('<span class="badge bg-yellow text-dark badg-plx">Credit</span>');
                break;
            case 2:
                $('#td-CloseKind').empty();
                $('#td-CloseKind').append('<span class="badge bg-yellow text-dark badg-plx">Cash</span>');
                break;
            case 3:
                $('#td-CloseKind').empty();
                $('#td-CloseKind').append('<span class="badge bg-yellow text-dark badg-plx">Bank</span>');
                break;
        }
        LoadData(opk);
    });
    function getDescriptionStyle (xx)
    {
        if (xx.length == 0)
        {
            return '';
        }
        if (xx.length > 0 && xx.length < 250)
        {
            return 'height:70px;';
        }
        if (xx.length > 500)
        {
            return 'height:90px;';
        }
    }
    function getDescriptionCaption (xx)
    {
        if (xx.length == 0)
        {
            return '';
        } else
        {
            return 'Description:';
        }
    }
    function LoadData (key)
    {
        $.ajax({
            type: "get",
            url: "/api/Sales/idocuments/TransactionDetails",
            data: { key: key },
            dataType: "json",
            success: function (response)
            {
                var count = 1;
                $("#tb-SalesRows").empty();
                for (const item of response)
                {
                    var str = '';
                    str += '  <tr id="tr-' + count + '" style="' + getDescriptionStyle(item.Description) + '">'
                    str += '      <td>'
                    str += '          <div class="d-flex align-items-center">'
                    str += '              <small style="margin-left:4px;margin-right:4px;min-width:30px;max-width:30px">' + count + '</small>'
                    str += '          </div>'
                    str += '          <div class="ccp position-absolute d-none mt-2">'
                    str += '              <p class="f-s-10 p-0 m-0 mt-1"><b class="me-1">' + getDescriptionCaption(item.Description) + ' </b>' + item.Description + '</p>'
                    str += '          </div>'
                    str += '      </td>'
                    str += '      <td>' + GetItemKind(item.ItemKind) + '</td>'
                    str += '      <td><span class="text-dark">' + item.jnAccount.Code + '</span></td>'
                    str += '      <td>'
                    str += '          <span class="text-dark">' + item.jnAccount.Display + '</span>'
                    str += '      </td>'
                    str += '      <td>' + item.strExpDate + '</td>'
                    str += '      <td>' + comma(item.Quantity) + '</td>'
                    str += '      <td>' + comma(item.Bonus) + '</td>'
                    str += '      <td>' + comma(item.UnitPrice) + '</td>'
                    str += '      <td>' + comma(item.Amount) + '</td>'
                    str += '      <td>' + comma(item.Discount) + '</td>'
                    str += '      <td><small class="f-s-9">' + item.jnvatDetails.Display + '</small></td>'
                    str += '      <td>' + comma(item.vatAmount) + '</td>'
                    str += '      <td>' + comma(item.Total) + '</td>'
                    str += '<td hidden id="td-UnitPrice" data-value="' + item.UnitPrice + '"></td>'
                    str += '<td hidden id="td-Quantity" data-value="' + item.Quantity + '"></td>'
                    str += '<td hidden id="td-Bonus" data-value="' + item.Bonus + '"></td>'
                    str += '<td hidden id="td-Amount" data-value="' + item.Amount + '"></td>'
                    str += '<td hidden id="td-Discount" data-value="' + item.Discount + '"></td>'
                    str += '<td hidden id="td-vatAmount" data-value="' + item.vatAmount + '"></td>'
                    str += '<td hidden id="td-UnitCost" data-value="' + item.UnitCost + '"></td>'
                    str += '<td hidden id="td-vatKey" data-value="' + item.vatKey + '"></td>'
                    str += '<td hidden id="td-vatRate" data-value="' + item.vatRate + '"></td>'
                    str += '<td hidden id="td-Total" data-value="' + item.Total + '"></td>'
                    str += '  </tr>'
                    $("#tb-SalesRows").append(str);
                    CalcAmount();
                    count += 1;
                }
                CalcAmount();
            },
            failure: function (response)
            {
                alert(response);
            },
            error: function (response)
            {
                alert(response.responseText);
            }
        });
    }
    function CalcAmount ()
    {
        var amount = 0;
        var vat = 0;
        var total = 0;
        $('#tb-SalesRows').find('tr').each(function ()
        {
            amount += $(this).find('[id="td-Amount"]').data('value');
            vat += $(this).find('[id="td-vatAmount"]').data('value');
            total += $(this).find('[id="td-Total"]').data('value');
        });
        $('#txt-Amount').text(comma(amount));
        $('#txt-vatAmount').text(comma(vat));
        $('#txt-Total').text(comma(total));
        $('#txt-xTotal').text(comma(total));
    }
    function GetItemKind (kind, Type)
    {
        var strKind = '';
        switch (kind)
        {
            case 0:
                strKind = '<span  class="badge bg-yellow text-dark badg-plx me-1">' + 'C/A' + '</span>';
                break;
            case 1:
                strKind = '<span  class="badge bg-danger text-dark badg-plx me-1">' + 'Employee' + '</span>';
                break;
            case 2:
                strKind = '<span  class="badge bg-info text-dark badg-plx me-1">' + 'Cash' + '</span>';
                break;
            case 3:
                strKind = '<span  class="badge bg-success text-dark badg-plx me-1">' + 'Bank' + '</span>';
                break;
            case 4:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Fixture' + '</span>';
                break;
            case 6:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Revenue' + '</span>';
                break;
            case 5:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Expenses' + '</span>';
                break;
            case 7:
                strKind = '<span  class="badge bg-warning text-dark badg-plx me-1">' + 'Account' + '</span>';
                break;
            case 8:
                strKind = '<span  class="badge bg-yellow text-dark badg-plx me-1">' + 'Stock' + '</span>';
                break;
        }
        return '<div class="d-flex">' + strKind + '</div>'
    }
    function ShowInvoiceCost(){
        $('#con-ItemDetails').empty();
        $("#con-ItemDetails").load('/Auditing/StockCost/ItemCostDetails?Key=' + opk);
        $("#mod-ItemDetails").modal({ backdrop: 'static' }).modal('toggle');
    }
 
</script>
