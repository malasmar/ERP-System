@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <title>Platxe | Login</title>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta content="Platxe ERP Login" name="description" />
    <meta content="" name="author" />
    <!-- ================== BEGIN core-css ================== -->
    <link href="~/Template/assets/css/vendor.min.css?version=3.019" rel="stylesheet" />
    <link href="~/Template/assets/css/apple/app.min.css?version=3.019" rel="stylesheet" />
    <link href="~/Template/assets/plugins/ionicons/css/ionicons.min.css?version=3.019" rel="stylesheet" />
    <!-- ================== END core-css ================== -->
    <link rel="stylesheet" href="~/css/vendor.css?version=3.019" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/Site.css?version=3.019" />
    <script src="~/js/vendor.js?version=3.019" asp-append-version="true"></script>
    <link href="~/shllash/jquery-confirm.min.css?version=3.019" rel="stylesheet" />
    
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');
        
        body, html {
            font-family: 'Inter', sans-serif;
            margin: 0;
            padding: 0;
            background-color: #f8fafc;
            height: 100%;
        }

        .login-split {
            display: flex;
            min-height: 100vh;
            width: 100%;
        }

        .login-left {
            flex: 1;
            display: none;
            background: linear-gradient(135deg, rgba(37, 99, 235, 0.9) 0%, rgba(30, 64, 175, 0.95) 100%), url('../Template/assets/img/login-bg/login-bg-17.jpg');
            background-size: cover;
            background-position: center;
            color: white;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 4rem;
            text-align: center;
        }

        @@media (min-width: 992px) {
            .login-left {
                display: flex;
            }
        }

        .login-left h1 {
            font-weight: 700;
            font-size: 3rem;
            margin-bottom: 1rem;
            letter-spacing: -1px;
            color: #ffffff;
        }

        .login-left p {
            font-size: 1.125rem;
            opacity: 0.9;
            max-width: 400px;
            line-height: 1.6;
            margin: 0 auto;
        }

        .login-right {
            flex: 1;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 2rem;
            background: #ffffff;
        }

        .login-card {
            width: 100%;
            max-width: 440px;
            padding: 2.5rem;
            background: #ffffff;
            border-radius: 16px;
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.05), 0 8px 10px -6px rgba(0, 0, 0, 0.01);
            border: 1px solid rgba(226, 232, 240, 0.8);
        }

        .login-header {
            text-align: center;
            margin-bottom: 2rem;
        }

        .login-header .brand {
            font-size: 1.85rem;
            font-weight: 700;
            color: #0f172a;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
            margin-bottom: 0.5rem;
        }
        
        .login-header .brand i {
            color: #2563eb;
            font-size: 2.2rem;
        }

        .login-header p {
            color: #64748b;
            font-size: 0.95rem;
            margin: 0;
            font-weight: 500;
        }

        .form-label {
            color: #475569;
            font-weight: 600;
            font-size: 0.85rem;
            margin-bottom: 0.5rem;
        }

        .form-control {
            height: 52px;
            font-size: 0.95rem;
            border-radius: 10px;
            border: 1px solid #e2e8f0;
            background-color: #f8fafc;
            transition: all 0.2s ease;
        }

        .form-control:focus {
            border-color: #2563eb;
            background-color: #ffffff;
            box-shadow: 0 0 0 4px rgba(37, 99, 235, 0.1);
        }

        .input-icon-wrapper {
            position: relative;
        }
        
        .input-icon-wrapper .form-control {
            padding-left: 2.8rem;
        }
        
        .input-icon-wrapper i {
            position: absolute;
            left: 1.1rem;
            top: 50%;
            transform: translateY(-50%);
            color: #94a3b8;
            font-size: 1.2rem;
            z-index: 4;
        }

        .btn-login {
            background: #2563eb;
            color: #ffffff;
            font-weight: 600;
            font-size: 1rem;
            height: 52px;
            border-radius: 10px;
            border: none;
            width: 100%;
            transition: all 0.2s ease;
            margin-top: 0.5rem;
            box-shadow: 0 4px 6px -1px rgba(37, 99, 235, 0.2);
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }

        .btn-login:hover {
            background: #1d4ed8;
            transform: translateY(-1px);
            box-shadow: 0 6px 8px -1px rgba(37, 99, 235, 0.3);
            color: #ffffff;
        }

        .login-options {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1.5rem;
            font-size: 0.9rem;
        }

        .form-check-input {
            cursor: pointer;
        }

        .form-check-input:checked {
            background-color: #2563eb;
            border-color: #2563eb;
        }

        .form-check-label {
            cursor: pointer;
            color: #64748b;
            font-weight: 500;
            padding-top: 2px;
        }

        .forgot-link {
            color: #2563eb;
            text-decoration: none;
            font-weight: 600;
            transition: color 0.2s;
        }

        .forgot-link:hover {
            color: #1d4ed8;
            text-decoration: underline;
        }

        #txtError {
            color: #dc2626;
            font-size: 0.875rem;
            background: #fef2f2;
            padding: 0.75rem 1rem;
            border-radius: 8px;
            border: 1px solid #fecaca;
            margin-bottom: 1.25rem;
            font-weight: 500;
            text-align: center;
        }

        #txtError[hidden] {
            display: none !important;
        }
    </style>
</head>
<body class="pace-top">
    <div id="loader" class="app-loader">
        <span class="spinner"></span>
    </div>
    <div id="app" class="app">
        
        <div class="login-split">
            <!-- Left Side: Branding & Visuals -->
            <div class="login-left">
                <div style="margin-bottom: 1.5rem;">
                    <i class="ion-md-cloud-outline" style="font-size: 5rem; color: #93c5fd;"></i>
                </div>
                <h1>Platxe ERP</h1>
                <p>Cloud Enterprise Resource Management and Planning. Streamline your business operations securely.</p>
            </div>

            <!-- Right Side: Login Form -->
            <div class="login-right">
                <div class="login-card">
                    <div class="login-header">
                        <div class="brand">
                            <i class="ion-md-cube"></i> Platxe
                        </div>
                        <p>Welcome back! Please enter your details.</p>
                    </div>

                    <form id="frmLogin">
                        <div class="mb-3">
                            <label for="txtCID" class="form-label">Client ID</label>
                            <div class="input-icon-wrapper">
                                <i class="ion-md-business"></i>
                                <input type="text" class="form-control" placeholder="Enter your Client ID" id="txtCID" required />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label for="txtEmail" class="form-label">Email Address</label>
                            <div class="input-icon-wrapper">
                                <i class="ion-md-mail"></i>
                                <input type="text" class="form-control" placeholder="name@company.com" id="txtEmail" required />
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="txtPassword" class="form-label">Password</label>
                            <div class="input-icon-wrapper">
                                <i class="ion-md-lock"></i>
                                <input type="password" class="form-control" placeholder="••••••••" id="txtPassword" required />
                            </div>
                        </div>

                        <div class="login-options">
                            <div class="form-check">
                                <input class="form-check-input" type="checkbox" id="chkRemember">
                                <label class="form-check-label" for="chkRemember">
                                    Remember me
                                </label>
                            </div>
                            <a href="/Account/RecoverPassword" class="forgot-link">Forgot Password?</a>
                        </div>

                        <p id="txtError" hidden></p>

                        <button type="submit" class="btn btn-login" onclick="Login()">
                            Sign In <i class="ion-md-log-in ms-1"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>

    </div>
    
    <script src="~/Template/assets/js/vendor.min.js?version=3.019"></script>
    <script src="~/Template/assets/js/app.min.js?version=3.019"></script>
    <script src="~/Template/assets/js/demo/login-v2.demo.js?version=3.019"></script>
    <script src="https://code.jquery.com/jquery-migrate-1.3.0.js"></script>

    <script class="append-on-ajax-script">
        var PLBrowserName="";
        var PLOS="";
        $(document).ready(function ()
        {
            $("#frmLogin").submit(function (event)
            {
                event.preventDefault();
            });
            $('#txtCID').val(Cookies.get('CID'));
            $("#xhtml").attr("dir", "ltr");
            $("html").attr("dir", "ltr");
            $("body").removeClass("rtl-mode");
            $("body").toggleClass("dx-rtl", false);
            GetBrowserDetails();
        });
        function Login ()
        {
            $('#txtError').prop('hidden', true);
            $('#txtError').text('');
            var cid = '';
            var uid = '';
            var pas = '';
            cid = $('#txtCID').val();
            uid = $('#txtEmail').val();
            pas = $('#txtPassword').val();
            if (cid == '')
                return;
            $.ajax({
                type: "Post",
                url: "/api/apiaccount/Login",
                data: {
                    ClientID: cid,
                    UserName: uid,
                    Password: pas
                },
                dataType: "json",
                success: function (response)
                {
                    switch (response)
                    {
                        case "Ok":
                            Cookies.set('CID', $('#txtCID').val());
                            window.location.replace('/');
                            break;
                        case "Password":
                            $('#txtError').prop('hidden', false);
                            $('#txtError').text('Password no matching');
                            break;
                        case "Expiry":
                            $('#txtError').prop('hidden', false);
                            $('#txtError').text('Expiry subscribe');
                            break;
                        case "NoSubscribe":
                            $('#txtError').prop('hidden', false);
                            $('#txtError').text('There is no Client');
                            break;
                        case "NoUser":
                            $('#txtError').prop('hidden', false);
                            $('#txtError').text('There is no user');
                            break;
                         default:
                            Cookies.set('CID', $('#txtCID').val());
                            window.location.replace('/Account/OTP?Key=' + response);
                            break;
                    }
                },
                failure: function (response)
                {
                    alert(response);
                },
                error: function (response)
                {
                    alert(response.responseText);
                }
            });
        }

        function GetBrowserDetails(){
            PLBrowserName = (function (agent)
            {
                switch (true)
                {
                    case agent.indexOf("edge") > -1: return "MS Edge";
                    case agent.indexOf("edg/") > -1: return "Edge ( chromium based)";
                    case agent.indexOf("opr") > -1 && !!window.opr: return "Opera";
                    case agent.indexOf("chrome") > -1 && !!window.chrome: return "Chrome";
                    case agent.indexOf("trident") > -1: return "MS IE";
                    case agent.indexOf("firefox") > -1: return "Mozilla Firefox";
                    case agent.indexOf("safari") > -1: return "Safari";
                    default: return "other";
                }
            })(window.navigator.userAgent.toLowerCase());
            
            var userAgent = navigator.userAgent || navigator.vendor || window.opera;

            //Check mobile device is Android
            if (/android/i.test(userAgent))
            {
                //Add your Code here
                PLOS = 'Android';
            }

            //Check mobile device is IOS
            if (/iPad|iPhone|iPod/.test(userAgent) && !window.MSStream)
            {
                //Add your Code here
                PLOS = 'IOS';
            }

            //Check device os is Windows (For Laptop and PC)
            if (navigator.appVersion.indexOf("Win") != -1)
            {
                //Add your Code here
                PLOS = 'Windows';
            }

            //Check device os is MAC (For Laptop and PC)
            if (navigator.appVersion.indexOf("Mac") != -1)
            {
                //Add your Code here
                PLOS = 'Mac';
            }
        }
    </script>
</body>
</html>