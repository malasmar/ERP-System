@model CLiFinancial.Cards.Revenue
@{
    string xLan = User.FindFirstValue("aiwLan");
    string DB = User.FindFirstValue("aiwDB");
}
<div class="modal-content">
    <div class="modal-header">
        <h4 class="modal-title">@iT.T(xLan,"2294","Revenue Card")</h4>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-hidden="true"></button>
    </div>
    <form id="frm-Revenue" data-parsley-validate="true">
        <div class="modal-body">
            @Html.HiddenFor(m => m.Key)
              @Html.HiddenFor(m => m.Account)
            @{
                if (Model.Key != null)
                {
                        <div class="xkey text-gray">@iT.T(xLan,"2263","Key"): @Model.Key</div>
                }
            }
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2264","Parent")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().LookupFor(m => m.Parent).ID("cnt-Parent").InputAttr("required", true).DataSource(CLiAccounting.Selections.AccountFinancialCategory.GetList(DB,xLan,PLenums.AccountingCategory.Revenue)).ValueExpr("Key").DisplayExpr("Display")
                </div>
            </div>
            <hr class="m-2 p-0" />
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2188","Code")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().TextBoxFor(m => m.Code).ID("cnt-Code").InputAttr("required", true)
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2265","Account Name")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().TextBoxFor(m => m.Name1).ID("cnt-Name1").InputAttr("required", true)
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2266","English Name")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().TextBoxFor(m => m.Name2).ID("cnt-Name2")
                </div>
            </div>
            <hr class="m-2 p-0" />
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2179","Group")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().LookupFor(m => m.Group).ID("cnt-Group").DataSource(CLiFinancial.Selections.Groups.Revenue(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2295","Sales Price")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().NumberBoxFor(m => m.Price).ID("cnt-Price").Width(140).ShowSpinButtons(true).Format("0,###.##")
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2296","vatKey")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().SelectBoxFor(m => m.vatKey).ID("cnt-vatKey").Width(140).DataSource(CLiFinancial.Selections.vatRate.vatRates(DB,xLan)).ValueExpr("Key").DisplayExpr("Display")
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2297","Sales Total")</label>
                <div class="col-lg-9 col-sm-12">
                    <div class="input-group">
                        @Html.DevExtreme().NumberBoxFor(m => m.Total).ID("cnt-Total").Width(140).ShowSpinButtons(true).Format("0,###.##")
                        <button type="button" class="btn btn-white f-s-10" onclick="RefelectAmount()">@iT.T(xLan, "2298","Reflect Amount")</button>
                    </div>
                </div>
            </div>
            <div class="form-group row">
                <label class="col-lg-3 col-sm-12"></label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().CheckBoxFor(m => m.EnablePoint).ID("cnt-EnablePoint").Text("Enable Point of Sales")
                </div>
            </div>
            <div class="form-group row" hidden>
                <label class="col-lg-3 col-sm-12">@iT.T(xLan,"2278","Status")</label>
                <div class="col-lg-9 col-sm-12">
                    @Html.DevExtreme().SwitchFor(m => m.Disable).ID("cnt-Disable").Width(65).SwitchedOnText("Disable").SwitchedOffText("Active")
                </div>
            </div>
        </div>
        <div class="modal-footer">
            <div class="btn-group">
                <button type="submit" class="btn btn-yellow text-dark">@iT.T(xLan,"2279","Save Change")</button>
                <button type="button" class="btn btn-dark" data-bs-dismiss="modal" aria-hidden="true">@iT.T(xLan,"2280","Cancel")</button>
            </div>
        </div>
    </form>
</div>
<script class="append-on-ajax-script">
    $(document).ready(function() {
        $("#frm-Revenue").submit(function(event) {
            event.preventDefault();
            SaveAccount();
        });
        $('#cnt-Parent').dxLookup({
            onValueChanged: function(e) {
                var selectedAccount = $("#cnt-Parent").dxLookup('instance').option('selectedItem');
                if ($('#Key').val() == 'null')
                {
                    ParentDetails(selectedAccount.Code);
                }
            }
        });
    });
    function SaveAccount() {
        if ($('#cnt-Code').dxTextBox('option', 'text') == "") {
            alert('Please enter Code!');
            return;
        }
        if ($('#cnt-Name1').dxTextBox('option', 'text') == "") {
            alert('Please enter name (Display) !');
            return;
        }
        var data = $('#frm-Revenue').serialize();
        $.ajax({
            type: "POST",
            url: "/api/fin/icards/UpdateRevenue",
            data: data,
            dataType: "json",
            success: function(response) {
                EndSaveAccount(response);
                $("#mod-Card").modal('toggle');
            },
            failure: function(response) {
                alert(response);
            },
            error: function(response) {
                alert(response.responseText);
            }
        });
    }
    function ParentDetails(code) {
        $.ajax({
            type: "get",
            url: "/api/acc/icards/AccountCode",
            data: { Parent: code },
            dataType: "json",
            success: function(res) {
                $('#cnt-Code').dxTextBox('option', 'value', res);
            },
            failure: function(response) {
                alert(response);
            },
            error: function(response) {
                alert(response.responseText);
            }
        });
    }
function RefelectAmount() {
           var vatrates = $("#cnt-vatKey").dxSelectBox('instance').option('selectedItem');
        var Price = 0;
        var vatRate = 0;
        var Total = 0;
        Total = $('#cnt-Total').dxNumberBox('option', 'value');
        vatRate = vatrates.Rate;
        Price = Number(Number((Total * 100) / (100 + vatRate)).toFixed(4));
        $('#cnt-Price').dxNumberBox('option', 'value', Price);
}
</script>
